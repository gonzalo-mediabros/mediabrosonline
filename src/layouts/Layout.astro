---
import "@/styles/global.css";
import SEO from "@/components/SEO/SEO.astro";
import ThemePanel from "@/components/dev/ThemePanel.astro";
import Whatsapp from "@/components/atoms/Whatsapp.astro";
import VideoLightbox from "@/components/atoms/VideoLightbox.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonicalURL?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage,
  canonicalURL,
  noindex,
  ogType,
  ogImageAlt,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalURL={canonicalURL}
      noindex={noindex}
      ogType={ogType}
      ogImageAlt={ogImageAlt}
    />

    <!-- Google Fonts: Red Hat Display + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Google Material Icons & Symbols -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/icon?family=Material+Icons"
      rel="stylesheet"
    />
    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-NSVTWGF9");
    </script>
    <!-- End Google Tag Manager -->
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NSVTWGF9"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <slot />
    <Whatsapp />
    <VideoLightbox />

    <!-- {import.meta.env.DEV && <ThemePanel />} -->
    <script>
      import Lenis from "lenis";

      const lenis = new Lenis({
        duration: 0.8,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);
    </script>
  </body>
</html>
