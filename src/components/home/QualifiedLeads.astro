---
import ChipOvertitle from "../atoms/ChipOvertitle.astro";
import Icon from "../atoms/Icon.astro";
import Button from "../atoms/Button.astro";
import Glow from "../atoms/Glow.astro";
import ImageBackground from "../atoms/ImageBackground.astro";

const BASE = import.meta.env.BASE_URL;
---

<section
  id="qualified-leads"
  class="relative py-16 overflow-hidden lg:py-24 bg-brand-fondo isolate"
>
  <m-container class="relative z-10">
    <m-row
      class="flex-col items-center gap-12 lg:flex-row lg:gap-8 lg:items-stretch"
    >
      <!-- Left Column: Content -->
      <m-col
        class="flex flex-col justify-center flex-none w-full lg:w-1/2 lg:pr-8 xl:pr-16"
      >
        <!-- Badge -->
        <div class="mb-6 lg:mb-8">
          <ChipOvertitle text="Nuestra agencia de marketing digital" />
        </div>

        <!-- Heading -->
        <h2
          class="text-4xl md:text-5xl font-display text-brand-dark leading-[1.15] tracking-tight mb-8"
        >
          Recibe leads calificados<br class="hidden md:block" /> de forma constante
        </h2>

        <!-- CTA Button -->
        <div class="mb-12 lg:mb-16">
          <Button
            label="Solicitar diagnóstico"
            href="#contacto"
            variant="celeste"
          />
        </div>

        <!-- Features Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-10">
          <!-- Feature 1 -->
          <div>
            <div
              class="flex items-center justify-center w-8 h-8 mb-4 rounded-full bg-brand-turquesa"
            >
              <Icon
                name="check"
                size={18}
                class="font-black text-brand-celeste"
              />
            </div>
            <h3
              class="mb-2 text-sm tracking-tight md:text-lg font-display text-brand-dark"
            >
              Nuestras certificaciones
            </h3>
            <p class="text-sm leading-relaxed text-brand-gris">
              Somos partners certificados en las principales plataformas de
              publicidad digital, cumpliendo estándares de calidad y buenas
              prácticas.
            </p>
          </div>

          <!-- Feature 2 -->
          <div>
            <div
              class="flex items-center justify-center w-8 h-8 mb-4 rounded-full bg-brand-turquesa"
            >
              <Icon
                name="check"
                size={18}
                class="font-black text-brand-celeste"
              />
            </div>
            <h3
              class="mb-2 text-sm tracking-tight md:text-lg font-display text-brand-dark"
            >
              Tecnología propia
            </h3>
            <p class="text-sm leading-relaxed text-brand-gris">
              Usamos automatización y herramientas internas para optimizar
              campañas más rápido y reducir el desperdicio de inversión.
            </p>
          </div>

          <!-- Feature 3 -->
          <div>
            <div
              class="flex items-center justify-center w-8 h-8 mb-4 rounded-full bg-brand-turquesa"
            >
              <Icon
                name="check"
                size={18}
                class="font-black text-brand-celeste"
              />
            </div>
            <h3
              class="mb-2 text-sm tracking-tight md:text-lg font-display text-brand-dark"
            >
              Tiempos de respuesta
            </h3>
            <p class="text-sm leading-relaxed text-brand-gris">
              Te respondemos con SLA definidos según el tipo de implementación.
              Menos espera, más velocidad para ejecutar mejoras.
            </p>
          </div>

          <!-- Feature 4 -->
          <div>
            <div
              class="flex items-center justify-center w-8 h-8 mb-4 rounded-full bg-brand-turquesa"
            >
              <Icon
                name="check"
                size={18}
                class="font-black text-brand-celeste"
              />
            </div>
            <h3
              class="mb-2 text-sm tracking-tight md:text-lg font-display text-brand-dark"
            >
              Equipo de trabajo
            </h3>
            <p class="text-sm leading-relaxed text-brand-gris">
              Cada cuenta trabaja con un equipo mínimo de 3 especialistas, para
              asegurar continuidad, análisis y ejecución constante.
            </p>
          </div>
        </div>
      </m-col>

      <!-- Right Column: Image with Bleeding Background -->
      <m-col
        class="relative flex items-center justify-center flex-none w-full lg:w-1/2 lg:mt-0 lg:items-end lg:justify-end"
      >
        <!-- Bleeding Dark Background (Breaks out of the grid to the right) -->
        <div
          class="absolute top-[35%] bottom-[0%] left-[-0%] w-screen bg-brand-dark rounded-[30px] z-0"
        >
          <ImageBackground
            src={BASE + "imgs/pattern-ondulado.svg"}
            class="inset-0 w-full h-full opacity-20 mix-blend-luminosity"
          />
          <Glow
            class="top-0 w-full max-w-4xl -translate-x-1/2 left-1/3 h-100 bg-brand-celeste opacity-5 -z-10"
          />
        </div>
        <div class="relative z-10 w-full mx-auto max-w-150 lg:mr-0">
          <img
            src={`${BASE}imgs/home/mano-celu.webp`}
            alt="Tráfico calificado conversiones"
            class="relative w-full h-auto bottom"
          />
        </div>
      </m-col>
    </m-row>
  </m-container>
</section>
