---
import ChipOvertitle from "@/components/atoms/ChipOvertitle.astro";
import Glow from "@/components/atoms/Glow.astro";
import ImageBackground from "@/components/atoms/ImageBackground.astro";
import Button from "@/components/atoms/Button.astro";

const BASE = import.meta.env.BASE_URL;
---

<section id="performance-ai" class="py-16 md:py-24 bg-brand-bg isolate">
  <m-container>
    <div
      class="relative overflow-hidden rounded-xl md:rounded-3xl isolate p-6 md:px-12 md:py-24 bg-brand-dark border border-brand-dark/40 shadow-sm text-white flex items-center min-h-150"
    >
      <ImageBackground
        src={`${BASE}imgs/pattern-ondulado.svg`}
        class="inset-0 w-full h-full pointer-events-none"
        style="opacity: 0.1"
      />
      <Glow class="top-0 -right-150 w-230 h-125 bg-brand-primary/20 blur-3xl" />
      <Glow class="top-0 -left-100 w-150 h-150 bg-indigo-700/20 blur-3xl" />
      <div
        class="hidden lg:block absolute left-[52%] -translate-x-1/2 top-1/2 -translate-y-1/2 z-0"
      >
        <img
          src={`${BASE}imgs/mb-suite-mobile.png`}
          alt="MB Suite app"
          class="h-auto w-90 object-cover opacity-90 animate-float"
        />
      </div>
      <m-row
        class="relative z-10 flex-col justify-between gap-12 lg:flex-row lg:gap-30"
      >
        <!-- COL 1 -->
        <m-col class="lg:w-[35%] flex-none text-white">
          <div class="mb-6"></div>
          <div class="flex items-center gap-5 mb-8">
            <span
              class="text-sm uppercase tracking-widest text-brand-accent-2 font-display mt-2"
              >Creamos</span
            >
            <img
              src={`${BASE}imgs/mbsuite-logo.svg`}
              alt=""
              class="w-32 md:w-40"
            />
          </div>
          <h2
            class="text-4xl md:text-5xl font-display leading-[1.1] tracking-tight mb-8 balan"
          >
            Tu infraestructura para generar leads
          </h2>
          <div
            class="pr-0 space-y-3 text-base leading-relaxed text-white/90 lg:pr-8"
          >
            <p>
              Para crecer necesitás un sistema digital de generación de demanda:
              propio, medible y escalable. MB Suite es la infraestructura donde
              se conecta todo.
            </p>
            <p>Vos tenés el control</p>
          </div>
          <div class="mt-10">
            <Button label="Consultar" href="#contacto" variant="celeste" />
          </div>
        </m-col>
        <!-- COL 2 -->
        <m-col class="lg:w-[32%] flex-none flex flex-col gap-3 w-full shrink">
          <h3
            class="text-xl md:text-2xl font-display font-semibold mb-6 text-white/90 text-center"
          >
            Somos la única agencia en LATAM que te brinda
          </h3>
          <div
            class="relative w-full items-start sm:gap-8 px-4 py-4 sm:px-6 sm:py-4 sm:min-w-0 transition-all rounded-lg bg-white/1 backdrop-blur-sm border border-indigo-500/30 shadow-[0_0_20px_rgba(99,102,241,0.15)] hover:shadow-[0_0_30px_rgba(99,102,241,0.3)] hover:border-indigo-500/60"
          >
            <h3
              class="text-xl mb-2 tracking-tight text-indigo-400 font-display"
            >
              Infraestructura
            </h3>
            <p
              class="text-sm leading-tight text-brand-bg-alt/80 w-full max-w-full"
            >
              Tus activos y el conocimiento de tu marca, todo en un solo lugar
              conectados con IA
            </p>
          </div>
          <div
            class="relative w-full sm:gap-8 px-6 py-4 transition-all rounded-lg bg-white/1 backdrop-blur-sm border border-sky-500/30 shadow-[0_0_20px_rgba(14,107,200,0.15)] hover:shadow-[0_0_30px_rgba(14,107,200,0.3)] hover:border-sky-500/60"
          >
            <h3
              class="text-xl mb-2 tracking-tight text-brand-primary font-display"
            >
              Estrategia
            </h3>
            <p class="text-sm leading-tight text-brand-bg-alt/80">
              Tomá decisiones estratégicas con información real, o delegalas en
              expertos.
            </p>
          </div>
          <div
            class="relative w-full items-start sm:gap-8 px-4 py-4 sm:px-6 sm:py-4 sm:min-w-0 transition-all rounded-lg bg-white/1 backdrop-blur-sm border border-cyan-400/30 shadow-[0_0_20px_rgba(161,249,244,0.1)] hover:shadow-[0_0_30px_rgba(161,249,244,0.25)] hover:border-cyan-400/60"
          >
            <h3
              class="text-xl mb-2 tracking-tight text-brand-accent-2 font-display"
            >
              Ejecución
            </h3>
            <p class="text-sm leading-tight text-brand-bg-alt/80">
              Gestioná internamente o apoyate en nuestro equipo para escalar más
              rápido.
            </p>
          </div>
        </m-col>
      </m-row>
    </div>
  </m-container>
</section>
