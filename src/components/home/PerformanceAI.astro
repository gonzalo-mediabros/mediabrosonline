---
import ChipOvertitle from "@/components/atoms/ChipOvertitle.astro";
import CardSection from "@/components/atoms/CardSection.astro";
import Glow from "@/components/atoms/Glow.astro";
import ImageBackground from "@/components/atoms/ImageBackground.astro";

const BASE = import.meta.env.BASE_URL;
---

<section id="performance-ai" class="py-16 md:py-24 bg-brand-bg isolate">
  <m-container>
    <!-- Outer Blue Container -->
    <CardSection
      variant="primary"
      glowStyle="dual"
      backgroundPattern={BASE + "imgs/pattern-ondulado.svg"}
      backgroundPatternOpacity={1}
      class="flex items-center min-h-150"
    >
      <m-row
        class="relative z-10 flex-col items-center gap-12 lg:flex-row lg:gap-16"
      >
        <!-- Left Side: Text Content -->
        <m-col class="lg:w-[45%] flex-none text-white">
          <!-- Badge -->
          <div class="mb-6">
            <ChipOvertitle text="IA aplicada a performance" theme="dark" />
          </div>

          <!-- Heading -->
          <h2
            class="text-4xl md:text-5xl font-display leading-[1.1] tracking-tight mb-8"
          >
            Mejores resultados con<br class="hidden xl:block" /> optimizaciones 24/7
          </h2>

          <!-- Description Paragraphs -->
          <div
            class="pr-0 space-y-3 text-sm leading-snug text-white/90 lg:pr-8"
          >
            <p>
              Desarrollamos tecnología propia para monitorear y optimizar
              campañas todos los días.
            </p>
            <p>
              Detectamos oportunidades, reducimos desperdicio de inversión y
              aceleramos mejoras para generar más leads con el mismo
              presupuesto.
            </p>
            <p>
              Unimos automatización + criterio humano para lograr performance
              real.
            </p>
          </div>
        </m-col>

        <!-- Right Side: Action Cards -->
        <m-col class="lg:w-[55%] flex-none flex flex-col gap-6 w-full shrink">
          <!-- Card 1: MIA -->
          <div
            class="relative flex flex-col items-start gap-6 px-6 py-8 transition-colors rounded-lg bg-brand-dark md:px-6 md:py-12 sm:flex-row sm:items-center sm:gap-8 hover:bg-brand-dark/95 border border-brand-dark"
          >
            <Glow
              class="top-0 left-100 w-125 h-125 bg-brand-primary opacity-20"
            />
            <!-- Icon -->
            <div class="shrink-0 w-24 md:w-27.5 flex justify-center">
              <img src={`${BASE}imgs/ico-MIA.svg`} alt="" />
            </div>
            <!-- Text -->
            <div class="flex flex-col">
              <h3
                class="mb-2 tracking-tight text-brand-primary font-display text-md"
              >
                MIA: MediaBros Intelligent Automation
              </h3>
              <p class="text-sm leading-tight text-brand-bg-alt/80">
                Optimizaciones automáticas y monitoreo constante para mejorar
                performance y reducir costos
              </p>
            </div>
          </div>

          <!-- Card 2: App -->
          <div
            class="relative flex flex-col items-start gap-6 px-6 py-8 transition-colors rounded-lg bg-brand-dark md:px-6 md:py-12 sm:flex-row sm:items-center sm:gap-8 hover:bg-brand-dark/95 border border-brand-dark"
          >
            <Glow
              class="top-0 left-80 w-125 h-125 bg-brand-primary opacity-10"
            />
            <!-- Icon -->
            <div class="shrink-0 w-24 md:w-27.5 flex justify-center">
              <img src={`${BASE}imgs/ico-mb-suite.svg`} alt="" />
            </div>
            <!-- Text -->
            <div class="flex flex-col">
              <h3
                class="mb-2 tracking-tight text-brand-primary font-display text-md"
              >
                MediaBros App
              </h3>
              <p class="text-sm leading-tight text-brand-bg-alt/80">
                Portal de clientes con estrategia, reportes y performance en
                tiempo real. Toda la información clara, centralizada y
                disponible cuando la necesitás.
              </p>
            </div>
          </div>
        </m-col>
      </m-row>
    </CardSection>
  </m-container>
</section>
