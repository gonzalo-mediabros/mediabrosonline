---
import ChipOvertitle from "../atoms/ChipOvertitle.astro";
import CarruselLoop from "../atoms/CarruselLoop.astro";
import { CLIENTS } from "../../data/clients";
import Glow from "../atoms/Glow.astro";

const BASE = import.meta.env.BASE_URL;
---

<section
  id="clients-carousel"
  class="py-16 md:py-24 bg-brand-fondo isolate overflow-clip"
>
  <div class="container mx-auto max-w-7xl">
    <m-col class="items-center mb-12 text-center md:mb-16">
      <!-- Badge -->
      <div class="mb-6">
        <ChipOvertitle text="Nuestros clientes" />
      </div>
      <!-- Heading -->
      <h2
        class="text-3xl md:text-4xl lg:text-[44px] font-display tracking-tight"
      >
        <span class="text-brand-dark">+150 empresas</span>
        <span class="text-brand-gris">confían en nosotros</span>
      </h2>
    </m-col>

    <!-- Carousel Container -->
    <div class="relative w-full">
      <!-- Left Fade -->
      <div
        class="absolute inset-y-0 left-0 z-10 w-16 pointer-events-none md:w-32 bg-linear-to-r from-brand-fondo to-transparent"
      >
      </div>

      <!-- Right Fade -->
      <div
        class="absolute inset-y-0 right-0 z-10 w-16 pointer-events-none md:w-32 bg-linear-to-l from-brand-fondo to-transparent"
      >
      </div>

      <!-- CarruselLoop — CSS ticker infinito -->
      <CarruselLoop
        speed={100}
        gap="gap-2 md:gap-10 mix-blend-multiply relative"
        pauseOnHover={false}
      >
        {
          CLIENTS.map((client) => (
            <div class="flex items-center justify-center">
              <img
                src={`${BASE}imgs/clientes/${client.url}`}
                alt={client.name}
                title={client.name}
                loading="lazy"
                class="object-contain w-auto h-20 md:h-30 saturate-0"
              />
            </div>
          ))
        }
      </CarruselLoop>
      <Glow
        class="absolute inset-0 w-full h-full left-1/4 bg-brand-celeste opacity-5 z-20"
      />
    </div>
  </div>
</section>
