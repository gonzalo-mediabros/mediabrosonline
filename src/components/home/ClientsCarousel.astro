---
import ChipOvertitle from "../atoms/ChipOvertitle.astro";
import Carrusel from "../atoms/Carrusel.astro";
import { CLIENTS } from "../../data/clients";
import Glow from "../atoms/Glow.astro";

const BASE = import.meta.env.BASE_URL;
---

<section
  id="clients-carousel"
  class="py-16 md:py-24 bg-brand-bg isolate overflow-clip"
>
  <div class="container mx-auto">
    <m-col class="items-center mb-12 text-center md:mb-16">
      <!-- Badge -->
      <div class="mb-6">
        <ChipOvertitle text="Nuestros clientes" />
      </div>
      <!-- Heading -->
      <h2
        class="text-3xl md:text-4xl lg:text-[44px] font-display tracking-tight"
      >
        <span class="text-brand-foreground">+150 empresas</span>
        <span class="text-brand-muted">confían en nosotros</span>
      </h2>
    </m-col>

    <!-- Carousel Container -->
    <div class="relative w-full">
      <!-- Left Fade -->
      <div
        class="absolute inset-y-0 left-0 z-10 w-16 pointer-events-none md:w-182 bg-linear-to-r from-brand-bg to-transparent"
      >
      </div>

      <!-- Right Fade -->
      <div
        class="absolute inset-y-0 right-0 z-10 w-16 pointer-events-none md:w-182 bg-linear-to-l from-brand-bg to-transparent"
      >
      </div>

      <!-- Ticker de logos con Embla AutoScroll -->
      <Carrusel
        slidesPerView="auto"
        loop={true}
        ticker={true}
        pauseOnHover={false}
      >
        {
          CLIENTS.map((client) => (
            <div class="mix-blend-multiply bg-brand-bg">
              <img
                src={`${BASE}imgs/clientes/${client.url}`}
                alt={client.name}
                title={client.name}
                class="block object-contain h-20 md:h-30 saturate-0 mix-blend-multiply opacity-80"
              />
            </div>
          ))
        }
      </Carrusel>
      <Glow
        class="absolute inset-0 w-full h-full left-1/4 bg-brand-primary opacity-5 z-20"
      />
    </div>
  </div>
</section>
