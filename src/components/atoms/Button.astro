---
import Glow from "./Glow.astro";
import Icon from "./Icon.astro";

interface Props extends astroHTML.JSX.AnchorHTMLAttributes, astroHTML.JSX.ButtonHTMLAttributes {
  label: string;
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: "celeste" | "dark" | "white";
  class?: string;
}

const {
  label,
  href,
  type = "button",
  variant = "celeste",
  class: className,
  ...rest
} = Astro.props;

const isLink = !!href;
const Tag = isLink ? "a" : "button";

const variants = {
  celeste: {
    pill: "bg-brand-primary hover:bg-brand-primary-hover text-white ",
    circle: "bg-white/10",
  },
  dark: {
    pill: "bg-brand-dark hover:bg-brand-dark-2 text-white",
    circle: "bg-white/5",
  },
  white: {
    pill: "bg-brand-surface hover:bg-brand-bg-alt text-brand-foreground",
    circle: "bg-brand-dark",
  },
};

const currVariant = variants[variant];
---

<Tag
  href={isLink ? href : undefined}
  type={!isLink ? type : undefined}
  {...rest}
  class:list={[
    "inline-flex items-center gap-3 pl-6 pr-1 py-1 rounded-full font-medium font-display transition-colors no-underline relative overflow-clip",
    isLink ? "cursor-pointer" : "border-none cursor-pointer",
    currVariant.pill,
    className,
  ]}
>
  <Glow class="top-0 z-10 left-10 w-200 h-200 bg-brand-primary/40" />
  <span class="flex-1 text-center">{label}</span>
  <span
    class:list={[
      "flex items-center justify-center rounded-full size-10 shrink-0",
      currVariant.circle,
    ]}
  >
    <Icon
      name="arrow_forward"
      size={18}
      class={variant === "white" ? "text-white" : "text-current"}
    />
  </span>
</Tag>
