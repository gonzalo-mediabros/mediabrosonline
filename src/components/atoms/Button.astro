---
import Icon from "./Icon.astro";

interface Props {
  label: string;
  href?: string;
  variant?: "celeste" | "dark" | "white";
  class?: string;
}

const { label, href = "#", variant = "celeste", class: className } = Astro.props;

const variants = {
  celeste: {
    pill: "bg-brand-celeste hover:bg-brand-celeste-hover text-white shadow-blue",
    circle: "bg-white/20",
  },
  dark: {
    pill: "bg-brand-dark hover:bg-brand-dark-2 text-white",
    circle: "bg-white/15",
  },
  white: {
    pill: "bg-white hover:bg-brand-pastel-gris text-brand-dark",
    circle: "bg-brand-dark",
  },
};

const v = variants[variant];
---

<a
  href={href}
  class:list={[
    "inline-flex items-center gap-3 pl-6 pr-2 py-2 rounded-full font-medium font-display transition-colors no-underline",
    v.pill,
    className,
  ]}
>
  <span>{label}</span>
  <span
    class:list={[
      "flex items-center justify-center rounded-full size-9 shrink-0",
      v.circle,
    ]}
  >
    <Icon
      name="arrow_forward"
      size={18}
      class={variant === "white" ? "text-white" : "text-current"}
    />
  </span>
</a>
