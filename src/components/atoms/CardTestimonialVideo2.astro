---
import Icon from "@/components/atoms/Icon.astro";

interface Props {
  quote: string;
  authorName: string;
  authorRole: string;
  thumbnail?: string;
  videoUrl?: string;
  class?: string;
}

const {
  quote,
  authorName,
  authorRole,
  thumbnail,
  videoUrl,
  class: className = "",
} = Astro.props;

const videoId = videoUrl?.includes("v=")
  ? videoUrl.split("v=")[1]?.split("&")[0]
  : videoUrl?.split("/").pop();

const defaultThumb = videoId
  ? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`
  : undefined;

const thumbSrc = thumbnail || defaultThumb;
---

<div
  class:list={[
    "bg-slate-50 rounded-xl overflow-hidden shadow-sm border border-slate-100 flex flex-row",
    className,
  ]}
>
  <!-- Thumbnail portrait izquierda -->
  <div class="thumbnail-col relative shrink-0 overflow-hidden">
    {
      thumbSrc ? (
        <img
          src={thumbSrc}
          alt={`Video testimonial de ${authorName}`}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      ) : (
        <div class="w-full h-full bg-brand-primary flex items-center justify-center text-white/40">
          <Icon name="play_circle" size={48} />
        </div>
      )
    }

    {
      videoId && (
        <button
          class="play-btn"
          data-open-lightbox={videoId}
          aria-label="Reproducir video"
        >
          <svg viewBox="0 0 24 24" fill="white" class="play-icon">
            <path d="M8 5v14l11-7z" />
          </svg>
        </button>
      )
    }
  </div>

  <!-- Contenido derecho -->
  <div class="p-6 flex flex-col flex-1">
    <div class="flex items-center gap-1 mb-4 text-yellow-400">
      <Icon name="star" size={20} fill={1} />
      <Icon name="star" size={20} fill={1} />
      <Icon name="star" size={20} fill={1} />
      <Icon name="star" size={20} fill={1} />
      <Icon name="star" size={20} fill={1} />
    </div>

    <p
      class="text-slate-700 mb-6 flex-1 italic leading-tight md:leading-relaxed text-sm md:text-base"
    >
      "{quote}"
    </p>

    <div>
      <p class="font-bold text-brand-foreground">{authorName}</p>
      <p class="text-sm text-slate-500">{authorRole}</p>
    </div>
  </div>
</div>

<style>
  .thumbnail-col {
    width: 40%;
    min-height: 200px;
  }

  .thumbnail-col img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumbnail-col:hover img {
    transform: scale(1.05);
  }

  .play-btn {
    position: absolute;
    bottom: 25px;
    left: 25px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .play-btn::before {
    content: "";
    position: absolute;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.25);
    transition: background 0.3s;
  }

  .thumbnail-col:hover .play-btn::before {
    background: rgba(255, 255, 255, 0.45);
  }

  .play-icon {
    position: relative;
    width: 36px;
    height: 36px;
    margin-left: 4px;
    opacity: 0.5;
    transition: opacity 0.3s;
  }

  .thumbnail-col:hover .play-icon {
    opacity: 1;
  }
</style>
