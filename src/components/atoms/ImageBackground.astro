---
interface Props {
  src: string;
  alt?: string;
  class?: string;
  style?: string;
}

const { src, alt = "", class: className, style } = Astro.props;
---

<img
  src={src}
  alt={alt}
  class:list={[
    "ImageBackground absolute pointer-events-none  object-cover",
    className,
  ]}
  style={style}
/>
