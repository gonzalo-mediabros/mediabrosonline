---
import Icon from "@/components/atoms/Icon.astro";

interface Props {
  icon: string;
  iconAlt: string;
  title: string;
  content: string;
  link: string;
  theme?: "light" | "dark";
}

const { icon, iconAlt, title, content, link, theme = "light" } = Astro.props;

const isLight = theme === "light";
---

<a
  href={link}
  class:list={[
    "group flex flex-col rounded-xl p-6 lg:p-8 shadow-sm transition-all duration-300 cursor-pointer no-underline",
    isLight
      ? "bg-brand-surface hover:shadow-lg hover:bg-brand-dark hover:-translate-y-1"
      : "bg-brand-dark",
  ]}
>
  <div class="flex items-center gap-4 mb-6">
    <div
      class:list={[
        "flex items-center justify-center shrink-0 rounded-full border-4 overflow-hidden size-14 transition-colors",
        isLight ? "border-brand-bg group-hover:border-white/20" : "border-white/20",
      ]}
    >
      <img src={icon} alt={iconAlt} class="object-cover size-full" />
    </div>
    <h3
      class:list={[
        "text-xl font-display  tracking-tight transition-colors",
        isLight ? "text-brand-foreground group-hover:text-white" : "text-white",
      ]}
    >
      {title}
    </h3>
  </div>
  <p
    class:list={[
      "text-sm leading-snug transition-colors flex-1 mb-2",
      isLight ? "text-brand-muted group-hover:text-white/80" : "text-white/80",
    ]}
  >
    {content}
  </p>
  <div
    class:list={[
      "flex items-center self-end justify-center w-8 h-8 mt-auto transition-colors rounded-full",
      isLight ? "bg-brand-bg group-hover:bg-white/10" : "bg-white/10",
    ]}
  >
    <!-- flecha -->
    <Icon
      name="arrow_forward"
      size={18}
      class:list={[
        "transition-colors",
        isLight ? "text-brand-muted group-hover:text-white" : "text-white",
      ]}
    />
  </div>
</a>
