---
interface Props {
  text: string;
  icon?: string;
  class?: string;
}

const { text, icon = "verified", class: className = "" } = Astro.props;
---

<span
  class:list={[
    "self-start inline-flex items-center gap-2 rounded-full px-4 py-2 text-xs font-bold uppercase tracking-wide border",
    className,
  ]}
>
  {
    icon && (
      <span class="material-symbols-outlined leading-none text-sm">{icon}</span>
    )
  }
  {text}
</span>
