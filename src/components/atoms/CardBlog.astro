---
import Chip from "./Chip.astro";

interface Props {
  image: string;
  category: string;
  title: string;
  excerpt?: string;
  date: string;
  slug: string;
  variant?: "default" | "compact";
}

const {
  image,
  category,
  title,
  excerpt,
  date,
  slug,
  variant = "default",
} = Astro.props;

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const imagePath = image.startsWith("http")
  ? image
  : `${BASE}/${image.replace(/^\//, "")}`;
const linkPath = `${BASE}/blog/${slug}`;
---

{
  variant === "default" ? (
    <a
      href={linkPath}
      class="flex flex-col md:flex-row md gap-0 overflow-hidden h-full rounded-lg border border-brand-border-subtle bg-brand-bg shadow-sm no-underline text-brand-foreground transition-shadow hover:shadow-md group"
    >
      <div class="w-full md:w-78 shrink-0 overflow-hidden border-r border-brand-border-subtle relative">
        <img
          src={imagePath}
          alt={title}
          class="md:absolute inset-0 min-h-20 w-full h-full max-h-60  object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      </div>
      <div class="p-4 flex flex-col items-start gap-2 flex-1 min-w-0">
        <Chip
          text={category}
          size="sm"
          icon=""
          class="bg-brand-bg-alt border-brand-border"
        />
        <h3 class="text-base md:text-lg font-display font-bold leading-tight group-hover:text-brand-primary transition-colors">
          {title}
        </h3>
        {excerpt && (
          <p class="text-brand-muted text-sm line-clamp-2 mt-auto">{excerpt}</p>
        )}
        <span class="text-xs text-brand-muted font-medium mt-auto pt-2 border-t border-brand-border-subtle w-full">
          {date}
        </span>
      </div>
    </a>
  ) : (
    <a
      href={linkPath}
      class="flex items-center gap-4 group no-underline text-brand-foreground"
    >
      <div class="size-16 rounded-lg overflow-hidden shrink-0 border border-brand-border-subtle">
        <img
          src={imagePath}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
          loading="lazy"
        />
      </div>
      <div class="flex flex-col gap-1 overflow-hidden">
        <h4 class="text-base font-bold font-display leading-tight truncate group-hover:text-brand-primary transition-colors">
          {title}
        </h4>
        <span class="text-xs text-brand-muted font-medium">{date}</span>
      </div>
    </a>
  )
}
