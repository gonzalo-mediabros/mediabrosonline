---
import CardSection from "./CardSection.astro";
import Chip from "./Chip.astro";
import Button from "./Button.astro";

interface Props {
  image: string;
  category: string;
  title: string;
  excerpt?: string;
  date: string;
  slug: string;
  variant?: "default" | "compact";
}

const {
  image,
  category,
  title,
  excerpt,
  date,
  slug,
  variant = "default",
} = Astro.props;

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const imagePath = image.startsWith('http') ? image : `${BASE}/${image.replace(/^\//, '')}`;
const linkPath = `${BASE}/blog/${slug}`;
---

{
  variant === "default" ? (
    <CardSection variant="light" class="!p-0 flex flex-col gap-0 overflow-hidden h-full transition-shadow hover:shadow-md">
      <a href={linkPath} class="block border-b border-brand-border-subtle overflow-hidden">
        <img 
          src={imagePath} 
          alt={title} 
          class="w-full aspect-video object-cover transition-transform duration-500 hover:scale-105" 
          loading="lazy" 
        />
      </a>
      <div class="p-6 md:p-8 flex flex-col items-start gap-4 flex-1">
        <Chip text={category} class="bg-brand-bg-alt border-brand-border" />
        <a href={linkPath} class="no-underline text-brand-foreground hover:text-brand-primary transition-colors">
          <h3 class="text-2xl font-display font-bold leading-tight">
            {title}
          </h3>
        </a>
        {excerpt && (
          <p class="text-brand-muted text-base line-clamp-2 mt-auto">
            {excerpt}
          </p>
        )}
        <div class="flex items-center justify-between w-full mt-4 pt-4 border-t border-brand-border-subtle">
          <span class="text-sm text-brand-muted font-medium">{date}</span>
          <Button href={linkPath} label="Leer más" variant="white" class="h-10 text-sm px-4" />
        </div>
      </div>
    </CardSection>
  ) : (
    <a href={linkPath} class="flex items-center gap-4 group no-underline text-brand-foreground">
      <div class="size-16 rounded-2xl overflow-hidden shrink-0 border border-brand-border-subtle">
        <img 
          src={imagePath} 
          alt={title} 
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" 
          loading="lazy" 
        />
      </div>
      <div class="flex flex-col gap-1 overflow-hidden">
        <h4 class="text-base font-bold font-display leading-tight truncate group-hover:text-brand-primary transition-colors">
          {title}
        </h4>
        <span class="text-xs text-brand-muted font-medium">{date}</span>
      </div>
    </a>
  )
}
