---
import Form from "../form/Form.astro";

type Field = Parameters<typeof Form>[0]["fields"][number];

const DEFAULT_FIELDS: Field[] = [
  { type: "input", name: "nombre", label: "Nombre completo", inputType: "text", required: true },
  { type: "input", name: "website", label: "Sitio web", inputType: "url", required: true },
  { type: "input", name: "email", label: "Email corporativo", inputType: "email", required: true },
  { type: "input", name: "telefono", label: "Teléfono (WhatsApp)", inputType: "tel", required: true },
];

interface Props {
  title?: string;
  subtitle?: string;
  buttonText?: string;
  theme?: "light" | "dark";
  fields?: Field[];
  class?: string;
}

const {
  title = "Asesoramiento personalizado",
  subtitle = "Completa tus datos y nos ponemos en contacto.",
  buttonText = "Enviar",
  theme = "dark",
  fields = DEFAULT_FIELDS,
  class: className,
} = Astro.props;

const isDark = theme === "dark";

const containerClasses = isDark
  ? "bg-[rgba(22,26,41,0.8)] backdrop-blur-xl border border-white/10 rounded-xl shadow-[0_40px_100px_-20px_rgba(0,0,0,0.5)]"
  : "bg-brand-surface rounded-xl border border-slate-100";

const titleClasses = isDark
  ? "font-display text-2xl text-white mb-2 text-center lg:text-left"
  : "text-2xl font-display text-brand-foreground mb-2 text-center";

const subtitleClasses = isDark
  ? "text-sm text-white/70 mb-8 leading-relaxed text-center lg:text-left"
  : "text-slate-500 text-center mb-8";
---

<div class:list={[containerClasses, "px-4 py-10 sm:px-10", className]}>
  {title && <h3 class={titleClasses}>{title}</h3>}
  {subtitle && <p class={subtitleClasses}>{subtitle}</p>}

  <Form fields={fields} buttonText={buttonText} theme={theme} />

  {Astro.slots.has("footer") && (
    <div class:list={["lf-footer", isDark ? "lf-footer--dark" : "lf-footer--light"]}>
      <slot name="footer" />
    </div>
  )}
</div>

<style>
  .lf-footer {
    margin-top: 1.5rem;
    width: 100%;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1.25rem;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .lf-footer--light { color: var(--color-brand-primary); }
  .lf-footer--dark  { color: rgb(148 163 184); }

  .lf-footer :global(fragment) {
    display: contents;
  }

  .lf-footer :global(.footer-item) {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .lf-footer :global(.footer-item .material-symbols-outlined) {
    font-size: 0.875rem !important;
    line-height: 1;
  }
</style>
