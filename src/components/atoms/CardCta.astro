---
/**
 * Componente CardCta
 * Reutiliza Button y Glow para crear una tarjeta de Call to Action.
 */
import Button from "@/components/atoms/Button.astro";
import Glow from "@/components/atoms/Glow.astro";

export interface Props {
  overtitle: string;
  title: string;
  buttonLabel: string;
  buttonHref: string;
  variant?: "dark" | "light";
  align?: "left" | "center" | "right";
  buttonAlign?: "left" | "center" | "right";
  direction?: "row" | "column";
  class?: string;
}

const {
  overtitle,
  title,
  buttonLabel,
  buttonHref,
  variant = "dark",
  align = "left",
  buttonAlign = "left",
  direction = "column",
  class: className,
} = Astro.props as Props;

const isDark = variant === "dark";

// Normalización de link para GitHub Pages
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, ""); // quitar slash final si existe
const finalHref =
  buttonHref.startsWith("http") || buttonHref.startsWith("#")
    ? buttonHref
    : `${baseUrl}${buttonHref.startsWith("/") ? "" : "/"}${buttonHref}`;

const styles = {
  container: isDark
    ? "bg-brand-dark text-white border-none"
    : "bg-brand-surface text-brand-foreground border border-brand-border-subtle shadow-sm",
  overtitle: isDark ? "text-white/70" : "text-brand-muted",
  title: isDark ? "text-white" : "text-brand-foreground",
  glow: isDark ? "bg-brand-primary/20" : "bg-brand-primary/10",
};

const alignClass = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
}[align];
const buttonAlignClass = {
  left: "justify-start",
  center: "justify-center",
  right: "justify-end",
}[buttonAlign];

const isRow = direction === "row";
// En row + right: invertimos el orden (botón a la izquierda, texto a la derecha)
const containerLayout = isRow
  ? `flex-col md:flex-row md:items-center gap-6 md:gap-10${align === "right" ? " md:flex-row-reverse" : ""}`
  : "flex-col gap-6 md:gap-8 justify-between min-h-[16rem]";
---

<div
  class:list={[
    "relative overflow-hidden rounded-2xl p-8 md:p-10 flex",
    containerLayout,
    styles.container,
    className,
  ]}
>
  <Glow class:list={["absolute -top-12 -right-12 w-64 h-64", styles.glow]} />

  <div
    class:list={[
      "space-y-3 relative z-10 transition-transform duration-300",
      isRow && "flex-1",
      alignClass,
    ]}
  >
    <p
      class:list={[
        "text-xs font-bold uppercase tracking-[0.1em] font-display",
        styles.overtitle,
      ]}
    >
      {overtitle}
    </p>
    <h3
      class:list={[
        "text-2xl md:text-3xl font-display font-extrabold leading-[1.1]",
        styles.title,
      ]}
    >
      {title}
    </h3>
  </div>

  <div
    class:list={["relative z-10 flex", !isRow && "mt-auto", buttonAlignClass]}
  >
    <Button
      label={buttonLabel}
      href={finalHref}
      variant="celeste"
      class="w-fit"
    />
  </div>
</div>
