---
/**
 * Icon — Material Symbols + Simple Icons (via astro-icon)
 *
 * lib="material"  → Google Material Symbols (font cargada en Layout)
 *   <Icon name="home" />
 *   <Icon name="favorite" fill={1} weight={300} size={28} />
 *
 * lib="social"    → SVG inline en build time via astro-icon + simple-icons
 *   Slug: buscá el nombre en https://icon-sets.iconify.design/simple-icons/
 *   <Icon lib="social" name="simple-icons:linkedin" size={20} />
 */

import { Icon as AstroIcon } from "astro-icon/components";

interface Props {
  id?: string;
  lib?: "material" | "social";
  name: string;
  // Material Symbols
  fill?: 0 | 1;
  weight?: 100 | 200 | 300 | 400 | 500 | 600 | 700;
  grade?: -25 | 0 | 200;
  opsz?: 20 | 24 | 40 | 48;
  // Común
  size?: number | string;
  class?: string;
  label?: string;
}

const {
  lib = "material",
  name,
  fill = 0,
  weight = 400,
  grade = 0,
  opsz = 24,
  size = 24,
  class: className = "",
  label,
} = Astro.props;

const cssSize = typeof size === "number" ? `${size}px` : size;

const materialStyle = `font-variation-settings: 'FILL' ${fill}, 'wght' ${weight}, 'GRAD' ${grade}, 'opsz' ${opsz}; font-size: ${cssSize}; line-height: 1;`;
---

{
  lib === "material" && (
    <span
      class:list={["material-symbols-outlined select-none", className]}
      style={materialStyle}
      aria-hidden={label ? undefined : "true"}
      aria-label={label}
    >
      {name}
    </span>
  )
}

{
  lib === "social" && (
    <AstroIcon
      name={name}
      width={cssSize}
      height={cssSize}
      class={className}
      aria-hidden={label ? undefined : "true"}
      aria-label={label}
    />
  )
}
