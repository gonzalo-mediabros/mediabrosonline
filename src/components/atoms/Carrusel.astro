---
// Carrusel.astro — Powered by Embla Carousel

import Icon from "@/components/atoms/Icon.astro";

type SlideCount = number | "auto";
type SlidesPerView =
  | SlideCount
  | { base?: SlideCount; sm?: SlideCount; md?: SlideCount; lg?: SlideCount; xl?: SlideCount; "2xl"?: SlideCount };

interface Props {
  ticker?: boolean; /** true = movimiento lineal continuo vía AutoScroll */
  slidesPerView?: SlidesPerView;
  freeMode?: boolean; /** alias legacy de ticker — se trata como ticker=true */
  speed?: number; /** ticker: px/frame para AutoScroll (default 1) · normal: ignorado */
  pauseOnHover?: boolean; /** detiene AutoScroll/autoplay al hover */
  autoplay?: number | false; /** delay en ms para autoplay en modo normal */
  loop?: boolean;
  navigation?: boolean;
  pagination?: boolean;
  theme?: "light" | "dark";
  arrowsPosition?: "bottom" | "sides";
  arrowsX?: "in" | "out";
  direction?: "left" | "right"; /** dirección del ticker */
  gap?:
    | number
    | string; /** gap entre slides en px (string ignorado, usar número) */
}

const {
  ticker: tickerProp = false,
  freeMode = false,
  slidesPerView = 1,
  gap = 24,
  autoplay = false,
  loop = true,
  navigation = false,
  pagination = false,
  speed,
  pauseOnHover = true,
  direction = "left",
  theme = "light",
  arrowsPosition = "bottom",
  arrowsX = "in",
} = Astro.props;

// freeMode es alias legacy de ticker
const ticker = tickerProp || freeMode;

const id = `embla-${Math.random().toString(36).slice(2, 8)}`;

// Gap siempre numérico en px
const gapNum = typeof gap === "number" ? gap : 24;

const computeSlideSize = (spv: SlideCount, g: number) =>
  spv === "auto" ? "auto" : spv === 1 ? "100%" : `calc((100% - ${g * (spv - 1)}px) / ${spv})`;

// Breakpoints Tailwind v4
const bpMap: Record<string, number> = { sm: 640, md: 768, lg: 1024, xl: 1280, "2xl": 1536 };

const isResponsive = typeof slidesPerView === "object" && slidesPerView !== null;

// CSS custom property inicial (base o valor simple)
const baseSpv: SlideCount = isResponsive
  ? ((slidesPerView as Record<string, SlideCount>).base ?? 1)
  : (slidesPerView as SlideCount) ?? 1;
const slideSize = computeSlideSize(baseSpv, gapNum);

// Genera CSS responsive (base + breakpoints) — evita inline style para no perder por especificidad
const responsiveCSS = isResponsive
  ? [
      `#${id} { --embla-slide-size: ${slideSize}; }`,
      ...Object.entries(bpMap)
        .filter(([bp]) => (slidesPerView as Record<string, SlideCount>)[bp] !== undefined)
        .map(([bp, minW]) => {
          const size = computeSlideSize((slidesPerView as Record<string, SlideCount>)[bp], gapNum);
          return `@media (min-width: ${minW}px) { #${id} { --embla-slide-size: ${size}; } }`;
        }),
    ].join("\n")
  : "";

// Velocidad para AutoScroll (px/frame), default 1
const autoScrollSpeed = speed ?? 1;

const showBottomBar = pagination || (arrowsPosition === "bottom" && navigation);
const sidesPrevClass = arrowsX === "out" ? "-left-6" : "left-3";
const sidesNextClass = arrowsX === "out" ? "-right-6" : "right-3";
---

{responsiveCSS && <style is:inline set:html={responsiveCSS} />}

<div class="max-w-full">
  <div
    class:list={[
      "carrusel-wrapper relative",
      arrowsPosition === "sides" && arrowsX === "out" && "overflow-visible",
    ]}
    data-theme={theme}
  >
    <div
      id={id}
      class="embla"
      data-ticker={String(ticker)}
      data-speed={String(autoScrollSpeed)}
      data-loop={String(loop)}
      data-autoplay={autoplay !== false ? String(autoplay) : "false"}
      data-pause-on-hover={String(pauseOnHover)}
      data-navigation={String(navigation)}
      data-direction={direction}
      data-pagination={String(pagination)}
      style={isResponsive ? `--embla-gap: ${gapNum}px;` : `--embla-gap: ${gapNum}px; --embla-slide-size: ${slideSize};`}
    >
      <div class="embla__viewport">
        <div class="embla__container">
          <slot />
        </div>
      </div>
    </div>

    {
      showBottomBar && (
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 mt-10">
          {pagination && (
            <div id={`${id}-dots`} class="embla-pagination flex gap-2" />
          )}
          {arrowsPosition === "bottom" && navigation && (
            <div class="flex gap-3">
              <button
                class="carousel-nav-prev w-11 h-11 rounded-full border flex items-center justify-center transition-all cursor-pointer select-none"
                aria-label="Anterior"
              >
                <Icon name="arrow_back" size={20} />
              </button>
              <button
                class="carousel-nav-next w-11 h-11 rounded-full border flex items-center justify-center transition-all cursor-pointer select-none"
                aria-label="Siguiente"
              >
                <Icon name="arrow_forward" size={20} />
              </button>
            </div>
          )}
        </div>
      )
    }

    {
      arrowsPosition === "sides" && navigation && (
        <>
          <button
            class:list={[
              "carousel-nav-prev w-11 h-11 rounded-full border flex items-center justify-center transition-all cursor-pointer select-none absolute top-1/2 -translate-y-1/2 z-10",
              sidesPrevClass,
            ]}
            aria-label="Anterior"
          >
            <Icon name="arrow_back" size={20} />
          </button>
          <button
            class:list={[
              "carousel-nav-next w-11 h-11 rounded-full border flex items-center justify-center transition-all cursor-pointer select-none absolute top-1/2 -translate-y-1/2 z-10",
              sidesNextClass,
            ]}
            aria-label="Siguiente"
          >
            <Icon name="arrow_forward" size={20} />
          </button>
        </>
      )
    }
  </div>
</div>

<script>
  import EmblaCarousel from "embla-carousel";
  import AutoScroll from "embla-carousel-auto-scroll";

  document
    .querySelectorAll<HTMLElement>(".embla[data-ticker]")
    .forEach((emblaEl) => {
      const ticker = emblaEl.dataset.ticker === "true";
      const speed = parseFloat(emblaEl.dataset.speed ?? "1");
      const loop = emblaEl.dataset.loop !== "false";
      const autoplayDelay =
        emblaEl.dataset.autoplay !== "false"
          ? parseInt(emblaEl.dataset.autoplay ?? "0")
          : false;
      const pauseOnHover = emblaEl.dataset.pauseOnHover === "true";
      const navigation = emblaEl.dataset.navigation === "true";
      const direction = emblaEl.dataset.direction ?? "left";
      const hasPagination = emblaEl.dataset.pagination === "true";

      const viewport = emblaEl.querySelector<HTMLElement>(".embla__viewport");
      if (!viewport) return;

      const plugins: Parameters<typeof EmblaCarousel>[2] = [];
      let autoScrollPlugin: ReturnType<typeof AutoScroll> | null = null;

      if (ticker) {
        autoScrollPlugin = AutoScroll({
          speed,
          direction: direction === "right" ? "backward" : "forward",
          stopOnInteraction: false,

          stopOnMouseEnter: pauseOnHover,

          startDelay: 0,
        });
        plugins.push(autoScrollPlugin);
      }

      const embla = EmblaCarousel(
        viewport,
        { loop, align: "start", dragFree: ticker },
        plugins,
      );

      const wrapper = emblaEl.closest<HTMLElement>(".carrusel-wrapper");
      if (!wrapper) return;

      // — Navegación —
      if (navigation) {
        const prevBtn =
          wrapper.querySelector<HTMLButtonElement>(".carousel-nav-prev");
        const nextBtn =
          wrapper.querySelector<HTMLButtonElement>(".carousel-nav-next");

        if (ticker && autoScrollPlugin) {
          const ap = autoScrollPlugin;
          prevBtn?.addEventListener("click", () => {
            ap.stop();
            embla.scrollPrev();
            setTimeout(() => ap.play(), 400);
          });
          nextBtn?.addEventListener("click", () => {
            ap.stop();
            embla.scrollNext();
            setTimeout(() => ap.play(), 400);
          });
        } else {
          prevBtn?.addEventListener("click", () => embla.scrollPrev());
          nextBtn?.addEventListener("click", () => embla.scrollNext());

          // Deshabilitar botones cuando no hay más slides (solo si loop=false)
          if (!loop) {
            const updateNavState = () => {
              if (prevBtn) prevBtn.disabled = !embla.canScrollPrev();
              if (nextBtn) nextBtn.disabled = !embla.canScrollNext();
            };
            embla.on("init", updateNavState);
            embla.on("select", updateNavState);
            embla.on("reInit", updateNavState);
            updateNavState();
          }
        }
      }

      // — Autoplay normal (no ticker) —
      if (!ticker && autoplayDelay !== false) {
        let timer = setInterval(() => embla.scrollNext(), autoplayDelay);
        if (pauseOnHover) {
          wrapper.addEventListener("mouseenter", () => clearInterval(timer));
          wrapper.addEventListener("mouseleave", () => {
            timer = setInterval(() => embla.scrollNext(), autoplayDelay);
          });
        }
      }

      // — Paginación dots —
      if (hasPagination) {
        const dotsContainer =
          wrapper.querySelector<HTMLElement>(".embla-pagination");
        if (dotsContainer) {
          const createDots = () => {
            dotsContainer.innerHTML = "";
            embla.scrollSnapList().forEach((_, i) => {
              const dot = document.createElement("button");
              dot.className =
                "embla-dot w-2 h-2 rounded-full transition-all duration-300";
              dot.setAttribute("aria-label", `Ir a slide ${i + 1}`);
              dot.addEventListener("click", () => embla.scrollTo(i));
              dotsContainer.appendChild(dot);
            });
          };

          const updateDots = () => {
            const dots =
              dotsContainer.querySelectorAll<HTMLElement>(".embla-dot");
            const selected = embla.selectedScrollSnap();
            dots.forEach((dot, i) => {
              dot.classList.toggle("is-active", i === selected);
            });
          };

          embla.on("init", createDots);
          embla.on("init", updateDots);
          embla.on("select", updateDots);
          embla.on("reInit", createDots);
          embla.on("reInit", updateDots);
          createDots();
          updateDots();
        }
      }
    });
</script>

<style>
  @reference "../../styles/global.css";

  /* Anti-FOUC: el viewport oculta slides desbordados hasta que Embla inicia */
  .embla__viewport {
    overflow: hidden;
  }

  .embla__container {
    display: flex;
    gap: var(--embla-gap, 0px);
  }

  /* Cada hijo directo se comporta como slide.
     :global() es necesario porque los hijos del <slot> pertenecen
     a otro componente y no tienen el mismo data-astro-cid. */
  :global(.embla__container > *) {
    flex: 0 0 var(--embla-slide-size, 100%);
    min-width: 0;
  }

  /* Light theme arrows */
  .carrusel-wrapper[data-theme="light"] .carousel-nav-prev,
  .carrusel-wrapper[data-theme="light"] .carousel-nav-next {
    @apply border-brand-border text-brand-foreground bg-white hover:bg-brand-primary hover:text-white hover:border-brand-primary shadow-sm;
  }

  /* Dark theme arrows */
  .carrusel-wrapper[data-theme="dark"] .carousel-nav-prev,
  .carrusel-wrapper[data-theme="dark"] .carousel-nav-next {
    @apply border-white/10 text-white bg-brand-dark/80 backdrop-blur-md hover:bg-brand-primary hover:border-brand-primary;
  }

  /* Botón deshabilitado */
  .carousel-nav-prev:disabled,
  .carousel-nav-next:disabled {
    @apply opacity-30 cursor-not-allowed grayscale;
  }

  /* Pagination dots — creados dinámicamente por JS, necesitan :global() */
  :global(.embla-dot) {
    @apply bg-brand-muted opacity-30;
  }

  :global(.embla-dot.is-active) {
    @apply opacity-100 w-8 rounded-full bg-brand-primary;
  }

  /* Pagination dots — dark */
  .carrusel-wrapper[data-theme="dark"] :global(.embla-dot) {
    @apply bg-white opacity-20;
  }

  .carrusel-wrapper[data-theme="dark"] :global(.embla-dot.is-active) {
    @apply bg-brand-accent! opacity-100!;
  }
</style>
