---
// Carrusel.astro — powered by Swiper.js
// Each direct slot child must be wrapped in <div class="swiper-slide">

import "swiper/css";
import "swiper/css/navigation";
import "swiper/css/pagination";
import Icon from "./Icon.astro";

interface Props {
  slidesPerView?: number | "auto";
  slidesPerViewMd?: number;
  slidesPerViewLg?: number;
  gap?: number;
  autoplay?: number | false;
  loop?: boolean;
  navigation?: boolean;
  pagination?: boolean;
  theme?: "light" | "dark";
}

const {
  slidesPerView = 1,
  slidesPerViewMd,
  slidesPerViewLg,
  gap = 24,
  autoplay = false,
  loop = true,
  navigation = false,
  pagination = false,
  theme = "light",
} = Astro.props;

const id = `swiper-${Math.random().toString(36).slice(2, 8)}`;

const config = {
  slidesPerView,
  spaceBetween: gap,
  loop,
  autoplay: autoplay !== false ? { delay: autoplay, disableOnInteraction: false } : false,
  navigation: navigation ? { prevEl: `#${id} .carousel-nav-prev`, nextEl: `#${id} .carousel-nav-next` } : false,
  pagination: pagination ? { clickable: true, el: `#${id} .swiper-pagination` } : false,
  breakpoints: {
    ...(slidesPerViewMd !== undefined && { 768: { slidesPerView: slidesPerViewMd } }),
    ...(slidesPerViewLg !== undefined && { 1024: { slidesPerView: slidesPerViewLg } }),
  },
};
---

<div
  id={id}
  class="swiper group"
  data-config={JSON.stringify(config)}
  data-theme={theme}
>
  <div class="swiper-wrapper">
    <slot />
  </div>

  <div class="flex flex-col md:flex-row items-center justify-between gap-6 mt-10">
    {pagination && <div class="swiper-pagination !static !w-fit !m-0"></div>}
    
    {navigation && (
      <div class="swiper-controls flex gap-3">
        <div class="carousel-nav-prev !w-11 !h-11 rounded-full border flex items-center justify-center transition-all cursor-pointer select-none">
          <Icon name="arrow_back" size={20} />
        </div>
        <div class="carousel-nav-next !w-11 !h-11 rounded-full border flex items-center justify-center transition-all cursor-pointer select-none">
          <Icon name="arrow_forward" size={20} />
        </div>
      </div>
    )}
  </div>
</div>

<script>
  import Swiper from "swiper";
  import { Navigation, Pagination, Autoplay } from "swiper/modules";

  document.querySelectorAll<HTMLElement>(".swiper[data-config]").forEach((el) => {
    const raw = el.getAttribute("data-config");
    if (!raw) return;

    const cfg = JSON.parse(raw);
    const modules = [];
    if (cfg.navigation) modules.push(Navigation);
    if (cfg.pagination) modules.push(Pagination);
    if (cfg.autoplay) modules.push(Autoplay);

    new Swiper(el, { ...cfg, modules });
  });
</script>

<style is:global>
  @reference "../../styles/global.css";

  /* Base color for light theme */
  .swiper[data-theme="light"] .carousel-nav-prev,
  .swiper[data-theme="light"] .carousel-nav-next {
    @apply border-brand-border text-brand-foreground bg-white hover:bg-brand-primary hover:text-white hover:border-brand-primary shadow-sm;
  }

  /* Base color for dark theme */
  .swiper[data-theme="dark"] .carousel-nav-prev,
  .swiper[data-theme="dark"] .carousel-nav-next {
    @apply border-white/10 text-white bg-white/5 hover:bg-brand-primary hover:border-brand-primary;
  }

  /* Swiper navigation states */
  .swiper-button-disabled {
    @apply opacity-30 cursor-not-allowed !grayscale;
  }

  /* Pagination styles */
  .swiper-pagination-bullet {
    @apply bg-brand-muted opacity-30 duration-300 transition-all;
  }

  .swiper-pagination-bullet-active {
    @apply !opacity-100 !bg-brand-primary !w-8 !rounded-full;
  }

  .swiper[data-theme="dark"] .swiper-pagination-bullet {
    @apply bg-white opacity-20;
  }

  .swiper[data-theme="dark"] .swiper-pagination-bullet-active {
    @apply !bg-brand-accent !opacity-100;
  }
</style>
