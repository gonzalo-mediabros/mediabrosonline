---
import Icon from "@/components/atoms/Icon.astro";

interface Props {
  quote: string;
  authorName: string;
  authorRole: string;
  thumbnail?: string;
  videoUrl?: string;
  class?: string;
}
const {
  quote,
  authorName,
  authorRole,
  thumbnail,
  videoUrl,
  class: className = "",
} = Astro.props;

// Extraer el ID del video para la miniatura de YouTube si no se provee una
const videoId = videoUrl?.split("v=")[1] || videoUrl?.split("/").pop();
const defaultThumb = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
---

<div
  id="testimonial-card"
  class:list={[
    "bg-slate-50 rounded-xl overflow-hidden shadow-sm border border-slate-100 flex flex-col",
    className,
  ]}
>
  <div class="w-full bg-brand-surface relative h-52">
    {
      videoUrl ? (
        <div class="video-container w-full h-full" data-video-id={videoId}>
          <div class="overlay" id="video-overlay">
            <img src={thumbnail || defaultThumb} alt="Video thumbnail" />
            <button class="play-button" aria-label="Reproducir video">
              <svg viewBox="0 0 24 24" fill="white">
                <path d="M8 5v14l11-7z" />
              </svg>
            </button>
          </div>
          <div id="player-slot" class="w-full h-full" />
        </div>
      ) : (
        <div class="w-full h-60 bg-brand-primary flex items-center justify-center text-white/50">
          <Icon name="play_circle" size={48} />
        </div>
      )
    }
  </div>
  <div class="p-6 flex flex-col flex-1">
    <div class="flex items-center gap-1 mb-4 text-yellow-400">
      <Icon name="star" size={20} fill={1} class="text-yellow-400" />
      <Icon name="star" size={20} fill={1} class="text-yellow-400" />
      <Icon name="star" size={20} fill={1} class="text-yellow-400" />
      <Icon name="star" size={20} fill={1} class="text-yellow-400" />
      <Icon name="star" size={20} fill={1} class="text-yellow-400" />
    </div>
    <p class="text-slate-700 mb-6 flex-1 italic">
      "{quote}"
    </p>
    <div>
      <p class="font-bold text-brand-foreground">{authorName}</p>
      <p class="text-sm text-slate-500">{authorRole}</p>
    </div>
  </div>
</div>
<style>
  .video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #ffffff;
    overflow: hidden;
    cursor: pointer;
  }

  .overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .video-container:hover img {
    transform: scale(1.05);
  }

  .play-button {
    position: absolute;
    width: 60px;
    height: 60px;
    background: rgba(255, 255, 255, 0.301);
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    opacity: 0.3;
  }

  .play-button svg {
    width: 40px;
    height: 40px;
    margin-left: 5px;
  }

  .play-button:hover {
    transform: scale(1.1);
  }

  #testimonial-card:hover .play-button {
    opacity: 1;
  }
  .video-container iframe {
    width: 200%;
    height: 100%;
    border: none;
  }
</style>
<script>
  function setupVideo() {
    const containers = document.querySelectorAll(".video-container");

    containers.forEach((container) => {
      container.addEventListener(
        "click",
        () => {
          const videoId = container.getAttribute("data-video-id");
          const slot = container.querySelector("#player-slot");
          const overlay = container.querySelector("#video-overlay");

          if (slot && overlay) {
            // Inyectamos el iframe solo al hacer click
            slot.innerHTML = `
            <iframe 
            width="100%"
            height="100%"
              src="https://www.youtube.com/embed/${videoId}?autoplay=1&controls=1&rel=0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
       
            ></iframe>
          `;
            overlay.remove(); // Eliminamos el botón y la imagen
          }
        },
        { once: true },
      );
    });
  }

  // Ejecutar en la carga inicial y en navegaciones de Astro
  setupVideo();
  document.addEventListener("astro:after-swap", setupVideo);
</script>
