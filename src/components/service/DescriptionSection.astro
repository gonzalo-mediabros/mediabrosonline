---
import ChipOvertitle from "../ui/ChipOvertitle.astro";
import Button from "../ui/Button.astro";

interface IconItem {
  src: string;
  alt: string;
  label: string;
  description: string;
}

interface Props {
  chipText: string;
  heading: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
  rightContent: "image" | "icons";
  imageSrc?: string;
  imageAlt?: string;
  icons?: IconItem[];
}

const {
  chipText,
  heading,
  description,
  ctaLabel,
  ctaHref,
  rightContent,
  imageSrc,
  imageAlt,
  icons = [],
} = Astro.props;

const BASE = import.meta.env.BASE_URL;
---

<section class="py-16 isolate md:py-24 bg-brand-fondo">
  <m-container>
    <m-row
      class="flex-col items-center gap-12 lg:flex-row lg:gap-8 lg:items-stretch"
    >
      <!-- Left Column: Content -->
      <m-col
        class="flex flex-col justify-center w-full text-sm lg:pr-8 xl:pr-16 basis-1 grow-3"
      >
        <div class="mb-6 lg:mb-8">
          <ChipOvertitle text={chipText} />
        </div>

        <h2
          class="text-4xl md:text-5xl font-display text-brand-dark leading-[1.15] tracking-tight mb-8"
        >
          {heading}
        </h2>

        <p class="mb-8 text-base leading-relaxed md:text-lg text-brand-gris">
          {description}
        </p>

        <Button
          label={ctaLabel}
          href={ctaHref}
          variant="celeste"
          class="self-start"
        />
      </m-col>

      <!-- Right Column -->
      <m-col class="flex items-center justify-center text-sm basis-1 grow-4">
        {
          rightContent === "image" && imageSrc && (
            <img
              src={`${BASE}${imageSrc}`}
              alt={imageAlt ?? ""}
              class="w-full h-auto rounded-lg"
            />
          )
        }

        {
          rightContent === "icons" && (
            <div class="flex flex-col w-full divide-y divide-brand-pastel-gris">
              {icons.map((item) => (
                <div class="flex items-start gap-4 py-6 first:pt-0 last:pb-0">
                  {item.src && (
                    <img
                      src={`${BASE}${item.src}`}
                      alt={item.alt}
                      class="size-12 shrink-0 mt-0.5"
                    />
                  )}
                  <div>
                    <h3 class="text-lg font-display text-brand-dark mb-1.5">
                      {item.label}
                    </h3>
                    <p class="text-sm leading-relaxed text-brand-gris">
                      {item.description}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          )
        }
      </m-col>
    </m-row>
  </m-container>
</section>
