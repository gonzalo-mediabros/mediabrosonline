---
import ChipOvertitle from "../atoms/ChipOvertitle.astro";
import Button from "../atoms/Button.astro";
import Glow from "../atoms/Glow.astro";

interface IconItem {
  src: string;
  alt: string;
  label: string;
  description: string;
}

interface Props {
  chipText: string;
  heading: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
  rightContent: "image" | "icons";
  imageSrc?: string;
  imageAlt?: string;
  icons?: IconItem[];
}

const {
  chipText,
  heading,
  description,
  ctaLabel,
  ctaHref,
  rightContent,
  imageSrc,
  imageAlt,
  icons = [],
} = Astro.props;

const BASE = import.meta.env.BASE_URL;
---

<section class="py-16 isolate md:py-20 bg-brand-fondo">
  <m-container>
    <m-row
      class="flex-col items-center gap-12 lg:flex-row lg:gap-8 lg:items-stretch"
    >
      <!-- Left Column: Content -->
      <m-col
        class="flex flex-col justify-center w-full text-sm lg:pr-8 xl:pr-16 basis-1 grow-3"
      >
        <div class="mb-6 lg:mb-8">
          <ChipOvertitle text={chipText} />
        </div>

        <h2
          class="text-4xl md:text-5xl font-display text-brand-dark leading-[1.15] tracking-tight mb-8"
        >
          {heading}
        </h2>

        <p
          class="mb-8 text-base leading-relaxed md:text-lg text-brand-gris"
          set:html={description}
        />

        <Button
          label={ctaLabel}
          href={ctaHref}
          variant="celeste"
          class="self-start"
        />
      </m-col>

      <!-- Right Column -->
      <m-col class="flex items-center justify-center text-sm basis-1 grow-4">
        <div
          class="relative w-full rounded-3xl overflow-clip h-120 p-2 bg-brand-dark/1"
        >
          <Glow
            class="top-0 z-10 -translate-x-1/2 translate-y-1/2 left-10 w-200 h-200 bg-brand-celeste/40"
          />
          <img
            src={`${BASE}imgs/${imageSrc}`}
            alt={imageAlt ?? ""}
            class="object-cover w-full h-120 opacity-100 brightness-95 max-w-full max-h-full rounded-2xl z-10"
          />
        </div>
      </m-col>
    </m-row>
  </m-container>
</section>
