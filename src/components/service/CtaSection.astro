---
import ChipOvertitle from "../atoms/ChipOvertitle.astro";
import Button from "../atoms/Button.astro";
import Glow from "../atoms/Glow.astro";

interface Props {
  chipText: string;
  heading: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
}

const { chipText, heading, description, ctaLabel, ctaHref } = Astro.props;
---

<section class="py-16 isolate md:py-24 bg-brand-fondo">
  <m-container
    class="relative flex items-center px-6 py-10 overflow-hidden bg-brand-dark rounded-xl shadow-blue/10 md:p-10 lg:p-16"
  >
    <Glow
      class="top-0 w-full -translate-x-1/2 left-100 h-100 bg-brand-dark opacity-20"
    />
    <Glow
      class="w-full -translate-x-1/2 top-30 -left-120 h-200 bg-brand-celeste opacity-15"
    />

    <m-row
      class="relative z-10 flex flex-col items-center justify-center w-full gap-12 lg:gap-16"
    >
      <!-- Left Side: Text Content -->
      <m-col class="flex flex-col items-center text-white gap-14">
        <ChipOvertitle text={chipText} theme="dark" />

        <div class="flex flex-col items-center gap-4">
          <h2 class="mb-2 text-3xl md:text-5xl font-display leading-tight">
            {heading}
          </h2>
          <p
            class="max-w-2xl text-base leading-relaxed text-center text-white/80"
          >
            {description}
          </p>
        </div>

        <Button label={ctaLabel} href={ctaHref} variant="celeste" />
      </m-col>
    </m-row>
  </m-container>
</section>
