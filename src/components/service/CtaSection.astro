---
import ChipOvertitle from "@/components/atoms/ChipOvertitle.astro";
import Button from "@/components/atoms/Button.astro";
import CardSection from "@/components/atoms/CardSection.astro";
import Glow from "@/components/atoms/Glow.astro";

interface Props {
  chipText: string;
  heading: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
}

const { chipText, heading, description, ctaLabel, ctaHref } = Astro.props;
---

<section class="py-16 isolate md:py-20 bg-brand-bg">
  <m-container>
    <CardSection
      variant="dark"
      glowStyle="dual"
      class="flex items-center justify-center px-6 py-10 md:p-10 lg:p-16"
    >
    <m-row
      class="relative z-10 flex flex-col items-center justify-center w-full gap-12 lg:gap-16"
    >
      <!-- Left Side: Text Content -->
      <m-col class="flex flex-col items-center text-white gap-14">
        <ChipOvertitle text={chipText} theme="dark" />

        <div class="flex flex-col items-center gap-4">
          <h2
            class="mb-2 text-3xl text-center md:text-5xl font-display leading-tight"
          >
            {heading}
          </h2>
          <p
            class="max-w-2xl text-base leading-relaxed text-center text-white/80"
            set:html={description}
          />
        </div>

        <Button label={ctaLabel} href={ctaHref} variant="celeste" />
      </m-col>
    </m-row>
    </CardSection>
  </m-container>
</section>
