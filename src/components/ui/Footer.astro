---
import Icon from "./Icon.astro";

interface Props {
  variant?: "dark" | "light";
}

const { variant = "dark" } = Astro.props;
const BASE = import.meta.env.BASE_URL;
---

<!-- ----- FOOTER ----- -->
<footer>
  <!-- --------------- FOOTER --------------- -->
  <section id="footer" class="bg-brand-dark">
    <m-container>
      <!-- Top grid: 4 columns -->
      <m-row
        class="flex-col gap-y-6 gap-x-2 lg:space-between py-20 lg:flex-row flex-wrap"
      >
        <!-- Col 1: Logo + Tagline + Social -->
        <m-col class="flex flex-col items-start gap-6">
          <img
            src={`${BASE}logo.svg`}
            alt="Mediabros"
            class="justify-start object-contain h-12 align-start"
          />
          <p class="text-sm leading-relaxed text-brand-gris">
            Agencia de marketing digital especializada en generación de leads
            para empresas B2B y B2C.
          </p>
          <!-- Social icons -->
          <div class="flex items-center gap-3 mt-2">
            <a
              href="https://www.linkedin.com/company/mediabros-marketing-digital/mycompany/"
              target="_blank"
              rel="noopener"
              aria-label="LinkedIn"
              class="flex items-center justify-center transition-all duration-300 border rounded-full w-9 h-9 border-white/10 text-brand-gris hover:text-white hover:border-brand-celeste hover:bg-brand-celeste/10"
            >
              <Icon lib="social" name="simple-icons:linkedin" size={18} />
            </a>
            <a
              href="https://www.instagram.com/mediabrosmkt/"
              target="_blank"
              rel="noopener"
              aria-label="Instagram"
              class="flex items-center justify-center transition-all duration-300 border rounded-full w-9 h-9 border-white/10 text-brand-gris hover:text-white hover:border-brand-celeste hover:bg-brand-celeste/10"
            >
              <Icon lib="social" name="simple-icons:instagram" size={18} />
            </a>
            <a
              href="https://www.facebook.com/MediaBrosMKT"
              target="_blank"
              rel="noopener"
              aria-label="Facebook"
              class="flex items-center justify-center transition-all duration-300 border rounded-full w-9 h-9 border-white/10 text-brand-gris hover:text-white hover:border-brand-celeste hover:bg-brand-celeste/10"
            >
              <Icon lib="social" name="simple-icons:facebook" size={18} />
            </a>
            <a
              href="https://www.tiktok.com/@mediabroslatam"
              target="_blank"
              rel="noopener"
              aria-label="TikTok"
              class="flex items-center justify-center transition-all duration-300 border rounded-full w-9 h-9 border-white/10 text-brand-gris hover:text-white hover:border-brand-celeste hover:bg-brand-celeste/10"
            >
              <Icon lib="social" name="simple-icons:tiktok" size={18} />
            </a>
          </div>
        </m-col>

        <!-- Col 2: Servicios -->
        <m-col class="flex flex-col gap-4 grow-2 lg:ml-20">
          <h3
            class="mb-2 text-sm font-semibold tracking-widest text-white uppercase font-display"
          >
            Servicios
          </h3>
          <div class="grid grid-cols-2 gap-2">
            {
              [
                "Google Ads",
                "Meta Ads",
                "TikTok Ads",
                "LinkedIn Ads",
                "Bing Ads",
                "Local SEO",
                "Content SEO",
                "Technical SEO",
                "Google Analytics",
                "Asesoramiento",
              ].map((s) => (
                <a
                  href=""
                  class="text-sm transition-colors duration-200 text-brand-gris hover:text-brand-celeste"
                >
                  {s}
                </a>
              ))
            }
          </div>
        </m-col>

        <!-- Col 3: Contenido -->
        <m-col class="flex flex-col gap-4">
          <h3
            class="mb-2 text-sm font-semibold tracking-widest text-white uppercase font-display"
          >
            Contenido
          </h3>
          {
            [
              "Agencia",
              "Testimonios",
              "Blog",
              "Oportunidades",
              "FAQs",
              "Contacto",
            ].map((s) => (
              <a
                href=""
                class="text-sm transition-colors duration-200 text-brand-gris hover:text-brand-celeste"
              >
                {s}
              </a>
            ))
          }
        </m-col>

        <!-- Col 4: Contacto internacional -->
        <m-col class="flex flex-col gap-4">
          <h3
            class="mb-2 text-sm font-semibold tracking-widest text-white uppercase font-display"
          >
            Contacto
          </h3>
          {
            [
              { flag: "usa", label: "USA", tel: "+1 786-828-5062" },
              { flag: "mex", label: "MEX", tel: "+52 55 1328 5398" },
              { flag: "chi", label: "CHL", tel: "+56 2 2582 3484" },
              { flag: "arg", label: "ARG", tel: "+54 11 5983-9447" },
              { flag: "col", label: "COL", tel: "+57 601 5087116" },
            ].map((c) => (
              <a
                href={`tel:${c.tel.replace(/\s/g, "")}`}
                class="flex items-center gap-2 text-sm transition-colors duration-200 text-brand-gris hover:text-white group whitespace-nowrap"
              >
                <img
                  src={`${BASE}flags/${c.flag}.svg`}
                  alt={c.label}
                  class="object-contain w-5 h-auto shrink-0"
                />
                <span class="text-xs font-medium text-white/40 w-7 shrink-0">
                  {c.label}
                </span>
                <span class="transition-colors duration-200 group-hover:text-brand-celeste">
                  {c.tel}
                </span>
              </a>
            ))
          }
        </m-col>
      </m-row>

      <!-- Bottom bar -->
      <m-row
        class="flex flex-col items-center justify-between gap-4 py-6 border-t border-white/8 sm:flex-row"
      >
        <m-col>
          <p class="text-xs text-brand-gris">
            <span class="text-white"
              >© MediaBros {new Date().getFullYear()}
            </span>· Todos los derechos reservados
          </p>
        </m-col>
        <m-col class="flex flex-row justify-end gap-6">
          <a
            href=""
            class="text-xs transition-colors duration-200 text-brand-gris hover:text-white"
            >Políticas de Privacidad</a
          >
          <a
            href=""
            class="text-xs transition-colors duration-200 text-brand-gris hover:text-white"
            >Términos de Uso</a
          >
        </m-col>
      </m-row>
    </m-container>
  </section>
</footer>
