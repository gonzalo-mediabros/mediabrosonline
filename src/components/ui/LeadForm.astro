---
import Button from "../atoms/Button.astro";

interface Props {
  title?: string;
  subtitle?: string;
  buttonText?: string;
  theme?: "light" | "dark";
}

const {
  title = "Asesoramiento personalizado",
  subtitle = "Completa tus datos y ",
  buttonText = "Enviar ",
  theme = "dark",
} = Astro.props;

const isDark = theme === "dark";

// Contenedor principal
const containerClasses = isDark
  ? "bg-[rgba(22,26,41,0.8)] backdrop-blur-xl border border-white/10 rounded-xl  shadow-[0_40px_100px_-20px_rgba(0,0,0,0.5)]"
  : "bg-brand-surface rounded-xl   border border-slate-100";

// Título y Subtítulo
const titleClasses = isDark
  ? "font-display text-2xl  text-white mb-2 text-center lg:text-left"
  : "text-2xl font-display  text-brand-foreground mb-2 text-center";

const subtitleClasses = isDark
  ? "text-sm text-text-light mb-8 leading-relaxed text-center lg:text-left"
  : "text-slate-500 text-center mb-8";

// Labels
const labelClasses = isDark
  ? "block text-xs font-semibold text-text-light uppercase tracking-wide ml-1"
  : "text-sm font-semibold text-slate-700";

// Inputs
const inputClasses = isDark
  ? "w-full py-4 px-5 bg-white/5 border border-white/10 rounded-md text-white placeholder:t"
  : "w-full bg-slate-50 border border-slate-200 rounded-md px-4 py-3 text-brand-foreground focus:outline-none focus:border-brand-primary focus:ring-1 focus:ring-brand-primary transition-base";

// Form attributes
const formId = `lead-form-${Math.random().toString(36).substr(2, 9)}`;
---

<div class={containerClasses + " px-4 py-10 sm:px-10"}>
  {title && <h3 class={titleClasses}>{title}</h3>}
  {subtitle && <p class={subtitleClasses}>{subtitle}</p>}

  <form
    id={formId}
    class={isDark ? "contents" : "flex flex-col gap-4"}
    onsubmit="event.preventDefault();"
  >
    <div class="flex flex-col gap-5">
      <div class="flex flex-col gap-1.5">
        <label for={`${formId}-name`} class={labelClasses}
          >Nombre completo</label
        >
        <input
          type="text"
          id={`${formId}-name`}
          name="nombre"
          required
          placeholder=""
          class={inputClasses}
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for={`${formId}-website`} class={labelClasses}>Sitio web</label>
        <input
          type="url"
          id={`${formId}-website`}
          name="website"
          required
          placeholder=""
          class={inputClasses}
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for={`${formId}-email`} class={labelClasses}
          >Email corporativo</label
        >
        <input
          type="email"
          id={`${formId}-email`}
          name="email"
          required
          placeholder=""
          class={inputClasses}
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for={`${formId}-phone`} class={labelClasses}
          >Teléfono (WhatsApp)</label
        >
        <input
          type="tel"
          id={`${formId}-phone`}
          name="telefono"
          required
          placeholder=""
          class={inputClasses}
        />
      </div>
    </div>

    <Button
      label={buttonText}
      type="submit"
      variant="dark"
      class="w-full justify-between mt-6"
    />

    <div
      class={isDark
        ? "mt-6 flex flex-wrap justify-center items-center text-center gap-4 lg:gap-6 text-sm font-medium text-slate-400 uppercase tracking-wide [&_.footer-item]:flex [&_.footer-item]:items-center [&_.footer-item]:gap-1.5 [&_.material-symbols-outlined]:text-xs"
        : "mt-6 flex flex-wrap justify-center items-center text-center gap-4 lg:gap-6 text-sm font-semibold text-brand-primary uppercase tracking-wide [&_.footer-item]:flex [&_.footer-item]:items-center [&_.footer-item]:gap-1.5 [&_.material-symbols-outlined]:text-xs"}
    >
      <slot name="footer" />
    </div>
  </form>
</div>
