---
import Icon from "./Icon.astro";

export interface Props {
  question: string;
}
const { question } = Astro.props;
---

<details
  class="group border-b border-slate-200 py-6 lg:py-8 w-full transition-all"
>
  <summary
    class="text-xl lg:text-2xl font-display font-bold text-brand-dark flex items-start lg:items-center justify-between gap-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden hover:text-brand-celeste transition-colors"
  >
    <span class="flex-1">{question}</span>
    <div
      class="flex items-center justify-center shrink-0 w-10 h-10 rounded-full bg-slate-50 text-brand-celeste group-hover:bg-brand-celeste/10 transition-all mt-0.5 lg:mt-0"
    >
      <span class="group-open:hidden flex items-center justify-center transition-transform">
        <Icon name="add" size={24} />
      </span>
      <span class="hidden group-open:flex items-center justify-center transition-transform">
        <Icon name="remove" size={24} />
      </span>
    </div>
  </summary>
  <div class="text-slate-600 mt-5 text-lg pr-14 leading-relaxed">
    <slot />
  </div>
</details>
