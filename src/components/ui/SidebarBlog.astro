---
import CardBlog from "../atoms/CardBlog.astro";
import Button from "../atoms/Button.astro";
import { fetchCategories } from "../../lib/wordpress";
import type { NormalizedPost } from "../../lib/wordpress-types";

interface Props {
  recentPosts: NormalizedPost[];
  currentCategory?: string;
}

const { recentPosts, currentCategory } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");

const wpCategories = await fetchCategories();
---

<aside class="flex flex-col gap-8">

  <!-- Categorías -->
  <div class="flex flex-col gap-3">
    <span class="text-xs font-semibold uppercase tracking-widest text-brand-muted-foreground">
      Categorías
    </span>
    <ul class="flex flex-col">
      <li>
        <a
          href={`${BASE}/blog`}
          class:list={[
            "flex items-center gap-2 py-2 text-sm transition-colors border-l-2 pl-3",
            currentCategory === undefined
              ? "border-brand-primary text-brand-primary font-semibold"
              : "border-transparent text-brand-muted hover:text-brand-foreground hover:border-brand-border font-medium",
          ]}
        >
          Todas
        </a>
      </li>
      {wpCategories.map((cat) => (
        <li>
          <a
            href={`${BASE}/blog/categoria/${cat.slug}`}
            class:list={[
              "flex items-center gap-2 py-2 text-sm transition-colors border-l-2 pl-3",
              currentCategory === cat.slug
                ? "border-brand-primary text-brand-primary font-semibold"
                : "border-transparent text-brand-muted hover:text-brand-foreground hover:border-brand-border font-medium",
            ]}
          >
            {cat.name}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Divider -->
  <hr class="border-brand-border-subtle" />

  <!-- Últimas Notas -->
  <div class="flex flex-col gap-4">
    <span class="text-xs font-semibold uppercase tracking-widest text-brand-muted-foreground">
      Últimas notas
    </span>
    <div class="flex flex-col divide-y divide-brand-border-subtle">
      {recentPosts.map((post) => (
        <div class="py-4 first:pt-0 last:pb-0">
          <CardBlog
            variant="compact"
            image={post.image ?? "/imgs/placeholder.jpg"}
            category={post.category}
            title={post.title}
            date={post.date}
            slug={post.slug}
          />
        </div>
      ))}
    </div>
  </div>

  <!-- Divider -->
  <hr class="border-brand-border-subtle" />

  <!-- Banner CTA -->
  <div class="rounded-xl bg-brand-dark px-6 py-8 flex flex-col gap-5">
    <div class="flex flex-col gap-2">
      <span class="text-xs font-semibold uppercase tracking-widest text-brand-accent/70">
        Aumentá tu presencia
      </span>
      <h4 class="text-lg font-bold font-display text-white leading-snug">
        ¿Querés más clientes potenciales?
      </h4>
    </div>
    <p class="text-sm text-white/60 leading-relaxed">
      Te ayudamos a atraer tráfico calificado y convertir visitas en oportunidades reales.
    </p>
    <Button
      href={`${BASE}/contacto`}
      label="Consultar ahora"
      variant="white"
      class="w-full justify-center"
    />
  </div>

</aside>
