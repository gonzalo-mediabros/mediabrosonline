---
import Icon from "../atoms/Icon.astro";
import Glow from "../atoms/Glow.astro";
import ImageBackground from "../atoms/ImageBackground.astro";

const BASE = import.meta.env.BASE_URL;

const services = [
  { name: "Technical SEO", icon: "ico-seo-technical.png", isActive: false },
  { name: "Google Ads", icon: "ico-google-ads.png", isActive: false },
  { name: "Meta Ads", icon: "ico-meta.png", isActive: false },
  { name: "LinkedIn Ads", icon: "ico-linkedin.png", isActive: false },
  { name: "TikTok Ads", icon: "ico-tiktok.png", isActive: false },
  { name: "Content SEO", icon: "ico-seo-content.png", isActive: false },
  { name: "Local SEO", icon: "ico-seo-local.png", isActive: false },
  { name: "Asesoramiento", icon: "ico-asesoramiento.png", isActive: false },
];
---

<!-- --------------- BIG HERO  --------------- -->
<section
  id="hero"
  class="relative flex flex-col min-h-screen px-0 py-0 overflow-hidden xl:py-6 bg-brand-fondo xl:px-14"
>
  <!-- Content Wrapper -->
  <div
    class="relative z-10 flex flex-col flex-1 pb-12 overflow-hidden text-white pt-26 bg-brand-dark md:rounded-4xl"
  >
    <!-- bg image -->
    <ImageBackground
      src={`${BASE}imgs/home/bg-hero.webp`}
      alt=""
      class="absolute w-[105%] h-[105%] object-cover -z-10 opacity-5 top-[-2.5%] left[-2.5%]"
    />
    <ImageBackground
      src={BASE + "imgs/pattern-ondulado.svg"}
      class="inset-0 w-full h-full opacity-5 mix-blend-luminosity"
    />
    <!-- bg gradient -->
    <Glow
      class="w-screen -translate-x-1/2 top-1/2 left-1/2 h-100 bg-brand-celeste opacity-5 -z-10"
    />
    <Glow
      class="bottom-0 w-full max-w-4xl -translate-x-1/2 left-2/3 h-100 bg-brand-dark opacity-80 -z-10"
    />
    <!-- bg image end-->
    <!-- Main Hero Text -->
    <m-row
      class="z-10 flex flex-col justify-center flex-1 py-16 text-center md:py-24"
    >
      <m-container>
        <m-row class="flex-col items-center">
          <m-col class="flex flex-col max-w-4xl gap-6">
            <h1
              class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl font-display leading"
            >
              Generación de leads<br />para empresas
            </h1>
            <h2
              class="text-xl font-bold md:text-3xl font-display text-brand-verde"
            >
              B2B y B2C - Ticket medio / alto
            </h2>
            <p
              class="max-w-2xl mx-auto text-lg leading-relaxed md:text-xl text-brand-pastel-gris"
            >
              Estrategia y gestión de campañas para generar demanda constante y
              oportunidades reales.
            </p>
          </m-col>
        </m-row>
      </m-container>
    </m-row>

    <!-- cards carrusel -->
    <m-row class="z-10 mt-auto">
      <m-container class="relative">
        <!-- Visual Left Arrow -->
        <div
          class="absolute left-0 z-20 items-center justify-center hidden w-12 h-12 transition-colors -translate-y-1/2 border rounded-full cursor-pointer top-1/2 lg:flex bg-brand-dark/80 border-white/10 backdrop-blur-md hover:bg-white/10 shadow-premium"
        >
          <Icon name="chevron_left" size={24} class="text-white" />
        </div>

        <!-- Scrollable Cards Container -->
        <div
          class="flex gap-4 px-2 pb-4 overflow-x-auto md:gap-6 snap-x snap-mandatory lg:px-16"
          style="scrollbar-width: none;"
        >
          {
            services.map((service) => (
              <div
                class={`snap-center sm:snap-start shrink-0 w-65 md:w-75 flex items-center gap-4 rounded-lg p-6 md:p-6 cursor-pointer group transition-colors ${
                  service.isActive
                    ? "bg-white/10 border border-white/20 shadow-card"
                    : "bg-white/5 border border-white/10 hover:bg-white/10"
                }`}
              >
                <div class="flex items-center justify-center bg-white rounded-full size-13 shrink-0">
                  <img
                    src={`${import.meta.env.BASE_URL}imgs/iconos/${service.icon}`}
                    alt={`${service.name} Icon`}
                    class="size-11"
                  />
                </div>
                <div class="flex-1 text-base font-semibold text-left font-display md:text-lg">
                  {service.name}
                </div>
                <Icon
                  name="arrow_forward"
                  size={16}
                  class={`text-sm transition-colors ${
                    service.isActive
                      ? "text-white"
                      : "text-white/40 group-hover:text-white"
                  }`}
                />
              </div>
            ))
          }
        </div>

        <!-- Visual Right Arrow -->
        <div
          class="absolute right-0 z-20 items-center justify-center hidden transition-colors -translate-y-1/2 border rounded-full cursor-pointer top-1/2 size-12 lg:flex bg-brand-dark/80 border-white/10 backdrop-blur-md hover:bg-white/10 shadow-premium"
        >
          <Icon name="chevron_right" size={24} class="text-white" />
        </div>
      </m-container>
    </m-row>
  </div>
</section>
