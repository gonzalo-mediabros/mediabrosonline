---
import Icon from "@/components/atoms/Icon.astro";
import Glow from "@/components/atoms/Glow.astro";
import ImageBackground from "@/components/atoms/ImageBackground.astro";
import Carrusel from "@/components/atoms/Carrusel.astro";
import { getNavItems } from "@/data/navigation";

const BASE = import.meta.env.BASE_URL;

const navItems = getNavItems(BASE);
const services =
  navItems.find((item) => item.label === "Servicios")?.children || [];
---

<!-- --------------- BIG HERO  --------------- -->
<section
  id="hero"
  class="relative flex flex-col h-dvh md:h-auto md:min-h-screen px-0 py-0 overflow-hidden xl:py-6 bg-brand-bg 2xl:px-14"
>
  <!-- Content Wrapper -->
  <div
    class="relative z-10 flex flex-col flex-1 pb-24 md:pb-20 overflow-hidden text-white pt-26 bg-brand-dark md:rounded-3xl"
  >
    <!-- bg image -->
    <ImageBackground
      src={`${BASE}imgs/home/bg-hero.webp`}
      alt=""
      class="absolute w-[105%] h-[105%] object-cover -z-10 opacity-5 top-[-2.5%] left[-2.5%]"
    />
    <ImageBackground
      src={BASE + "imgs/pattern-ondulado.svg"}
      class="inset-0 w-full h-full opacity-5 mix-blend-luminosity"
    />
    <!-- bg gradient -->
    <Glow
      class="w-screen -translate-x-1/2 top-1/2 left-1/2 h-100 bg-brand-primary opacity-5 -z-10"
    />
    <Glow
      class="bottom-0 w-full max-w-4xl -translate-x-1/2 left-2/3 h-100 bg-brand-dark opacity-80 -z-10"
    />

    <!-- Main Hero Text -->
    <m-row
      class="z-10 flex flex-col justify-center flex-1 text-center py:10 md:py-24"
    >
      <m-container>
        <m-row class="flex-col items-center">
          <m-col class="flex flex-col max-w-4xl gap-6">
            <h1
              class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl font-display leading"
            >
              Generación de leads<br />para empresas
            </h1>
            <h2
              class="text-xl font-bold md:text-3xl font-display text-brand-accent"
            >
              B2B y B2C - Ticket medio / alto
            </h2>
            <p
              class="max-w-2xl mx-auto text-lg leading-relaxed md:text-xl text-brand-bg-alt"
            >
              Estrategia y gestión de campañas para generar demanda constante y
              oportunidades reales.
            </p>
          </m-col>
        </m-row>
      </m-container>
    </m-row>

    <!-- cards carrusel -->
    <m-row class="z-10 w-full px-4 xl:px-26">
      <Carrusel
        ticker={true}
        speed={2}
        slidesPerView="auto"
        loop={true}
        autoplay={0}
        pauseOnHover={true}
        arrowsPosition="sides"
        navigation={true}
        arrowsX="out"
        theme="dark"
      >
        {
          services.map((service) => (
            <a href={service.href}>
              <div class="w-65 md:w-75 flex items-center gap-4 rounded-lg p-6 cursor-pointer group transition-colors bg-white/5 border border-white/10 hover:bg-white/10">
                <div class="flex items-center justify-center bg-brand-surface rounded-full size-13 shrink-0">
                  <img
                    src={service.icon}
                    alt={`${service.label} Icon`}
                    class="size-11"
                  />
                </div>
                <div class="flex-1 text-base font-semibold text-left font-display md:text-lg">
                  {service.label}
                </div>
                <Icon
                  name="arrow_forward"
                  size={16}
                  class="text-sm text-white/40 group-hover:text-white transition-colors"
                />
              </div>
            </a>
          ))
        }
      </Carrusel>
    </m-row>
  </div>
</section>
