---
const services = [
  { name: "Technical SEO", icon: "ico-seo-technical.png", isActive: false },
  { name: "Google Ads", icon: "ico-google-ads.png", isActive: false },
  { name: "Meta Ads", icon: "ico-meta.png", isActive: false },
  { name: "LinkedIn Ads", icon: "ico-linkedin.png", isActive: false },
  { name: "TikTok Ads", icon: "ico-tiktok.png", isActive: false },
];
---

<!-- --------------- HERO LEAD GENERATION --------------- -->
<section
  id="hero-lead-gen"
  class="relative min-h-screen flex flex-col bg-brand-dark text-white overflow-hidden"
>
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <!-- Using placehold.co to simulate the background office image -->
    <img
      src="https://placehold.co/1920x1080/1f213d/1f213d?text=+"
      alt="Office Background"
      class="w-full h-full object-cover opacity-40 mix-blend-luminosity"
    />
    <div class="absolute inset-0 bg-brand-dark/80"></div>
  </div>
  <!-- Content Wrapper -->
  <div class="relative z-10 flex flex-col flex-1">
    <!-- Main Hero Text -->
    <main
      class="flex-1 flex flex-col justify-center py-16 md:py-24 text-center"
    >
      <m-container>
        <m-row class="flex-col items-center">
          <m-col class="max-w-4xl space-y-6 md:space-y-8">
            <h1
              class="text-4xl sm:text-5xl md:text-6xl lg:text-[80px] font-display font-bold leading-[1.1] tracking-tight"
            >
              Generación de leads<br />para empresas
            </h1>
            <h2
              class="text-xl md:text-3xl font-display font-bold text-brand-verde"
            >
              B2B y B2C - Ticket medio / alto
            </h2>
            <p
              class="text-lg md:text-xl text-brand-pastel-gris max-w-2xl mx-auto leading-relaxed"
            >
              Estrategia y gestión de campañas para generar demanda constante y
              oportunidades reales.
            </p>
          </m-col>
        </m-row>
      </m-container>
    </main>

    <div class="pb-12 mt-auto">
      <m-container>
        <div class="relative">
          <!-- Visual Left Arrow -->
          <div
            class="absolute left-0 top-1/2 -translate-y-1/2 z-20 w-12 h-12 hidden lg:flex items-center justify-center bg-brand-dark/80 border border-white/10 rounded-full backdrop-blur-md cursor-pointer hover:bg-white/10 transition-colors shadow-premium"
          >
            <m-icon class="material-symbols-outlined text-white"
              >chevron_left</m-icon
            >
          </div>

          <!-- Scrollable Cards Container -->
          <div
            class="flex overflow-x-auto gap-4 md:gap-6 snap-x snap-mandatory pb-4 px-2 lg:px-16"
            style="scrollbar-width: none;"
          >
            {
              services.map((service) => (
                <div
                  class={`snap-center sm:snap-start shrink-0 w-65 md:w-75 flex items-center gap-4 rounded-lg p-6 md:p-6 cursor-pointer group transition-colors ${
                    service.isActive
                      ? "bg-white/10 border border-white/20 shadow-card"
                      : "bg-white/5 border border-white/10 hover:bg-white/10"
                  }`}
                >
                  <div class="size-13 rounded-full bg-white flex items-center justify-center shrink-0">
                    <img
                      src={`${import.meta.env.BASE_URL}iconos/${service.icon}`}
                      alt={`${service.name} Icon`}
                      class="size-11"
                    />
                  </div>
                  <div class="flex-1 text-left font-display font-semibold text-base md:text-lg">
                    {service.name}
                  </div>
                  <m-icon
                    class={`material-symbols-outlined text-sm transition-colors ${
                      service.isActive
                        ? "text-white"
                        : "text-white/40 group-hover:text-white"
                    }`}
                  >
                    arrow_forward
                  </m-icon>
                </div>
              ))
            }
          </div>

          <!-- Visual Right Arrow -->
          <div
            class="absolute right-0 top-1/2 -translate-y-1/2 z-20 size-12 hidden lg:flex items-center justify-center bg-brand-dark/80 border border-white/10 rounded-full backdrop-blur-md cursor-pointer hover:bg-white/10 transition-colors shadow-premium"
          >
            <m-icon class="material-symbols-outlined text-white"
              >chevron_right</m-icon
            >
          </div>
        </div>
      </m-container>
    </div>
  </div>
</section>
