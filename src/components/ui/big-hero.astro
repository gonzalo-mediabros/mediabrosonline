<!-- --------------- HERO LEAD GENERATION --------------- -->
<section
  id="hero-lead-gen"
  class="relative min-h-screen flex flex-col bg-brand-dark text-white overflow-hidden"
>
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <!-- Using placehold.co to simulate the background office image -->
    <img
      src="https://placehold.co/1920x1080/1f213d/1f213d?text=+"
      alt="Office Background"
      class="w-full h-full object-cover opacity-40 mix-blend-luminosity"
    />
    <div class="absolute inset-0 bg-brand-dark/80"></div>
  </div>
  <!-- Content Wrapper -->
  <div class="relative z-10 flex flex-col flex-1">
    <!-- Top Navigation -->
    <header class="py-6">
      <m-container>
        <m-row class="flex-row items-center justify-between">
          <!-- Logo Simulation -->
          <div
            class="flex items-center gap-2 font-display font-bold text-xl md:text-2xl tracking-tight"
          >
            <div
              class="w-8 h-8 bg-white text-brand-dark rounded-full flex items-center justify-center text-sm font-black"
            >
              mb
            </div>
            <span
              >mediabros<span
                class="text-xs align-top opacity-70 ml-1 font-medium"
                >LATAM</span
              ></span
            >
          </div>

          <!-- Desktop Nav -->
          <nav class="hidden md:flex items-center gap-8 text-sm font-medium">
            <a href="#" class="text-brand-turquesa">Inicio</a>
            <a href="#" class="hover:text-brand-turquesa transition-colors"
              >Agencia</a
            >
            <a
              href="#"
              class="hover:text-brand-turquesa transition-colors flex items-center gap-1"
            >
              Servicios
              <m-icon class="material-symbols-outlined text-[16px]"
                >expand_more</m-icon
              >
            </a>
            <a href="#" class="hover:text-brand-turquesa transition-colors"
              >Clientes</a
            >
            <a href="#" class="hover:text-brand-turquesa transition-colors"
              >Contacto</a
            >
          </nav>

          <!-- Mobile Menu Icon (Visual only) -->
          <button class="md:hidden text-white">
            <m-icon class="material-symbols-outlined text-3xl">menu</m-icon>
          </button>
        </m-row>
      </m-container>
    </header>

    <!-- Main Hero Text -->
    <main
      class="flex-1 flex flex-col justify-center py-16 md:py-24 text-center"
    >
      <m-container>
        <m-row class="flex-col items-center">
          <m-col class="max-w-4xl space-y-6 md:space-y-8">
            <h1
              class="text-4xl sm:text-5xl md:text-6xl lg:text-[80px] font-display font-bold leading-[1.1] tracking-tight"
            >
              Generación de leads<br />para empresas
            </h1>
            <h2
              class="text-xl md:text-3xl font-display font-bold text-brand-verde"
            >
              B2B y B2C - Ticket medio / alto
            </h2>
            <p
              class="text-lg md:text-xl text-brand-pastel-gris max-w-2xl mx-auto leading-relaxed"
            >
              Estrategia y gestión de campañas para generar demanda constante y
              oportunidades reales.
            </p>
          </m-col>
        </m-row>
      </m-container>
    </main>

    <!-- Bottom Carousel (CSS-only implementation to meet strict constraints) -->
    <div class="pb-12 mt-auto">
      <m-container>
        <div class="relative">
          <!-- Visual Left Arrow -->
          <div
            class="absolute left-0 top-1/2 -translate-y-1/2 z-20 w-12 h-12 hidden lg:flex items-center justify-center bg-brand-dark/80 border border-white/10 rounded-full backdrop-blur-md cursor-pointer hover:bg-white/10 transition-colors shadow-premium"
          >
            <m-icon class="material-symbols-outlined text-white"
              >chevron_left</m-icon
            >
          </div>

          <!-- Scrollable Cards Container -->
          <div
            class="flex overflow-x-auto gap-4 md:gap-6 snap-x snap-mandatory pb-4 px-2 lg:px-16"
            style="scrollbar-width: none;"
          >
            <!-- Card 1 -->
            <div
              class="snap-center sm:snap-start shrink-0 w-65 md:w-75 bg-white/5 border border-white/10 rounded-xl p-4 md:p-5 flex items-center gap-4 hover:bg-white/10 transition-colors cursor-pointer group"
            >
              <div
                class="w-12 h-12 rounded-full bg-white flex items-center justify-center shrink-0"
              >
                <img
                  src="https://placehold.co/40x40/ffffff/1f213d?text=SEO"
                  alt="Technical SEO Icon"
                  class="w-8 h-8 rounded-full"
                />
              </div>
              <div
                class="flex-1 text-left font-display font-semibold text-base md:text-lg"
              >
                Technical SEO
              </div>
              <m-icon
                class="material-symbols-outlined text-white/40 group-hover:text-white transition-colors text-sm"
                >arrow_forward</m-icon
              >
            </div>

            <!-- Card 2 (Active state simulation) -->
            <div
              class="snap-center sm:snap-start shrink-0 w-[260px] md:w-[300px] bg-white/10 border border-white/20 rounded-xl p-4 md:p-5 flex items-center gap-4 cursor-pointer group shadow-card"
            >
              <div
                class="w-12 h-12 rounded-full bg-white flex items-center justify-center shrink-0"
              >
                <img
                  src="https://placehold.co/40x40/ffffff/1f213d?text=GAds"
                  alt="Google Ads Icon"
                  class="w-8 h-8 rounded-full"
                />
              </div>
              <div
                class="flex-1 text-left font-display font-semibold text-base md:text-lg"
              >
                Google Ads
              </div>
              <m-icon
                class="material-symbols-outlined text-white transition-colors text-sm"
                >arrow_forward</m-icon
              >
            </div>

            <!-- Card 3 -->
            <div
              class="snap-center sm:snap-start shrink-0 w-[260px] md:w-[300px] bg-white/5 border border-white/10 rounded-xl p-4 md:p-5 flex items-center gap-4 hover:bg-white/10 transition-colors cursor-pointer group"
            >
              <div
                class="w-12 h-12 rounded-full bg-white flex items-center justify-center shrink-0"
              >
                <img
                  src="https://placehold.co/40x40/ffffff/1f213d?text=Meta"
                  alt="Meta Ads Icon"
                  class="w-8 h-8 rounded-full"
                />
              </div>
              <div
                class="flex-1 text-left font-display font-semibold text-base md:text-lg"
              >
                Meta Ads
              </div>
              <m-icon
                class="material-symbols-outlined text-white/40 group-hover:text-white transition-colors text-sm"
                >arrow_forward</m-icon
              >
            </div>

            <!-- Card 4 -->
            <div
              class="snap-center sm:snap-start shrink-0 w-[260px] md:w-[300px] bg-white/5 border border-white/10 rounded-xl p-4 md:p-5 flex items-center gap-4 hover:bg-white/10 transition-colors cursor-pointer group"
            >
              <div
                class="w-12 h-12 rounded-full bg-white flex items-center justify-center shrink-0"
              >
                <img
                  src="https://placehold.co/40x40/ffffff/1f213d?text=IN"
                  alt="LinkedIn Ads Icon"
                  class="w-8 h-8 rounded-full"
                />
              </div>
              <div
                class="flex-1 text-left font-display font-semibold text-base md:text-lg"
              >
                LinkedIn Ads
              </div>
              <m-icon
                class="material-symbols-outlined text-white/40 group-hover:text-white transition-colors text-sm"
                >arrow_forward</m-icon
              >
            </div>

            <!-- Card 5 -->
            <div
              class="snap-center sm:snap-start shrink-0 w-[260px] md:w-[300px] bg-white/5 border border-white/10 rounded-xl p-4 md:p-5 flex items-center gap-4 hover:bg-white/10 transition-colors cursor-pointer group"
            >
              <div
                class="w-12 h-12 rounded-full bg-white flex items-center justify-center shrink-0"
              >
                <img
                  src="https://placehold.co/40x40/ffffff/1f213d?text=TK"
                  alt="TikTok Ads Icon"
                  class="w-8 h-8 rounded-full"
                />
              </div>
              <div
                class="flex-1 text-left font-display font-semibold text-base md:text-lg"
              >
                TikTok Ads
              </div>
              <m-icon
                class="material-symbols-outlined text-white/40 group-hover:text-white transition-colors text-sm"
                >arrow_forward</m-icon
              >
            </div>
          </div>

          <!-- Visual Right Arrow -->
          <div
            class="absolute right-0 top-1/2 -translate-y-1/2 z-20 w-12 h-12 hidden lg:flex items-center justify-center bg-brand-dark/80 border border-white/10 rounded-full backdrop-blur-md cursor-pointer hover:bg-white/10 transition-colors shadow-premium"
          >
            <m-icon class="material-symbols-outlined text-white"
              >chevron_right</m-icon
            >
          </div>
        </div>
      </m-container>
    </div>
  </div>
</section>
