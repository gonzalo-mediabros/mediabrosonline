---
import ChipOvertitle from "@/components/atoms/ChipOvertitle.astro";
const BASE = import.meta.env.BASE_URL;
---

<!-- --------------- CERTIFICATIONS --------------- -->
<section id="certifications" class="py-18 md:py-24 bg-brand-bg-alt">
  <m-container>
    <m-row
      class="flex-col items-center justify-between gap-10 lg:flex-row lg:gap-8"
    >
      <!-- Left: Title Area -->
      <m-col
        class="items-center flex-none w-full gap-6 text-center lg:items-start lg:text-left lg:w-auto"
      >
        <ChipOvertitle text=" Expertos en Marketing Digital" />
        <h2
          class="text-3xl md:text-4xl lg:text-5xl font-display text-brand-foreground tracking-tight w."
        >
          Certificaciones
        </h2>
      </m-col>

      <!-- Right: Badges Area -->
      <m-col class="w-full lg:w-auto">
        <div
          class="flex flex-row items-center flex-nowrap w-full max-w-xl mx-auto"
        >
          <!-- Left Laurel -->
          <img
            src={`${BASE}imgs/badges/laurel-izq.png`}
            alt="Laurel decorativo izquierdo"
            class="h-12 md:h-20 object-contain opacity-50"
          />

          <!-- Badges -->
          <div
            class="flex flex-row items-center flex-nowrap flex-1 gap-0 md:gap-2 mix-blend-multiply justify-center"
          >
            <img
              src={`${BASE}imgs/badges/badge-google.png`}
              alt="Google Partner Premier"
              class="h-16 md:h-24 object-contain"
            />
            <img
              src={`${BASE}imgs/badges/badge-meta.png`}
              alt="Meta Business Partner"
              class="h-16 md:h-24 object-contain"
            />
            <img
              src={`${BASE}imgs/badges/badge-linkedin.png`}
              alt="LinkedIn Marketing Partners"
              class="h-16 md:h-24 object-contain"
            />
            <img
              src={`${BASE}imgs/badges/badge-mb.png`}
              alt="+15 Años de experiencia"
              class="h-16 md:h-24 object-contain"
            />
          </div>

          <!-- Right Laurel -->
          <img
            src={`${BASE}imgs/badges/laurel-der.png`}
            alt="Laurel decorativo derecho"
            class="h-12 md:h-20 object-contain opacity-50"
          />
        </div>
      </m-col>
    </m-row>
  </m-container>
</section>
