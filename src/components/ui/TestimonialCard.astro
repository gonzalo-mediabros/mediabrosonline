---
interface Props {
  quote: string;
  authorName: string;
  authorRole: string;
  authorImage: string;
  class?: string;
}
const {
  quote,
  authorName,
  authorRole,
  authorImage,
  class: className = "",
} = Astro.props;
---

<div
  class:list={[
    "bg-slate-50 rounded-xl p-8 shadow-card border border-slate-100 flex flex-col",
    className,
  ]}
>
  <div class="block m-0 mb-4">
    <m-icon
      class="text-amber-400 material-symbols-outlined"
      style="font-variation-settings: 'FILL' 1;">star</m-icon
    >
    <m-icon
      class="text-amber-400 material-symbols-outlined"
      style="font-variation-settings: 'FILL' 1;">star</m-icon
    >
    <m-icon
      class="text-amber-400 material-symbols-outlined"
      style="font-variation-settings: 'FILL' 1;">star</m-icon
    >
    <m-icon
      class="text-amber-400 material-symbols-outlined"
      style="font-variation-settings: 'FILL' 1;">star</m-icon
    >
    <m-icon
      class="text-amber-400 material-symbols-outlined"
      style="font-variation-settings: 'FILL' 1;">star</m-icon
    >
  </div>
  <p class="text-slate-700 mb-4 flex-1 italic text-lg leading-normal">
    "{quote}"
  </p>
  <div class="flex items-center gap-4 border-t border-slate-100 pt-6">
    <img
      src={authorImage}
      alt={authorName}
      class="w-14 h-14 rounded-full object-cover border border-slate-200 shadow-sm"
    />
    <div>
      <p class="font-bold text-brand-dark text-lg">{authorName}</p>
      <p class="text-sm text-slate-500 leading-tight mt-0.5 max-w-50">
        {authorRole}
      </p>
    </div>
  </div>
</div>
