---
interface Props {
  pathname?: string;
}

const { pathname = "/" } = Astro.props;

const BASE = import.meta.env.BASE_URL;

const services = [
  { label: "Google Ads", icon: `${BASE}iconos/ico-google-ads.png` },
  { label: "Meta Ads", icon: `${BASE}iconos/ico-meta.png` },
  { label: "LinkedIn Ads", icon: `${BASE}iconos/ico-linkedin.png` },
  { label: "Tiktok Ads", icon: `${BASE}iconos/ico-tiktok.png` },
  { label: "Content SEO", icon: `${BASE}iconos/ico-seo-content.png` },
  { label: "Technical SEO", icon: `${BASE}iconos/ico-seo-technical.png` },
  { label: "Local SEO", icon: `${BASE}iconos/ico-seo-local.png` },
  { label: "Asesoramiento", icon: `${BASE}iconos/ico-asesoramiento.png` },
];

const navItems = [
  { label: "Inicio", href: BASE },
  { label: "Agencia", href: `${BASE}agencia` },
  { label: "Clientes", href: `${BASE}clientes` },
  { label: "Contacto", href: `${BASE}contacto` },
];

const isActive = (href: string) => {
  const normalized = href.endsWith("/") ? href : `${href}/`;
  const current = pathname.endsWith("/") ? pathname : `${pathname}/`;
  return current === normalized;
};
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 py-5 text-white transition-all duration-300"
>
  <m-container class="font-display">
    <m-row class="flex-row items-center justify-between">
      <!-- Logo -->
      <a href={BASE} class="">
        <img src={`${BASE}logo.svg`} alt="Mediabros online" />
      </a>

      <!-- Desktop Nav -->
      <nav class="items-center hidden gap-8 text-lg md:flex">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "transition-colors hover:text-brand-turquesa",
                isActive(item.href) ? "text-brand-turquesa" : "",
              ]}
            >
              {item.label}
            </a>
          ))
        }

        <!-- Servicios dropdown trigger -->
        <div class="relative" id="services-trigger-wrap">
          <button
            id="services-trigger"
            aria-expanded="false"
            aria-haspopup="true"
            class="flex items-center gap-1 p-0 text-lg transition-colors bg-transparent border-0 cursor-pointer hover:text-brand-turquesa text-inherit"
          >
            Servicios
            <m-icon
              id="services-chevron"
              class="material-symbols-outlined text-[16px] transition-transform duration-200"
            >
              expand_more
            </m-icon>
          </button>

          <!-- Dropdown panel -->
          <div
            id="services-dropdown"
            role="menu"
            class="absolute right-0 hidden p-4 mt-3 shadow-xl w-150 top-full bg-brand-dark rounded-2xl"
          >
            <ul class="grid grid-cols-2 gap-1" role="none">
              {
                services.map((svc) => (
                  <li role="none">
                    <a
                      href="#services-multichannel"
                      role="menuitem"
                      class="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/10 transition-colors text-white/90 hover:text-white text-md no-underline"
                    >
                      <img
                        src={svc.icon}
                        alt=""
                        class="object-contain size-8 shrink-0"
                      />
                      <span class="whitespace-nowrap">{svc.label}</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </nav>

      <!-- Burger button (mobile) -->
      <button
        id="burger-btn"
        class="p-1 text-white bg-transparent border-0 cursor-pointer md:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <m-icon class="text-3xl material-symbols-outlined">menu</m-icon>
      </button>
    </m-row>
  </m-container>
</header>

<!-- ------------------------------------------  MOBILE MENU ------------------------------------------ -->
<div
  id="mobile-menu"
  class="fixed inset-0 flex pointer-events-none z-60 md:hidden font-display"
  aria-hidden="true"
>
  <!-- Overlay -->
  <div
    id="mobile-overlay"
    class="absolute inset-0 transition-opacity duration-300 opacity-0 bg-black/60"
  >
  </div>

  <!-- Panel (slide from right) -->
  <div
    id="mobile-panel"
    class="relative flex flex-col w-4/5 h-full max-w-sm ml-auto overflow-y-auto transition-transform duration-300 translate-x-full bg-brand-dark"
  >
    <!-- Panel header -->
    <div
      class="flex items-center justify-between px-6 py-5 border-b border-white/10"
    >
      <img src={`${BASE}logo.svg`} alt="Mediabros online" class="h-10" />
      <button
        id="close-btn"
        class="p-1 text-white bg-transparent border-0 cursor-pointer"
        aria-label="Cerrar menú"
      >
        <m-icon class="text-2xl material-symbols-outlined">close</m-icon>
      </button>
    </div>

    <!-- Nav items -->
    <nav class="flex flex-col px-4 py-4">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "flex items-center px-4 py-3.5 rounded-xl text-md font-medium transition-colors no-underline",
              isActive(item.href)
                ? "text-brand-turquesa bg-white/5"
                : "text-white/80 hover:text-white hover:bg-white/10",
            ]}
          >
            {item.label}
          </a>
        ))
      }

      <!-- Servicios — expanded inline -->
      <div class="pt-4 mt-2 border-t border-white/10">
        <p class="px-4 mb-2 text-sm tracking-widest uppercase text-white/40">
          Servicios
        </p>
        {
          services.map((svc) => (
            <a
              href="#services-multichannel"
              class="flex items-center gap-3 px-4 py-3 no-underline transition-colors text-md rounded-xl text-white/80 hover:text-white hover:bg-white/10"
            >
              <img
                src={svc.icon}
                alt=""
                class="object-contain size-8 shrink-0"
              />
              <span>{svc.label}</span>
            </a>
          ))
        }
      </div>
    </nav>
  </div>
</div>

<script>
  // ------------------------------------------ CONFIG ------------------------------------------
  const STICKY_THRESHOLD = 200; // px — header gains solid bg after this scroll depth

  // ------------------------------------------ ELEMENTS ------------------------------------------
  const header = document.getElementById("main-header")!;
  const burgerBtn = document.getElementById("burger-btn")!;
  const closeBtn = document.getElementById("close-btn")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const mobilePanel = document.getElementById("mobile-panel")!;
  const mobileOverlay = document.getElementById("mobile-overlay")!;
  const servicesTrigger = document.getElementById("services-trigger")!;
  const servicesDropdown = document.getElementById("services-dropdown")!;
  const servicesChevron = document.getElementById("services-chevron")!;

  // ------------------------------------------ MOBILE MENU ------------------------------------------
  const openMobile = () => {
    mobileMenu.classList.remove("pointer-events-none");
    mobileMenu.setAttribute("aria-hidden", "false");
    mobileOverlay.classList.add("opacity-100");
    mobilePanel.classList.remove("translate-x-full");
    burgerBtn.setAttribute("aria-expanded", "true");
  };

  const closeMobile = () => {
    mobileMenu.classList.add("pointer-events-none");
    mobileMenu.setAttribute("aria-hidden", "true");
    mobileOverlay.classList.remove("opacity-100");
    mobilePanel.classList.add("translate-x-full");
    burgerBtn.setAttribute("aria-expanded", "false");
  };

  burgerBtn.addEventListener("click", openMobile);
  closeBtn.addEventListener("click", closeMobile);
  mobileOverlay.addEventListener("click", closeMobile);

  mobilePanel
    .querySelectorAll("a")
    .forEach((link) => link.addEventListener("click", closeMobile));

  // ------------------------------------------ SERVICES DROPDOWN ------------------------------------------
  const openDropdown = () => {
    servicesDropdown.classList.remove("hidden");
    servicesTrigger.setAttribute("aria-expanded", "true");
    servicesChevron.classList.add("rotate-180");
  };

  const closeDropdown = () => {
    servicesDropdown.classList.add("hidden");
    servicesTrigger.setAttribute("aria-expanded", "false");
    servicesChevron.classList.remove("rotate-180");
  };

  servicesTrigger.addEventListener("click", (e) => {
    e.stopPropagation();
    servicesDropdown.classList.contains("hidden")
      ? openDropdown()
      : closeDropdown();
  });

  document.addEventListener("click", (e) => {
    if (
      !servicesTrigger.contains(e.target as Node) &&
      !servicesDropdown.contains(e.target as Node)
    ) {
      closeDropdown();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeDropdown();
      closeMobile();
    }
  });

  servicesDropdown
    .querySelectorAll("a")
    .forEach((link) => link.addEventListener("click", closeDropdown));

  // ------------------------------------------ SCROLL STICKY ----------------------------------------------
  const STICKY_CLASSES = ["bg-brand-dark/95", "shadow-md", "backdrop-blur-sm"];

  const updateHeader = () => {
    if (window.scrollY >= STICKY_THRESHOLD) {
      header.classList.add(...STICKY_CLASSES);
    } else {
      header.classList.remove(...STICKY_CLASSES);
    }
  };

  window.addEventListener("scroll", updateHeader, { passive: true });
  updateHeader(); // run once on load in case page is already scrolled
</script>
