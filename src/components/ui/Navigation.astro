---
import Icon from "../atoms/Icon.astro";
import NavDesktop from "./NavDesktop.astro";
import NavMobile from "./NavMobile.astro";
import { getNavItems } from "../../data/navigation";

interface Props {
  theme?: "dark" | "light";
  pathname?: string;
  logo?: string;
}

const { theme = "dark", pathname = "/", logo } = Astro.props;
const BASE = import.meta.env.BASE_URL;
const navItems = getNavItems(BASE);

const defaultLogo = theme === "dark" ? `${BASE}imgs/logo-blanco.svg` : `${BASE}imgs/logo.svg`;
const logoStatic = logo ? `${BASE}imgs/${logo}` : defaultLogo;
const logoSticky = `${BASE}imgs/logo.svg`;
const staticTextClass = theme === "dark" ? "text-white" : "text-brand-dark";
---

<!-- -------------------------- STATIC HEADER -------------------------- -->
<header
  id="header-static"
  class:list={[
    "absolute top-0 left-0 right-0 z-20 py-5 md:top-15 xl:px-16",
    staticTextClass,
  ]}
>
  <m-container class="font-display lg:max-w-[calc(100%-100px)]">
    <m-row class="flex-row items-center justify-between">
      <a href={BASE}>
        <img src={logoStatic} alt="Mediabros online" class="h-10" />
      </a>

      <NavDesktop navItems={navItems} pathname={pathname} theme={theme} />

      <button
        id="burger-btn"
        class="p-1 bg-transparent border-0 cursor-pointer md:hidden text-inherit"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <Icon name="menu" size={32} />
      </button>
    </m-row>
  </m-container>
</header>

<!-- -------------------------- STICKY HEADER -------------------------- -->
<header
  id="header-sticky"
  class="fixed top-0 left-0 right-0 z-20 py-3 transition-all duration-300 ease-in-out -translate-y-full opacity-0 bg-brand-fondo border-b border-brand-gris/15 text-brand-dark xl:px-16"
  aria-hidden="true"
>
  <m-container class="font-display lg:max-w-[calc(100%-100px)]">
    <m-row class="flex-row items-center justify-between">
      <a href={BASE}>
        <img src={logoSticky} alt="Mediabros online" class="h-9" />
      </a>

      <NavDesktop navItems={navItems} pathname={pathname} theme="light" />

      <button
        id="burger-btn-sticky"
        class="p-1 bg-transparent border-0 cursor-pointer md:hidden text-inherit"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <Icon name="menu" size={32} />
      </button>
    </m-row>
  </m-container>
</header>

<!-- -------------------------- MOBILE MENU -------------------------- -->
<NavMobile navItems={navItems} pathname={pathname} BASE={BASE} />

<!-- -------------------------- SCRIPT -------------------------- -->
<script>
  const STICKY_THRESHOLD = 400;
  const stickyHeader = document.getElementById("header-sticky")!;
  const burgerBtnSticky = document.getElementById("burger-btn-sticky");
  const burgerBtn = document.getElementById("burger-btn");

  const updateSticky = () => {
    if (window.scrollY >= STICKY_THRESHOLD) {
      stickyHeader.classList.remove("-translate-y-full", "opacity-0");
      stickyHeader.classList.add("translate-y-0", "opacity-100");
      stickyHeader.removeAttribute("aria-hidden");
    } else {
      stickyHeader.classList.remove("translate-y-0", "opacity-100");
      stickyHeader.classList.add("-translate-y-full", "opacity-0");
      stickyHeader.setAttribute("aria-hidden", "true");
    }
  };

  burgerBtnSticky?.addEventListener("click", () => burgerBtn?.click());

  window.addEventListener("scroll", updateSticky, { passive: true });
  updateSticky();
</script>
