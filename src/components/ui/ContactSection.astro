---
import ChipOvertitle from "../atoms/ChipOvertitle.astro";
import Glow from "../atoms/Glow.astro";
import ImageBackground from "../atoms/ImageBackground.astro";
import LeadForm from "./LeadForm.astro";

const BASE = import.meta.env.BASE_URL;
---

<section id="contacto" class="py-14 md:py-24 bg-brand-bg">
  <m-container
    class="relative w-full overflow-hidden rounded-xl shadow-blue bg-brand-primary/90"
  >
    <!-- Main Card Wrapper with Blue Background -->

    <!-- <ImageBackground
          src={`${BASE}imgs/home/bg.team.webp`}
          alt="Fondo de equipo trabajando"
          class="absolute inset-0 object-cover w-full opacity-4 mix-blend-luminosity h-[150%] -top-70"
        /> -->
    <ImageBackground
      src={BASE + "imgs/pattern-ondulado.svg"}
      class="inset-0 w-full h-full opacity-120"
    />
    <Glow
      class="w-screen -translate-x-1/2 top-1/2 left-1/2 h-100 bg-brand-primary opacity-85"
    />
    <Glow
      class="top-0 w-full max-w-4xl -translate-x-1/2 opacity-100 left-0/3 h-100 bg-brand-accent-2/10"
    />

    <!-- Content -->

    <m-row
      class="relative z-10 flex-col items-center gap-20 px-2 py-10 lg:flex-row md:p-10 lg:pr-10 lg:pl-20 lg:py-10"
    >
      <!-- Left Column: Text Content -->
      <m-col class="flex-1 w-full lg:w-1/2">
        <!-- Tag/Badge -->
        <div class="mb-8">
          <ChipOvertitle text="Conversemos" theme="dark" />
        </div>

        <!-- Heading -->
        <h2
          class="mb-6 text-4xl leading-tight text-white md:text-5xl lg:text-6xl font-display"
        >
          Apasionados por el Marketing Digital
        </h2>

        <!-- Description -->
        <p class="leading-relaxed text-white/90">
          Desarrollamos estrategias de marketing digital para nuestros clientes,
          desde la etapa de planeamiento hasta la implementación de campañas de
          marketing digital, medición de resultados y asesoramiento
          personalizado.
        </p>
      </m-col>

      <!-- Right Column: Form -->
      <m-col class="flex-1 w-full lg:w-1/2">
        <LeadForm theme="light" />
      </m-col>
    </m-row>
  </m-container>
</section>
