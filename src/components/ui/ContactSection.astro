---
import ChipOvertitle from "../atoms/ChipOvertitle.astro";
import CardSection from "../atoms/CardSection.astro";
import LeadForm from "../atoms/LeadForm.astro";

const BASE = import.meta.env.BASE_URL;
---

<section id="contacto" class="py-14 md:py-24 bg-brand-bg">
  <m-container>
    <CardSection
      variant="primary"
      glowStyle="dual"
      backgroundPattern={BASE + "imgs/pattern-ondulado.svg"}
      backgroundPatternOpacity={1.2}
      class="flex items-center px-2 py-10 lg:pr-10 lg:pl-20 lg:py-10 md:p-10"
    >
      <m-row
        class="flex-col items-center gap-20 lg:flex-row"
      >
      <!-- Left Column: Text Content -->
      <m-col class="flex-1 w-full lg:w-1/2">
        <!-- Tag/Badge -->
        <div class="mb-8">
          <ChipOvertitle text="Conversemos" theme="dark" />
        </div>

        <!-- Heading -->
        <h2
          class="mb-6 text-4xl leading-tight text-white md:text-5xl lg:text-6xl font-display"
        >
          Apasionados por el Marketing Digital
        </h2>

        <!-- Description -->
        <p class="leading-relaxed text-white/90">
          Desarrollamos estrategias de marketing digital para nuestros clientes,
          desde la etapa de planeamiento hasta la implementación de campañas de
          marketing digital, medición de resultados y asesoramiento
          personalizado.
        </p>
      </m-col>

      <!-- Right Column: Form -->
      <m-col class="flex-1 w-full lg:w-1/2">
        <LeadForm theme="light" />
      </m-col>
    </m-row>
    </CardSection>
  </m-container>
</section>
