---
import Form from "@/components/form/Form.astro";
import Input from "@/components/form/Input.astro";
import Textarea from "@/components/form/Textarea.astro";
import Select from "@/components/form/Select.astro";
import Checkbox from "@/components/form/Checkbox.astro";
import Radio from "@/components/form/Radio.astro";

const motivoOptions = [
  { value: "prioridades", label: "Cambio de prioridades internas" },
  { value: "presupuesto", label: "Limitaciones de presupuesto" },
  { value: "otra_agencia", label: "Decisión de trabajar con otra agencia" },
  { value: "resultados", label: "Resultados distintos a los esperados" },
  { value: "otro", label: "Otro" },
];

const yesNoOptions = [
  { value: "si", label: "Sí" },
  { value: "no", label: "No" },
];
---

<div class="bg-white rounded-xl p-10">
  <Form
    actions={["https://mb-suite.com/api/v1/public/forms/submit?formId=42eb0a8938cd4960a617de9485c9bf92"]}
    theme="dark"
    buttonText="Solicitar baja"
    successTitle="Solicitud recibida"
    successMessage="Te confirmamos la baja en breve."
  >
    <Input name="_website" type="hidden" value="" />
    <Input
      name="companyName"
      label="Nombre de empresa"
      type="text"
      required
      theme="light"
    />
    <Input
      name="name"
      label="Nombre y apellido del contacto"
      type="text"
      required
      theme="light"
    />
    <Input name="email" label="Email" type="email" required theme="light" />
    <Input name="phone" label="Teléfono" type="tel" theme="light" />
    <Select
      name="reason"
      label="Motivo"
      options={motivoOptions}
      theme="light"
    />
    <Input
      name="other_reason"
      label="Especificar otro motivo"
      type="text"
      theme="light"
      showIf={{ field: "reason", is: "==", value: "otro" }}
    />
    <Input
      name="end_date"
      label="Fecha de finalización"
      type="date"
      theme="light"
    />
    <Checkbox
      name="invoices_settled"
      label="Confirmo que las facturas pendientes están saldadas"
      required
      theme="light"
    />
    <Radio
      name="advisor_contact"
      label="¿Querés que un asesor te contacte?"
      options={yesNoOptions}
      theme="light"
    />
    <Radio
      name="report_access"
      label="¿Mantener acceso a reportes?"
      options={yesNoOptions}
      theme="light"
    />
    <Textarea
      name="feedback_positive"
      label="¿Qué fue lo más valioso de trabajar con nosotros?"
      theme="light"
    />
    <Textarea name="feedback_improvements" label="¿Qué podríamos mejorar?" theme="light" />
    <Checkbox
      name="confirm_cancellation"
      label="Confirmo que deseo procesar la baja de mi cuenta"
      required
      theme="light"
    />
  </Form>
</div>
