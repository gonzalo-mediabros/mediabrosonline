---
interface Props {
  name: string;
  label: string;
  placeholder?: string;
  required?: boolean;
  theme?: "light" | "dark";
  value?: string;
  error?: string;
  rows?: number;
  id?: string;
}

const {
  name,
  label,
  placeholder,
  required = false,
  theme = "light",
  value,
  error,
  rows = 4,
  id,
} = Astro.props;

const inputId = id ?? `input-${Math.random().toString(36).substr(2, 9)}`;
const isDark = theme === "dark";

const labelClasses = isDark
  ? "block text-xs font-semibold text-slate-400 uppercase tracking-wide ml-1"
  : "text-sm font-semibold text-slate-700";

const textareaClasses = isDark
  ? "w-full py-4 px-5 bg-white/5 border border-white/10 rounded-md text-white placeholder:text-slate-500 focus:outline-none focus:border-brand-primary focus:ring-1 focus:ring-brand-primary transition-colors resize-y"
  : "w-full bg-slate-50 border border-slate-200 rounded-md px-4 py-3 text-brand-foreground focus:outline-none focus:border-brand-primary focus:ring-1 focus:ring-brand-primary transition-colors resize-y";
---

<div class="flex flex-col gap-1.5">
  <label for={inputId} class={labelClasses}>{label}</label>
  <textarea
    id={inputId}
    name={name}
    placeholder={placeholder}
    required={required}
    rows={rows}
    class={textareaClasses}
  >{value}</textarea>
  {error && <span class="text-xs text-red-400">{error}</span>}
</div>
