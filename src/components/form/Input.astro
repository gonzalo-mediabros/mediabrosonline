---
interface Props {
  name: string;
  type?: string;
  label: string;
  placeholder?: string;
  required?: boolean;
  theme?: "light" | "dark";
  value?: string;
  error?: string;
  id?: string;
  showIf?: object;
}

const {
  name,
  type = "text",
  label,
  placeholder,
  required = false,
  theme = "light",
  value,
  error,
  id,
  showIf,
} = Astro.props;

const inputId = id ?? `input-${Math.random().toString(36).substr(2, 9)}`;
const isDark = theme === "dark";

const labelClasses = isDark
  ? "block text-xs font-semibold text-slate-400 uppercase tracking-wide ml-1"
  : "text-sm font-semibold text-slate-700";

const inputClasses = isDark
  ? "w-full py-4 px-5 bg-white/5 border border-white/10 rounded-md text-white placeholder:text-slate-500 focus:outline-none focus:border-brand-primary focus:ring-1 focus:ring-brand-primary transition-colors"
  : "w-full bg-slate-50 border border-slate-200 rounded-md px-4 py-3 text-brand-foreground focus:outline-none focus:border-brand-primary focus:ring-1 focus:ring-brand-primary transition-colors";
---

<div class="flex flex-col gap-1.5" {...(showIf ? { "data-show-if": JSON.stringify(showIf), hidden: true } : {})}>
  <label for={inputId} class={labelClasses}>{label}</label>
  <input
    type={type}
    id={inputId}
    name={name}
    placeholder={placeholder}
    required={required}
    value={value}
    class={inputClasses}
  />
  {error && <span class="text-xs text-red-400">{error}</span>}
</div>
