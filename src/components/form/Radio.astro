---
interface Option {
  value: string;
  label: string;
}

interface Props {
  name: string;
  label?: string;
  options: Option[];
  required?: boolean;
  theme?: "light" | "dark";
  value?: string;
  error?: string;
}

const {
  name,
  label,
  options,
  required = false,
  theme = "light",
  value,
  error,
} = Astro.props;

const isDark = theme === "dark";

const legendClasses = isDark
  ? "block text-xs font-semibold text-slate-400 uppercase tracking-wide ml-1"
  : "text-sm font-semibold text-slate-700";

const optionLabelClasses = isDark
  ? "text-sm text-slate-300 cursor-pointer leading-snug"
  : "text-sm text-brand-foreground cursor-pointer leading-snug";
---

<fieldset class="flex flex-col gap-1.5">
  {label && <legend class={legendClasses}>{label}</legend>}
  <div class="flex flex-col gap-2">
    {options.map((o) => (
      <div class="flex items-center gap-2.5">
        <input
          type="radio"
          id={`${name}-${o.value}`}
          name={name}
          value={o.value}
          checked={o.value === value}
          required={required}
          class="size-4 shrink-0 accent-brand-primary cursor-pointer"
        />
        <label for={`${name}-${o.value}`} class={optionLabelClasses}>{o.label}</label>
      </div>
    ))}
  </div>
  {error && <span class="text-xs text-red-400">{error}</span>}
</fieldset>
