---
import ChipOvertitle from "../ui/ChipOvertitle.astro";
import Button from "../ui/Button.astro";
---

<section id="banner-cta" class="py-16 md:py-24 bg-brand-fondo">
  <m-container
    class="relative flex items-center p-6 overflow-hidden bg-brand-dark rounded-xl shadow-blue md:p-10 lg:p-10"
  >
    <div
      class="absolute top-0 left-100 -translate-x-1/2 w-full h-100 bg-brand-dark opacity-20 blur-[120px] rounded-full pointer-events-none z-1"
    >
    </div>

    <m-row
      class="relative z-10 flex-col items-center w-full gap-12 lg:flex-row lg:gap-16"
    >
      <!-- Left Side: Text Content -->
      <m-col class="flex text-white grow-2">
        <!-- Badge -->
        <div class="mb-6">
          <ChipOvertitle text="Google Ads" theme="dark" />
        </div>

        <!-- Heading -->
        <h2
          class="mb-8 text-4xl tracking-tight md:text-4xl font-display leading"
        >
          ¿Es el canal adecuado para tu empresa?
        </h2>

        <!-- Description -->
        <p class="text-base leading-relaxed text-white/90">
          Podemos analizar tu mercado, tu ticket promedio y tu estrategia
          actual para definir cómo aprovechar Google Ads dentro de un plan de
          generación de demanda.
        </p>
      </m-col>

      <!-- Right Side: CTA Button -->
      <m-col class="flex items-center justify-center">
        <Button label="Consúltanos" href="#contacto" variant="white" />
      </m-col>
    </m-row>
  </m-container>
</section>
