---
import ChipOvertitle from "../ui/ChipOvertitle.astro";

const BASE = import.meta.env.BASE_URL;
---

<section id="tipos-campanas" class="py-16 md:py-24 bg-brand-fondo">
  <m-container class="p-8 bg-white rounded-3xl md:p-12 lg:p-16">
    <m-row
      class="flex-col items-start gap-12 lg:flex-row lg:gap-16 lg:items-center"
    >
      <!-- Left Column: Content -->
      <m-col class="flex flex-col justify-center w-full text-sm lg:w-1/2">
        <!-- Icon -->
        <span
          class="inline-flex items-center justify-center w-16 h-16 mb-6 rounded-full bg-gradient-to-tr from-brand-pastel-verde/40 to-brand-pastel-celeste/40"
        >
          <img
            src={`${BASE}iconos/ico-google-ads.png`}
            alt="Google Ads"
            class="size-16"
          />
        </span>

        <!-- Badge -->
        <div class="mb-6">
          <ChipOvertitle text="Campañas en Google Ads" />
        </div>

        <!-- Heading -->
        <h2
          class="text-4xl md:text-5xl font-display text-brand-dark leading-[1.15] tracking-tight mb-8"
        >
          Tipos de campañas de Google Ads
        </h2>

        <!-- Description -->
        <p class="text-base leading-relaxed md:text-lg text-brand-gris">
          La red publicitaria de Google Ads ofrece diferentes tipos de
          campañas para poder cumplir con los objetivos de tu empresa y captar
          a tu publico objetivo en las diferentes etapas de su proceso de
          compra.
        </p>
      </m-col>

      <!-- Right Column: Campaign List -->
      <m-col class="flex flex-col w-full text-sm shrink">
        <!-- Campaign Item 1: Google Search -->
        <div
          class="flex items-start gap-4 py-6 border-b border-brand-pastel-gris first:pt-0"
        >
          <img
            src={`${BASE}imgs/google-ads/ico-google.png`}
            alt="Google Search"
            class="size-12 shrink-0 mt-0.5"
          />
          <div>
            <h3 class="text-lg font-display text-brand-dark mb-1.5">
              Google Search
            </h3>
            <p class="text-sm leading-relaxed text-brand-gris">
              Si tu producto o servicio tiene búsquedas este tipo de campañas
              son la prioridad ya que generan tráfico caliente y conversiones.
            </p>
          </div>
        </div>

        <!-- Campaign Item 2: Google Display -->
        <div
          class="flex items-start gap-4 py-6 border-b border-brand-pastel-gris"
        >
          <img
            src={`${BASE}imgs/google-ads/ico-display.png`}
            alt="Google Display"
            class="size-12 shrink-0 mt-0.5"
          />
          <div>
            <h3 class="text-lg font-display text-brand-dark mb-1.5">
              Google Display
            </h3>
            <p class="text-sm leading-relaxed text-brand-gris">
              Ideal para darnos a conocer ó hacer seguimiento de nuestros
              clientes potenciales en la red publicitaria de sitios más
              grande.
            </p>
          </div>
        </div>

        <!-- Campaign Item 3: YouTube -->
        <div
          class="flex items-start gap-4 py-6 border-b border-brand-pastel-gris"
        >
          <img
            src={`${BASE}imgs/google-ads/ico-youtube.png`}
            alt="YouTube"
            class="size-12 shrink-0 mt-0.5"
          />
          <div>
            <h3 class="text-lg font-display text-brand-dark mb-1.5">
              YouTube
            </h3>
            <p class="text-sm leading-relaxed text-brand-gris">
              Con una gran variedad de formatos podemos encontrar a nuestro
              público objetivo cuando mira contenidos en YouTube.
            </p>
          </div>
        </div>

        <!-- Campaign Item 4: Max Performance -->
        <div
          class="flex items-start gap-4 py-6 border-brand-pastel-gris last:pb-0"
        >
          <img
            src={`${BASE}imgs/google-ads/ico-max-perfo.png`}
            alt="Max Performance"
            class="size-12 shrink-0 mt-0.5"
          />
          <div>
            <h3 class="text-lg font-display text-brand-dark mb-1.5">
              Max Performance
            </h3>
            <p class="text-sm leading-relaxed text-brand-gris">
              Campañas basadas en objetivos que permiten acceder a todo el
              inventario de la red publicitaria de Google y encontrar a tu
              público.
            </p>
          </div>
        </div>
      </m-col>
    </m-row>
  </m-container>
</section>
