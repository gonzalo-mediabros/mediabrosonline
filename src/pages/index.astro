---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/ui/Navigation.astro";
import HeroBig from "../components/ui/HeroBig.astro";
import Footer from "../components/ui/Footer.astro";
import Certificaciones from "../components/ui/Certificaciones.astro";
import ContactSection from "../components/ui/ContactSection.astro";
import QualifiedLeads from "../components/home/QualifiedLeads.astro";
import PerformanceAI from "../components/home/PerformanceAI.astro";
import ServicesGrid from "../components/home/ServicesGrid.astro";
import ClientsCarousel from "../components/home/ClientsCarousel.astro";

const { pathname } = Astro.url;
---

<Layout
  title="Mediabros - Rediseño Estratégico"
  description="Genera leads de calidad para tu empresa con una estrategia de marketing digital probada. Curso online gratuito en 45 minutos."
>
  <Navigation pathname={pathname} logo="logo-text-blanco.svg" />
  <HeroBig />
  <QualifiedLeads />
  <PerformanceAI />
  <ServicesGrid />
  <ContactSection />
  <ClientsCarousel />
  <Certificaciones />
  <Footer />
</Layout>
