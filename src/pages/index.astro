---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/ui/Navigation.astro";
import HeroBig from "../components/ui/HeroBig.astro";
import Footer from "../components/ui/Footer.astro";
import Certificaciones from "../components/ui/Certificaciones.astro";
import ContactSection from "../components/ui/ContactSection.astro";
import QualifiedLeads from "../components/home/QualifiedLeads.astro";
import PerformanceAI from "../components/home/PerformanceAI.astro";
import ServicesGrid from "../components/home/ServicesGrid.astro";
import ClientsCarousel from "../components/home/ClientsCarousel.astro";

const { pathname } = Astro.url;

const SEO = {
  title: "🥇 Agencia de Marketing Digital | MediaBros Marketing Digital",
  description: "Agencia de Marketing Digital. Google Partner Premier. Expertos en Google Ads, Instagram Ads, Facebook Ads y Posicionamiento Web. +15 años de experiencia.",
  canonicalURL: new URL(Astro.url.pathname, Astro.site ?? Astro.url).href,
  ogType: "website",
  ogImage: undefined,  // no definida en JSON → usa default del Layout
  ogImageAlt: "Mediabros Online — Agencia de Marketing Digital",
  noindex: false,
};
---

<Layout {...SEO}>
  <Navigation pathname={pathname} logo="logo-text-blanco.svg" />
  <HeroBig />
  <QualifiedLeads />
  <PerformanceAI />
  <ServicesGrid />
  <ContactSection />
  <ClientsCarousel />
  <Certificaciones />
  <Footer />
</Layout>
