<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Williams Psicología | Terapia para hispanohablantes</title>

    <!-- Tailwind CSS v4 -->
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>

    <!-- Google Fonts: Fraunces (Headings) & DM Sans (Body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,400&display=swap"
      rel="stylesheet"
    />

    <!-- Google Material Icons -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300,0,0"
      rel="stylesheet"
    />

    <style>
      body {
        font-family: "DM Sans", sans-serif;
        background-color: #fdfbf7;
      }
      h1,
      h2,
      h3,
      h4,
      .font-serif {
        font-family: "Fraunces", serif;
      }
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 300,
          "GRAD" 0,
          "opsz" 24;
      }
      /* Ocultar barra de desplazamiento para el carrusel pero permitir scroll */
      .hide-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </head>
  <body
    class="antialiased selection:bg-[#D98A6C] selection:text-white text-[#2D2A26]"
  >
    <!-- Navegación -->
    <nav class="absolute w-full top-0 z-50">
      <div
        class="max-w-[1400px] mx-auto px-6 py-8 flex justify-between items-center"
      >
        <div class="text-3xl font-serif text-[#2D2A26]">
          Williams<span class="text-[#D98A6C]">.</span>
        </div>
        <div
          class="hidden md:flex space-x-12 text-[15px] font-medium text-[#6B655C]"
        >
          <a href="#equipo" class="hover:text-[#D98A6C] transition-colors"
            >Equipo</a
          >
          <a href="#servicios" class="hover:text-[#D98A6C] transition-colors"
            >Servicios</a
          >
          <a href="#metodo" class="hover:text-[#D98A6C] transition-colors"
            >Enfoque</a
          >
        </div>
        <a
          href="#tarifas"
          class="bg-[#2D2A26] text-[#FDFBF7] px-8 py-3 rounded-full text-sm font-medium hover:bg-[#D98A6C] transition-colors duration-300"
        >
          Ver tarifas
        </a>
      </div>
    </nav>

    <!-- Contenedor general para el Light Mode (Fondo Sólido) -->
    <div class="bg-[#FDFBF7] relative overflow-hidden">
      <!-- Ilustración Vectorial Fondo Hero -->
      <svg
        class="absolute top-0 right-0 w-full md:w-1/2 h-auto text-[#F2EFE9] opacity-70 -z-10"
        viewBox="0 0 1000 1000"
        fill="currentColor"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M834.5 241C950.5 401.5 1014.5 617.5 907 775C799.5 932.5 520.5 1031.5 292.5 965C64.5 898.5 -112.5 666.5 -133 460.5C-153.5 254.5 13.5 74.5 233.5 18C453.5 -38.5 718.5 80.5 834.5 241Z"
        ></path>
      </svg>

      <!-- Hero Section -->
      <section class="pt-40 pb-20 md:pt-56 md:pb-32 px-6 relative z-10">
        <div
          class="max-w-[1400px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center"
        >
          <div class="lg:col-span-7 pr-0 lg:pr-12">
            <h1
              class="text-6xl md:text-[5.5rem] font-serif leading-[1.05] tracking-tight text-[#2D2A26] mb-8"
            >
              Un espacio propio,<br />
              <span class="text-[#D98A6C] italic font-light"
                >estés donde estés.</span
              >
            </h1>
            <p
              class="text-xl md:text-2xl text-[#6B655C] font-light leading-relaxed mb-12 max-w-2xl"
            >
              Acompañamos a personas hispanohablantes que viven lejos de su país
              a transitar sus procesos emocionales desde su cultura y en su
              idioma.
            </p>
            <a
              href="#contacto"
              class="inline-flex items-center justify-center bg-[#D98A6C] text-white px-10 py-5 rounded-full text-lg font-medium hover:bg-[#C2765A] transition-all hover:scale-105 shadow-xl shadow-[#D98A6C]/20"
            >
              Comenzar mi proceso
            </a>
          </div>
          <div class="lg:col-span-5 relative">
            <!-- Vector decorativo escandinavo -->
            <svg
              class="absolute -top-12 -left-12 w-32 h-32 text-[#D98A6C]/20"
              viewBox="0 0 100 100"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <circle
                cx="50"
                cy="50"
                r="49"
                stroke="currentColor"
                stroke-width="2"></circle>
              <circle
                cx="50"
                cy="50"
                r="35"
                stroke="currentColor"
                stroke-width="2"></circle>
              <circle
                cx="50"
                cy="50"
                r="21"
                stroke="currentColor"
                stroke-width="2"></circle>
            </svg>
            <div class="h-[600px] w-full rounded-[40px] overflow-hidden">
              <img
                src="https://images.unsplash.com/photo-1600607688969-a5bfcd64bd28?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80"
                alt="Consultorio minimalista"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Equipo Section -->
      <section id="equipo" class="py-32 px-6">
        <div class="max-w-[1400px] mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
            <div class="lg:col-span-1">
              <span
                class="text-[#D98A6C] font-medium tracking-[0.2em] uppercase text-sm mb-4 block"
                >El Equipo</span
              >
              <h2 class="text-5xl font-serif text-[#2D2A26] mb-8 leading-tight">
                Somos colegas y familia.
              </h2>
              <p class="text-lg text-[#6B655C] font-light leading-relaxed">
                Llegamos a este proyecto con trayectorias clínicas distintas
                pero con una idea en común: que la psicoterapia de calidad
                requiere algo más que técnica — requiere que el profesional
                comprenda el mundo del paciente.
              </p>
            </div>

            <div class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="group">
                <div
                  class="aspect-[4/5] rounded-[32px] overflow-hidden mb-6 bg-[#E6DCD0]"
                >
                  <img
                    src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                    alt="Guillermo"
                    class="w-full h-full object-cover grayscale opacity-90 mix-blend-multiply group-hover:scale-105 transition-transform duration-700"
                  />
                </div>
                <h3 class="text-3xl font-serif text-[#2D2A26] mb-2">
                  Guillermo Williams
                </h3>
                <p class="text-[#8B7355] text-sm tracking-wider uppercase mb-4">
                  Psicólogo UBA
                </p>
                <p class="text-[#6B655C] font-light leading-relaxed">
                  10+ años de experiencia. Enfoque integrativo. Interesado en
                  pensar junto con el paciente, de manera ética y transparente,
                  en un contexto que rara vez facilita la pausa.
                </p>
              </div>
              <div class="group mt-0 md:mt-16">
                <div
                  class="aspect-[4/5] rounded-[32px] overflow-hidden mb-6 bg-[#E6DCD0]"
                >
                  <img
                    src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                    alt="Diego"
                    class="w-full h-full object-cover grayscale opacity-90 mix-blend-multiply group-hover:scale-105 transition-transform duration-700"
                  />
                </div>
                <h3 class="text-3xl font-serif text-[#2D2A26] mb-2">
                  Diego Williams
                </h3>
                <p class="text-[#8B7355] text-sm tracking-wider uppercase mb-4">
                  Psicólogo UNC
                </p>
                <p class="text-[#6B655C] font-light leading-relaxed">
                  18 años ayudando a personas a estar mejor. Creo firmemente que
                  no hay diagnóstico ni etiqueta que agote la experiencia única
                  de cada individuo.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Motivos de Consulta (Carrusel de Cards Gigantes) -->
      <section
        id="servicios"
        class="py-32 pl-6 md:pl-12 lg:pl-[calc(50vw-700px)] overflow-hidden relative"
      >
        <div class="mb-16 pr-6">
          <span
            class="text-[#D98A6C] font-medium tracking-[0.2em] uppercase text-sm mb-4 block"
            >Nuestros Servicios</span
          >
          <h2 class="text-5xl md:text-6xl font-serif text-[#2D2A26] mb-6">
            ¿En qué podemos ayudarte?
          </h2>
        </div>

        <!-- Carrusel Horizontal -->
        <div
          class="flex overflow-x-auto gap-6 pb-12 snap-x snap-mandatory scroll-pl-6 hide-scrollbar cursor-grab active:cursor-grabbing"
        >
          <!-- Duelo migratorio (Destacado) -->
          <div
            class="snap-start shrink-0 w-[85vw] sm:w-[450px] bg-[#2D2A26] rounded-[40px] p-10 md:p-12 flex flex-col justify-between text-[#FDFBF7] relative overflow-hidden h-[500px]"
          >
            <span class="material-symbols-outlined text-5xl text-[#D98A6C]"
              >public</span
            >
            <div>
              <h3 class="text-4xl font-serif mb-4">
                Duelo migratorio y desarraigo
              </h3>
              <p class="text-[#C4BCB3] text-lg font-light leading-relaxed">
                Vivir afuera puede ser mucho a la vez: la nostalgia, la
                adaptación, sentir que no terminás de pertenecer a ningún lado.
                Es más frecuente de lo que se habla.
              </p>
            </div>
            <!-- Vector decorativo -->
            <svg
              class="absolute -bottom-10 -right-10 w-64 h-64 text-[#3F3B36]"
              viewBox="0 0 100 100"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M0 100 C 0 44.77 44.77 0 100 0"
                stroke="currentColor"
                stroke-width="2"></path>
              <path
                d="M20 100 C 20 55.82 55.82 20 100 20"
                stroke="currentColor"
                stroke-width="2"></path>
            </svg>
          </div>

          <!-- Ansiedad y estrés -->
          <div
            class="snap-start shrink-0 w-[85vw] sm:w-[450px] bg-white border border-[#E8E3D9] rounded-[40px] p-10 md:p-12 flex flex-col justify-between hover:border-[#D98A6C] transition-colors h-[500px]"
          >
            <span class="material-symbols-outlined text-5xl text-[#9CAF88]"
              >air</span
            >
            <div>
              <h3 class="text-4xl font-serif mb-4 text-[#2D2A26]">
                Ansiedad y estrés
              </h3>
              <p class="text-[#6B655C] text-lg font-light leading-relaxed">
                Cuando el cuerpo y la mente no paran, aunque no haya una razón
                clara. Esa sensación de alerta constante que agota.
              </p>
            </div>
          </div>

          <!-- Soledad -->
          <div
            class="snap-start shrink-0 w-[85vw] sm:w-[450px] bg-[#F2EFE9] border border-[#E8E3D9] rounded-[40px] p-10 md:p-12 flex flex-col justify-between hover:border-[#D98A6C] transition-colors h-[500px]"
          >
            <span class="material-symbols-outlined text-5xl text-[#D98A6C]"
              >person</span
            >
            <div>
              <h3 class="text-4xl font-serif mb-4 text-[#2D2A26]">Soledad</h3>
              <p class="text-[#6B655C] text-lg font-light leading-relaxed">
                No siempre es fácil de nombrar, pero es uno de los malestares
                más comunes en quienes viven lejos de su red afectiva.
              </p>
            </div>
          </div>

          <!-- Depresión -->
          <div
            class="snap-start shrink-0 w-[85vw] sm:w-[450px] bg-white border border-[#E8E3D9] rounded-[40px] p-10 md:p-12 flex flex-col justify-between hover:border-[#D98A6C] transition-colors h-[500px]"
          >
            <span class="material-symbols-outlined text-5xl text-[#9CAF88]"
              >cloud</span
            >
            <div>
              <h3 class="text-4xl font-serif mb-4 text-[#2D2A26]">
                Depresión y estado de ánimo
              </h3>
              <p class="text-[#6B655C] text-lg font-light leading-relaxed">
                La tristeza que se instala, la falta de energía, el alejamiento
                de lo que antes importaba.
              </p>
            </div>
          </div>

          <!-- Identidad -->
          <div
            class="snap-start shrink-0 w-[85vw] sm:w-[450px] bg-white border border-[#E8E3D9] rounded-[40px] p-10 md:p-12 flex flex-col justify-between hover:border-[#D98A6C] transition-colors h-[500px]"
          >
            <span class="material-symbols-outlined text-5xl text-[#D98A6C]"
              >fingerprint</span
            >
            <div>
              <h3 class="text-4xl font-serif mb-4 text-[#2D2A26]">
                Identidad y autoestima
              </h3>
              <p class="text-[#6B655C] text-lg font-light leading-relaxed">
                Preguntas sobre quién sos, qué querés, cómo te relacionás con
                vos mismo. Especialmente intensas en contextos de cambio.
              </p>
            </div>
          </div>

          <!-- Trauma -->
          <div
            class="snap-start shrink-0 w-[85vw] sm:w-[450px] bg-[#9CAF88] rounded-[40px] p-10 md:p-12 flex flex-col justify-between text-[#FDFBF7] h-[500px]"
          >
            <span class="material-symbols-outlined text-5xl text-white"
              >healing</span
            >
            <div>
              <h3 class="text-4xl font-serif mb-4">Trauma</h3>
              <p class="text-[#F0F4EC] text-lg font-light leading-relaxed">
                Experiencias que dejaron marca y que siguen apareciendo en el
                presente. Se trabaja con tiempo, respeto y cuidado.
              </p>
            </div>
          </div>

          <!-- Espaciador final -->
          <div class="snap-start shrink-0 w-6 sm:w-12"></div>
        </div>
      </section>
    </div>

    <!-- SECCIÓN DE TRANSICIÓN A DARK MODE (Gradiente de FDFBF7 a 1A1816) -->
    <!-- Aquí es donde la UI cambia magistralmente, aplicando un gradiente suave en el fondo -->
    <div
      class="bg-gradient-to-b from-[#FDFBF7] via-[#8B7355] to-[#1A1816] transition-colors duration-1000 relative"
    >
      <!-- Ilustración de transición vectorial -->
      <svg
        class="absolute top-1/4 left-0 w-full h-auto text-black opacity-5 mix-blend-overlay pointer-events-none"
        viewBox="0 0 1440 320"
        preserveAspectRatio="none"
      >
        <path
          fill="currentColor"
          d="M0,128L80,144C160,160,320,192,480,186.7C640,181,800,139,960,128C1120,117,1280,139,1360,149.3L1440,160L1440,320L1360,320C1280,320,1120,320,960,320C800,320,640,320,480,320C320,320,160,320,80,320L0,320Z"
        ></path>
      </svg>

      <!-- Objetivo y Método (Sin formato de Card, Texto Editorial Puro) -->
      <section
        id="metodo"
        class="pt-32 pb-48 px-6 max-w-[1400px] mx-auto relative z-10"
      >
        <div class="grid grid-cols-1 md:grid-cols-2 gap-24">
          <!-- Objetivo -->
          <div class="text-[#2D2A26] mix-blend-color-burn">
            <span
              class="text-current font-semibold tracking-[0.2em] uppercase text-sm mb-6 block"
              >Nuestro Objetivo</span
            >
            <h2 class="text-4xl md:text-6xl font-serif mb-8 leading-tight">
              Un espacio propio en tu idioma y cultura.
            </h2>
            <p class="text-xl font-light leading-relaxed mb-6">
              Acompañar a personas hispanohablantes que viven lejos de su país a
              transitar sus procesos emocionales con un espacio propio.
            </p>
            <p class="text-xl font-light leading-relaxed">
              Creemos firmemente que la terapia es una herramienta de
              crecimiento, no solo de alivio del síntoma.
            </p>
          </div>

          <!-- Método (El texto ya se vuelve blanco/claro porque estamos más abajo en el gradiente) -->
          <div class="text-[#FDFBF7] mt-12 md:mt-48">
            <span
              class="text-[#D98A6C] font-semibold tracking-[0.2em] uppercase text-sm mb-6 block"
              >El Método</span
            >
            <h2 class="text-4xl md:text-6xl font-serif mb-8 leading-tight">
              No aplicamos un modelo rígido.
            </h2>
            <p class="text-xl font-light leading-relaxed mb-6 opacity-90">
              Trabajamos desde un enfoque integrativo y basado en evidencia,
              combinando herramientas de distintas corrientes terapéuticas según
              las necesidades de cada persona.
            </p>
            <p class="text-2xl font-serif italic text-[#D98A6C]">
              Construimos el proceso junto con vos.
            </p>
          </div>
        </div>
      </section>
    </div>

    <!-- CONTENEDOR DARK MODE TOTAL -->
    <div class="bg-[#1A1816] text-[#FDFBF7] relative overflow-hidden">
      <!-- Vector decorativo oscuro -->
      <svg
        class="absolute top-0 right-0 w-96 h-96 text-[#2D2A26] opacity-50"
        viewBox="0 0 200 200"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <line
          x1="100"
          y1="0"
          x2="100"
          y2="200"
          stroke="currentColor"
          stroke-width="1"></line>
        <line
          x1="0"
          y1="100"
          x2="200"
          y2="100"
          stroke="currentColor"
          stroke-width="1"></line>
        <circle cx="100" cy="100" r="50" stroke="currentColor" stroke-width="1"
        ></circle>
        <circle cx="100" cy="100" r="80" stroke="currentColor" stroke-width="1"
        ></circle>
      </svg>

      <!-- Planes y Precios -->
      <section id="tarifas" class="pt-12 pb-24 px-6 relative z-10">
        <div class="max-w-[1400px] mx-auto">
          <div class="text-center mb-20">
            <h2 class="text-5xl md:text-7xl font-serif mb-6">
              Planes y Precios
            </h2>
            <p class="text-[#A39C93] text-xl font-light max-w-2xl mx-auto">
              Transparencia en nuestros honorarios para que puedas planificar tu
              proceso de bienestar.
            </p>
          </div>

          <!-- Planes Principales (Grandes) -->
          <div
            class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto mb-8"
          >
            <!-- Consulta Inicial -->
            <div
              class="bg-[#23211E] border border-[#3F3B36] rounded-[40px] p-12 md:p-16 flex flex-col justify-between hover:border-[#8B7355] transition-all"
            >
              <div>
                <span
                  class="material-symbols-outlined text-[#9CAF88] text-4xl mb-6"
                  >forum</span
                >
                <h3 class="text-4xl font-serif mb-4">Consulta inicial</h3>
                <p
                  class="text-[#A39C93] text-lg font-light mb-10 leading-relaxed"
                >
                  Para conocernos, evaluar tu situación y decidir si somos el
                  equipo adecuado para vos.
                </p>
              </div>
              <div>
                <div
                  class="text-[#8B7355] font-medium flex items-center gap-2 mb-4"
                >
                  <span class="material-symbols-outlined text-xl">schedule</span
                  > 20 minutos
                </div>
                <div class="flex items-baseline gap-3 mb-10">
                  <span class="text-6xl font-serif">€20</span>
                  <span class="text-[#A39C93] text-xl">/ $20 USD</span>
                </div>
                <a
                  href="#contacto"
                  class="block w-full py-5 px-6 bg-[#3F3B36] text-[#FDFBF7] text-center rounded-full text-lg font-medium hover:bg-[#FDFBF7] hover:text-[#1A1816] transition-colors"
                  >Agendar consulta</a
                >
              </div>
            </div>

            <!-- Sesión Individual -->
            <div
              class="bg-[#D98A6C] text-[#1A1816] rounded-[40px] p-12 md:p-16 flex flex-col justify-between relative transform md:-translate-y-6 shadow-2xl shadow-[#D98A6C]/10"
            >
              <div
                class="absolute top-8 right-8 bg-[#1A1816] text-[#FDFBF7] text-xs font-bold uppercase tracking-widest py-2 px-5 rounded-full"
              >
                Más habitual
              </div>
              <div>
                <span
                  class="material-symbols-outlined text-[#1A1816] text-4xl mb-6"
                  >person</span
                >
                <h3 class="text-4xl font-serif mb-4">Sesión individual</h3>
                <p
                  class="text-[#1A1816]/80 text-lg font-light mb-10 leading-relaxed"
                >
                  Tu espacio semanal o quincenal para trabajar a fondo en tu
                  bienestar emocional y mental.
                </p>
              </div>
              <div>
                <div
                  class="text-[#1A1816] font-medium flex items-center gap-2 mb-4"
                >
                  <span class="material-symbols-outlined text-xl">schedule</span
                  > 50 minutos
                </div>
                <div class="flex items-baseline gap-3 mb-10">
                  <span class="text-6xl font-serif">€32</span>
                  <span class="text-[#1A1816]/70 text-xl">/ $35 USD</span>
                </div>
                <a
                  href="#contacto"
                  class="block w-full py-5 px-6 bg-[#1A1816] text-[#FDFBF7] text-center rounded-full text-lg font-medium hover:bg-[#3F3B36] transition-colors"
                  >Reservar sesión</a
                >
              </div>
            </div>
          </div>

          <!-- Beca (Banner Horizontal Pequeño) -->
          <div
            class="max-w-5xl mx-auto bg-[#23211E] border border-[#3F3B36] rounded-3xl p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6 hover:border-[#D98A6C]/50 transition-colors"
          >
            <div class="flex items-center gap-6">
              <div
                class="w-16 h-16 rounded-full bg-[#1A1816] flex items-center justify-center flex-shrink-0"
              >
                <span class="material-symbols-outlined text-[#D98A6C]"
                  >volunteer_activism</span
                >
              </div>
              <div>
