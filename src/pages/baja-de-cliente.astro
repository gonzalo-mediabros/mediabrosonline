---
import Layout from "@/layouts/Layout.astro";
import Navigation from "@/components/ui/Navigation.astro";
import HeroSmall from "@/components/ui/HeroSmall.astro";
import Breadcrumb from "@/components/atoms/Breadcrumb.astro";
import FormClienteBaja from "@/components/form/FormClienteBaja.astro";
import Certificaciones from "@/components/ui/Certificaciones.astro";
import Footer from "@/components/ui/Footer.astro";

const { pathname } = Astro.url;

const SEO = {
  title: "Baja de cliente | Mediabros Online",
  description:
    "Formulario de baja de cliente. Completá este formulario si necesitás dar de baja algún servicio de Mediabros y nos pondremos en contacto.",
  canonicalURL: new URL(Astro.url.pathname, Astro.site ?? Astro.url).href,
  ogType: "website" as const,
  noindex: true,
};
---

<Layout {...SEO}>
  <Navigation pathname={pathname} />

  <HeroSmall
    title="Baja de cliente"
    subtitle="Lamentamos que te vayas. Completá el formulario para procesar tu baja."
  />

  <Breadcrumb
    items={[{ label: "Home", href: "/" }, { label: "Baja de cliente" }]}
  />

  <main class="py-16 md:py-24 bg-brand-bg">
    <m-container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-center text-3xl font-display font-semibold mb-8">
          Completá tus datos para iniciar el proceso de baja.
        </h2>
        <FormClienteBaja />
      </div>
    </m-container>
  </main>

  <Certificaciones />
  <Footer />
</Layout>
