---
import Layout from "@/layouts/Layout.astro";
import Navigation from "@/components/ui/Navigation.astro";
import HeroSmall from "@/components/ui/HeroSmall.astro";
import Breadcrumb from "@/components/atoms/Breadcrumb.astro";
import ChipOvertitle from "@/components/atoms/ChipOvertitle.astro";
import Carrusel from "@/components/atoms/Carrusel.astro";
import CardTestimonialVideo2 from "@/components/atoms/CardTestimonialVideo2.astro";
import CardCta from "@/components/atoms/CardCta.astro";
import Icon from "@/components/atoms/Icon.astro";
import Certificaciones from "@/components/ui/Certificaciones.astro";
import Footer from "@/components/ui/Footer.astro";
import { CLIENTS } from "@/data/clients.ts";
import Button from "@/components/atoms/Button.astro";

const { pathname } = Astro.url;
const BASE = import.meta.env.BASE_URL;

const SEO = {
  title: "Clientes | Agencia de Marketing Digital",
  description:
    "Te invitamos a conocer las marcas que confían en nosotros. Más de 15 años de experiencia en el mundo online y más de 500 proyectos realizados.",
  canonicalURL: new URL(Astro.url.pathname, Astro.site ?? Astro.url).href,
  ogType: "website",
  noindex: false,
} as const;

const industries = [
  { label: "Seguridad", icon: "security" },
  { label: "Logística", icon: "local_shipping" },
  { label: "E. Renovables", icon: "energy_savings_leaf" },
  { label: "Servicios", icon: "support_agent" },
  { label: "Maquinaria", icon: "precision_manufacturing" },
  { label: "Industria", icon: "factory" },
  { label: "Construcción", icon: "architecture" },
  { label: "Salud", icon: "medical_services" },
  { label: "Alimentos", icon: "restaurant" },
  { label: "Automotriz", icon: "directions_car" },
  { label: "Mobiliario", icon: "chair" },
  { label: "Mayoreo", icon: "store" },
];

const testimonials = [
  {
    quote:
      "Desde 2018 trabajamos con Mediabros con muy buenos resultados, logrando un crecimiento sostenido de interesados en nuestros cursos y la confianza para seguir trabajando juntos.",
    authorName: "Lucas Silva",
    authorRole: "Instituto Gato Dumas",
    videoUrl: "https://www.youtube.com/embed/dtq26W-1fj0",
    thumbnail: `${import.meta.env.BASE_URL}imgs/clientes/casos/Gato-Dumas.webp`,
  },
  {
    quote:
      "Nuestra experiencia con Mediabros ha sido excelente. Son profesionales muy capacitados y su plataforma me permite ver de forma práctica los resultados de nuestras campañas en Google Ads y Meta Ads.",
    authorName: "Luismar Vargas",
    authorRole: "Centro Médico Bandera",
    videoUrl: "https://www.youtube.com/embed/GfW_YOXZnuk",
    thumbnail: `${import.meta.env.BASE_URL}imgs/clientes/casos/bandera.png`,
  },
  {
    quote:
      "Encontramos en Mediabros un gran partner para SEO y paid media. Logramos duplicar el tráfico de nuestros clientes y obtener muy buenos indicadores de conversión, llegando al público correcto.",
    authorName: "Eliana Tunarroza",
    authorRole: "La Areté / Institución Educativa",
    videoUrl: "https://www.youtube.com/embed/7-yxVGgZwzc",
    thumbnail: `${import.meta.env.BASE_URL}imgs/clientes/casos/La-Arete.webp`,
  },
  {
    quote:
      "Con Mediabros tuvimos una experiencia muy satisfactoria, con comunicación clara desde el inicio y un plan de trabajo alineado a nuestras necesidades. Ejecutaron estrategias de forma constante.",
    authorName: "Adrian Reyes",
    authorRole: "Caliza",
    videoUrl: "https://www.youtube.com/embed/qodfPZ9d-AQ",
    thumbnail: `${import.meta.env.BASE_URL}imgs/clientes/casos/CALIZA_.webp`,
  },
  {
    quote:
      "Con Mediabros hemos tenido una experiencia muy positiva. Son un equipo profesional, comprometido y estructurado, adaptándose completamente a nuestras necesidades y presupuestos.",
    authorName: "Felipe Canales",
    authorRole: "Nearway",
    videoUrl: "https://www.youtube.com/embed/74R_hErDmFg",
    thumbnail: `${import.meta.env.BASE_URL}imgs/clientes/casos/Nearway_.jpg`,
  },
  {
    quote:
      "Con Mediabros hemos tenido una experiencia excelente. Son un equipo altamente profesional y resolutivo, siempre dispuestos a orientarnos en las mejores decisiones. Una de las mejores agencias.",
    authorName: "Sara Zambrano Morón",
    authorRole: "Llegó",
    videoUrl: "https://www.youtube.com/embed/_4Rw2-iD_Xc",
    thumbnail: `${import.meta.env.BASE_URL}imgs/clientes/casos/Zambrano.webp`,
  },
  {
    quote:
      "En 2021 comenzamos a trabajar con Mediabros como partner de performance para anuncios digitales. Optimizamos campañas y terminamos aumentando considerablemente la tasa de conversión.",
    authorName: "Esteban Airaldo",
    authorRole: "Sueno Dorado",
    videoUrl: "https://www.youtube.com/embed/bCyTzYDvmvw",
    thumbnail: `${import.meta.env.BASE_URL}imgs/clientes/casos/Sueno-Dorado.webp`,
  },
  {
    quote:
      "Con Mediabros trabajamos performance y SEO para el lanzamiento del ecommerce. En pocos meses lograron posicionar categorías clave en el puesto número uno de Google, generando consultas relevantes.",
    authorName: "Agustín Tiscornia",
    authorRole: "Electrocity",
    videoUrl: "https://www.youtube.com/embed/DCpicQIYcVA",
    thumbnail: `${import.meta.env.BASE_URL}imgs/clientes/casos/Electrocity_.webp`,
  },
];
---

<Layout {...SEO}>
  <Navigation pathname={pathname} />

  <HeroSmall
    title="Clientes"
    subtitle="El éxito de nuestros clientes es el nuestro"
  />

  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Clientes" }]} />

  <!-- Testimonios -->
  <section class="py-16 md:py-20 bg-brand-bg">
    <m-container>
      <div class="mb-10">
        <ChipOvertitle text="Historias de éxito" />
        <h2
          class="mt-4 text-4xl md:text-5xl font-display leading-tight text-brand-foreground"
        >
          Testimonios de nuestros clientes
        </h2>
      </div>
      <Carrusel
        slidesPerView={{ base: 1, md: 1, lg: 2 }}
        navigation={true}
        pagination={true}
      >
        {
          testimonials.map((t) => (
            <div class="embla__slide mb-12 h-full">
              <CardTestimonialVideo2
                quote={t.quote}
                authorName={t.authorName}
                authorRole={t.authorRole}
                videoUrl={t.videoUrl}
                thumbnail={t.thumbnail}
                class="h-90"
              />
            </div>
          ))
        }
      </Carrusel>
    </m-container>
  </section>

  <!-- CTA ancho completo -->
  <section class="py-10 bg-brand-bg">
    <m-container>
      <CardCta
        variant="dark"
        overtitle=""
        title="Únete a +100 empresas en LATAM que confían en nosotros"
        buttonLabel="Consúltanos"
        buttonHref="/contacto"
        direction="row"
        align="left"
      />
    </m-container>
  </section>

  <!-- Empresas con las que trabajamos -->
  <section class="py-16 md:py-20 bg-brand-surface">
    <m-container>
      <m-row class="gap-10 md:gap-16 items-start">
        <m-col class="md:w-1/2">
          <ChipOvertitle text="Relaciones de confianza" />
          <h2
            class="mt-4 text-4xl md:text-5xl font-display leading-tight text-brand-foreground"
          >
            Empresas con las que trabajamos
          </h2>
        </m-col>
        <m-col class="md:w-1/2 space-y-4">
          <p class="text-base leading-relaxed text-brand-muted">
            En Mediabros construimos relaciones de largo plazo con nuestros
            clientes. No buscamos cuentas, buscamos socios estratégicos que
            quieran crecer de manera sostenida.
          </p>
          <p class="text-base leading-relaxed text-brand-muted">
            Trabajamos con empresas de más de 12 industrias en Argentina,
            México, Colombia y toda la región LATAM.
          </p>
        </m-col>
      </m-row>
    </m-container>
  </section>

  <!-- Grilla de industrias -->
  <section class="py-16 bg-brand-surface">
    <m-container>
      <div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
        {
          industries.map((industry) => (
            <div class="flex flex-col items-center gap-3">
              <div class="w-16 h-16 rounded-xl bg-brand-dark flex items-center justify-center text-white">
                <Icon name={industry.icon} size={32} fill={1} />
              </div>
              <span class="text-xs font-medium text-center text-brand-muted uppercase tracking-wide">
                {industry.label}
              </span>
            </div>
          ))
        }
      </div>
    </m-container>
  </section>

  <!-- Logos de clientes -->
  <section class="py-16 md:py-20 bg-brand-bg">
    <m-container>
      <div
        id="clients-grid"
        class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4 md:gap-8 items-center"
      >
        {
          CLIENTS.map((client, index) => (
            <img
              src={`${BASE}imgs/clientes/logos/${client.url}`}
              alt={client.name}
              loading="lazy"
              class:list={[
                "w-full h-24 md:h-32 object-contain grayscale hover:grayscale-0 transition-all duration-500 mix-blend-multiply client-logo",
                index >= 14
                  ? "hidden opacity-0 translate-y-4"
                  : "block opacity-100 translate-y-0",
              ]}
            />
          ))
        }
      </div>

      {
        CLIENTS.length > 14 && (
          <div class="mt-16 flex justify-center">
            <Button
              type="button"
              id="load-more-clients"
              variant="celeste"
              label="Ver más "
            />
          </div>
        )
      }
    </m-container>
  </section>

  <script>
    function setupLoadMore() {
      const btn = document.getElementById("load-more-clients");
      const hiddenLogos = document.querySelectorAll(".client-logo.hidden");

      if (!btn || hiddenLogos.length === 0) return;

      btn.addEventListener("click", () => {
        hiddenLogos.forEach((logo, index) => {
          // Primero mostramos el elemento (quitamos hidden)
          logo.classList.remove("hidden");

          // Pequeño delay para asegurar que el navegador registre el cambio antes de la animación
          setTimeout(() => {
            logo.classList.remove("opacity-0", "translate-y-4");
            logo.classList.add("opacity-100", "translate-y-0");
          }, index * 30); // Efecto cascada de 30ms por logo
        });

        // Ocultar el botón con una transición suave
        btn.style.opacity = "0";
        btn.style.pointerEvents = "none";
        setTimeout(() => {
          btn.parentElement?.remove();
        }, 300);
      });
    }

    // Inicialización
    setupLoadMore();
    // Soporte para Astro View Transitions
    document.addEventListener("astro:after-swap", setupLoadMore);
  </script>

  <Certificaciones />
  <Footer />
</Layout>
