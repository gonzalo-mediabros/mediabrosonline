---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/ui/Navigation.astro";
import Footer from "../components/ui/Footer.astro";

// Home components
import HeroBig from "../components/ui/HeroBig.astro";
import QualifiedLeads from "../components/home/QualifiedLeads.astro";
import PerformanceAI from "../components/home/PerformanceAI.astro";
import ServicesGrid from "../components/home/ServicesGrid.astro";
import ClientsCarousel from "../components/home/ClientsCarousel.astro";

// Google Ads components
import HeroSmall from "../components/ui/HeroSmall.astro";
import ResultadosMedibles from "../components/google-ads/ResultadosMedibles.astro";
import TiposCampanas from "../components/google-ads/TiposCampanas.astro";
import PorQueGoogleAds from "../components/google-ads/PorQueGoogleAds.astro";
import CtaBanner from "../components/google-ads/CtaBanner.astro";
import FaqsSection from "../components/google-ads/FaqsSection.astro";

// Shared UI
import Certificaciones from "../components/ui/Certificaciones.astro";
import ContactSection from "../components/ui/ContactSection.astro";

const { pathname } = Astro.url;
---

<Layout title="TEST — Componentes" description="Página de prueba de componentes">
  <Navigation pathname={pathname} />

  <!-- ===================== HOME COMPONENTS ===================== -->

  <div class="bg-yellow-300 text-black font-bold text-center py-2 text-sm tracking-widest uppercase">
    HOME / HeroBig
  </div>
  <HeroBig />

  <div class="bg-yellow-300 text-black font-bold text-center py-2 text-sm tracking-widest uppercase">
    HOME / QualifiedLeads
  </div>
  <QualifiedLeads />

  <div class="bg-yellow-300 text-black font-bold text-center py-2 text-sm tracking-widest uppercase">
    HOME / PerformanceAI
  </div>
  <PerformanceAI />

  <div class="bg-yellow-300 text-black font-bold text-center py-2 text-sm tracking-widest uppercase">
    HOME / ServicesGrid
  </div>
  <ServicesGrid />

  <div class="bg-yellow-300 text-black font-bold text-center py-2 text-sm tracking-widest uppercase">
    HOME / ClientsCarousel
  </div>
  <ClientsCarousel />

  <!-- ===================== GOOGLE ADS COMPONENTS ===================== -->

  <div class="bg-blue-400 text-white font-bold text-center py-2 text-sm tracking-widest uppercase">
    GOOGLE ADS / HeroSmall
  </div>
  <HeroSmall
    title="Google Ads"
    icon="ico-google-ads.png"
    subtitle="Google Ads como motor principal de generación de demanda y leads calificados"
  />

  <div class="bg-blue-400 text-white font-bold text-center py-2 text-sm tracking-widest uppercase">
    GOOGLE ADS / ResultadosMedibles
  </div>
  <ResultadosMedibles />

  <div class="bg-blue-400 text-white font-bold text-center py-2 text-sm tracking-widest uppercase">
    GOOGLE ADS / TiposCampanas
  </div>
  <TiposCampanas />

  <div class="bg-blue-400 text-white font-bold text-center py-2 text-sm tracking-widest uppercase">
    GOOGLE ADS / PorQueGoogleAds
  </div>
  <PorQueGoogleAds />

  <div class="bg-blue-400 text-white font-bold text-center py-2 text-sm tracking-widest uppercase">
    GOOGLE ADS / CtaBanner
  </div>
  <CtaBanner />

  <div class="bg-blue-400 text-white font-bold text-center py-2 text-sm tracking-widest uppercase">
    GOOGLE ADS / FaqsSection
  </div>
  <FaqsSection />

  <!-- ===================== SHARED UI ===================== -->

  <div class="bg-green-400 text-black font-bold text-center py-2 text-sm tracking-widest uppercase">
    SHARED / ContactSection
  </div>
  <ContactSection />

  <div class="bg-green-400 text-black font-bold text-center py-2 text-sm tracking-widest uppercase">
    SHARED / Certificaciones
  </div>
  <Certificaciones />

  <Footer />
</Layout>
