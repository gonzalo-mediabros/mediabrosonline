---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/ui/Navigation.astro";
import HeroBig from "../components/ui/HeroBig.astro";
import LeadForm from "../components/ui/LeadForm.astro";
import Footer from "../components/ui/Footer.astro";
import ChipOvertitle from "../components/ui/ChipOvertitle.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";
import CardTeam from "../components/ui/CardTeam.astro";
import Icon from "../components/ui/Icon.astro";
import Certificaciones from "../components/ui/Certificaciones.astro";
import HeroSmall from "../components/ui/HeroSmall.astro";

const BASE = import.meta.env.BASE_URL;
const { pathname } = Astro.url;
---

<Layout
  title="Mediabros - Rediseño Estratégico"
  description="Genera leads de calidad para tu empresa con una estrategia de marketing digital probada. Curso online gratuito en 45 minutos."
>
  <!-- ----- HERO ----- -->
  <Navigation pathname={pathname} />
  <HeroBig />
  <HeroSmall
    title="Nuestra agencia de marketing digital"
    subtitle="Tecnología propia y estrategias de generación de demanda."
  />

  <!-- --------------- QUALIFIED LEADS SECTION --------------- -->
  <section
    id="qualified-leads"
    class="relative py-16 overflow-hidden lg:py-24 bg-brand-fondo"
  >
    <m-container class="relative z-10">
      <m-row
        class="flex-col items-center gap-12 lg:flex-row lg:gap-8 lg:items-stretch"
      >
        <!-- Left Column: Content -->
        <m-col
          class="flex flex-col justify-center flex-none w-full lg:w-1/2 lg:pr-8 xl:pr-16"
        >
          <!-- Badge -->
          <div class="mb-6 lg:mb-8">
            <ChipOvertitle text="Nuestra agencia de marketing digital" />
          </div>

          <!-- Heading -->
          <h2
            class="text-4xl md:text-5xl xl:text-[52px] font-display font-semibold text-brand-dark leading-[1.15] tracking-tight mb-8"
          >
            Recibe leads calificados<br class="hidden md:block" /> de forma constante
          </h2>

          <!-- CTA Button -->
          <div class="mb-12 lg:mb-16">
            <a
              href="#"
              class="inline-flex items-center justify-center gap-2 bg-brand-celeste hover:bg-brand-celeste-hover text-white font-medium text-base px-8 py-3.5 rounded-full transition-colors shadow-blue"
            >
              Solicitar diagnóstico
              <Icon name="arrow_forward" size={20} />
            </a>
          </div>

          <!-- Features Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-10">
            <!-- Feature 1 -->
            <div>
              <div
                class="flex items-center justify-center w-8 h-8 mb-4 rounded-full bg-brand-turquesa"
              >
                <Icon
                  name="check"
                  size={18}
                  class="font-black text-brand-celeste"
                />
              </div>
              <h3
                class="text-[17px] md:text-lg font-display font-semibold text-brand-dark mb-2 tracking-tight"
              >
                Nuestras certificaciones
              </h3>
              <p
                class="text-brand-gris text-[14px] md:text-[15px] leading-relaxed"
              >
                Somos partners certificados en las principales plataformas de
                publicidad digital, cumpliendo estándares de calidad y buenas
                prácticas.
              </p>
            </div>

            <!-- Feature 2 -->
            <div>
              <div
                class="flex items-center justify-center w-8 h-8 mb-4 rounded-full bg-brand-turquesa"
              >
                <Icon
                  name="check"
                  size={18}
                  class="font-black text-brand-celeste"
                />
              </div>
              <h3
                class="text-[17px] md:text-lg font-display font-semibold text-brand-dark mb-2 tracking-tight"
              >
                Tecnología propia
              </h3>
              <p
                class="text-brand-gris text-[14px] md:text-[15px] leading-relaxed"
              >
                Usamos automatización y herramientas internas para optimizar
                campañas más rápido y reducir el desperdicio de inversión.
              </p>
            </div>

            <!-- Feature 3 -->
            <div>
              <div
                class="flex items-center justify-center w-8 h-8 mb-4 rounded-full bg-brand-turquesa"
              >
                <Icon
                  name="check"
                  size={18}
                  class="font-black text-brand-celeste"
                />
              </div>
              <h3
                class="text-[17px] md:text-lg font-display font-semibold text-brand-dark mb-2 tracking-tight"
              >
                Tiempos de respuesta
              </h3>
              <p
                class="text-brand-gris text-[14px] md:text-[15px] leading-relaxed"
              >
                Te respondemos con SLA definidos según el tipo de
                implementación. Menos espera, más velocidad para ejecutar
                mejoras.
              </p>
            </div>

            <!-- Feature 4 -->
            <div>
              <div
                class="flex items-center justify-center w-8 h-8 mb-4 rounded-full bg-brand-turquesa"
              >
                <Icon
                  name="check"
                  size={18}
                  class="font-black text-brand-celeste"
                />
              </div>
              <h3
                class="text-[17px] md:text-lg font-display font-semibold text-brand-dark mb-2 tracking-tight"
              >
                Equipo de trabajo
              </h3>
              <p
                class="text-brand-gris text-[14px] md:text-[15px] leading-relaxed"
              >
                Cada cuenta trabaja con un equipo mínimo de 3 especialistas,
                para asegurar continuidad, análisis y ejecución constante.
              </p>
            </div>
          </div>
        </m-col>

        <!-- Right Column: Image with Bleeding Background -->
        <m-col
          class="relative flex items-center justify-center flex-none w-full lg:w-1/2 lg:mt-0 lg:items-end lg:justify-end"
        >
          <!-- Bleeding Dark Background (Breaks out of the grid to the right) -->
          <div
            class="absolute top-[35%] bottom-[0%] left-[-0%] w-screen bg-brand-dark rounded-[30px] z-0"
          >
          </div>
          <div class="relative z-10 w-full mx-auto max-w-150 lg:mr-0">
            <img
              src={`${BASE}home/mano-celu.webp`}
              alt="Tráfico calificado conversiones"
              class="w-full h-auto"
            />
          </div>
        </m-col>
      </m-row>
    </m-container>
  </section>
  <!-- --------------- PERFORMANCE AI SECTION --------------- -->
  <section id="performance-ai" class="py-16 md:py-24 bg-brand-fondo">
    <m-container>
      <!-- Outer Blue Container -->
      <div
        class="relative flex items-center p-6 overflow-hidden bg-brand-celeste rounded-xl shadow-blue md:p-10 lg:p-10 min-h-150"
      >
        <m-row
          class="relative z-10 flex-col items-center gap-12 lg:flex-row lg:gap-16"
        >
          <!-- Left Side: Text Content -->
          <m-col class="lg:w-[45%] flex-none text-white">
            <!-- Badge -->
            <div class="mb-6">
              <ChipOvertitle text="IA aplicada a performance" theme="dark" />
            </div>

            <!-- Heading -->
            <h2
              class="text-4xl md:text-5xl lg:text-[52px] font-display font-semibold leading-[1.1] tracking-tight mb-8"
            >
              Mejores resultados con<br class="hidden xl:block" /> optimizaciones
              24/7
            </h2>

            <!-- Description Paragraphs -->
            <div
              class="text-white/90 text-[15px] md:text-base leading-snug space-y-3 pr-0 lg:pr-8"
            >
              <p>
                Desarrollamos tecnología propia para monitorear y optimizar
                campañas todos los días.
              </p>
              <p>
                Detectamos oportunidades, reducimos desperdicio de inversión y
                aceleramos mejoras para generar más leads con el mismo
                presupuesto.
              </p>
              <p>
                Unimos automatización + criterio humano para lograr performance
                real.
              </p>
            </div>
          </m-col>

          <!-- Right Side: Action Cards -->
          <m-col class="lg:w-[55%] flex-none flex flex-col gap-6 w-full shrink">
            <!-- Card 1: MIA -->
            <div
              class="flex flex-col items-start gap-6 p-6 transition-colors rounded-lg bg-brand-dark md:p-8 sm:flex-row sm:items-center sm:gap-8 shadow-premium hover:bg-brand-dark/95"
            >
              <!-- Icon -->
              <div class="shrink-0 w-24 md:w-27.5 flex justify-center">
                <img src={`${BASE}ico-MIA.svg`} alt="" />
              </div>
              <!-- Text -->
              <div class="flex flex-col">
                <h3
                  class="text-brand-celeste font-display font-semibold text-lg md:text-[20px] tracking-tight mb-2"
                >
                  MIA: MediaBros Intelligent Automation
                </h3>
                <p
                  class="text-brand-pastel-gris/80 text-[14px] md:text-[15px] leading-relaxed"
                >
                  Optimizaciones automáticas y monitoreo constante para mejorar
                  performance y reducir costos
                </p>
              </div>
            </div>

            <!-- Card 2: App -->
            <div
              class="flex flex-col items-start gap-6 p-6 transition-colors rounded-lg bg-brand-dark md:p-8 sm:flex-row sm:items-center sm:gap-8 shadow-premium hover:bg-brand-dark/95"
            >
              <!-- Icon -->
              <div class="shrink-0 w-24 md:w-27.5 flex justify-center">
                <img src={`${BASE}ico-mb-suite.svg`} alt="" />
              </div>
              <!-- Text -->
              <div class="flex flex-col">
                <h3
                  class="text-brand-celeste font-display font-semibold text-lg md:text-[20px] tracking-tight mb-2"
                >
                  MediaBros App
                </h3>
                <p
                  class="text-brand-pastel-gris/80 text-[14px] md:text-[15px] leading-relaxed"
                >
                  Portal de clientes con estrategia, reportes y performance en
                  tiempo real. Toda la información clara, centralizada y
                  disponible cuando la necesitás.
                </p>
              </div>
            </div>
          </m-col>
        </m-row>
      </div>
    </m-container>
  </section>
  <!-- --------------- SERVICES MULTICHANNEL --------------- -->
  <section id="services-multichannel" class="py-20 lg:py-28 bg-brand-fondo">
    <m-container>
      <!-- Section Header -->
      <m-col class="mb-12 md:mb-16">
        <div class="mb-6">
          <ChipOvertitle text="Servicios" />
        </div>
        <h2
          class="text-4xl md:text-5xl lg:text-[56px] font-display font-semibold text-brand-dark leading-[1.1] tracking-tight max-w-2xl"
        >
          Campañas multicanal<br /> que generan leads
        </h2>
      </m-col>

      <!-- Services Grid -->
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
        <ServiceCard
          icon={`${BASE}iconos/ico-google-ads.png`}
          iconAlt="Google Ads Icon"
          title="Google Ads"
          content="Administración profesional de campañas en Search, Display, Remarketing, Shopping y Video. ¡Optimizamos tus conversiones!"
          link="#"
        />
        <ServiceCard
          icon={`${BASE}iconos/ico-meta.png`}
          iconAlt="Meta Ads Icon"
          title="Meta Ads"
          content="Creamos, configuramos y administramos campañas en Facebook Ads e Instagram Ads de forma profesional."
          link="#"
        />
        <ServiceCard
          icon={`${BASE}iconos/ico-linkedin.png`}
          iconAlt="LinkedIn Ads Icon"
          title="LinkedIn Ads"
          content="Campañas patrocinadas en la red de profesionales mas grande del mundo. Segmentaciones especificas y enfocadas en leads."
          link="#"
        />
        <ServiceCard
          icon={`${BASE}iconos/ico-tiktok.png`}
          iconAlt="Tiktok Ads Icon"
          title="Tiktok Ads"
          content="Gestión de campañas en Tiktok Ads: configuración, segmentación y optimización para atraer tráfico de calidad y aumentar conversiones."
          link="#"
        />
        <ServiceCard
          icon={`${BASE}iconos/ico-seo-content.png`}
          iconAlt="Content SEO Icon"
          title="Content SEO"
          content="Redacción de contenido optimizado para SEO: relevante, estructurado y enfocado en palabras clave para mejorar el posicionamiento en buscadores."
          link="#"
        />
        <ServiceCard
          icon={`${BASE}iconos/ico-seo-technical.png`}
          iconAlt="Technical SEO Icon"
          title="Technical SEO"
          content="Optimización técnica para mejorar el rendimiento e indexación en buscadores: estructura, sitemap, robots y etiquetas."
          link="#"
        />
        <ServiceCard
          icon={`${BASE}iconos/ico-seo-local.png`}
          iconAlt="Local SEO Icon"
          title="Local SEO"
          content="Optimización del posicionamiento geolocalizado a través de Google My Business. Nos aseguramos de que tus clientes encuentren tu empresa."
          link="#"
        />
        <ServiceCard
          icon={`${BASE}iconos/ico-asesoramiento.png`}
          iconAlt="Asesoramiento Icon"
          title="Asesoramiento"
          content="Asesoramiento para aumentar tus leads"
          link="#"
        />
      </div>
    </m-container>
  </section>
  <!-- --------------- CONTACT --------------- -->
  <section id="contact" class="py-14 md:py-24 bg-brand-fondo">
    <m-container>
      <!-- Main Card Wrapper with Blue Background -->
      <div class="relative w-full overflow-hidden rounded-xl shadow-blue">
        <div class="absolute inset-0 bg-brand-celeste/90">
          <img
            src={`${BASE}home/bg.team.webp`}
            alt="Fondo de equipo trabajando"
            class="absolute inset-0 object-cover w-full opacity-8 mix-blend-luminosity h-[150%] -top-70"
          />
        </div>

        <!-- Content -->
        <div class="relative z-10 p-6 md:p-10 lg:p-10">
          <m-row class="flex-col items-center gap-12 lg:flex-row">
            <!-- Left Column: Text Content -->
            <m-col class="flex-1 w-full lg:w-1/2">
              <div class="max-w-xl">
                <!-- Tag/Badge -->
                <div class="mb-8">
                  <ChipOvertitle text="Conversemos" theme="dark" />
                </div>

                <!-- Heading -->
                <h2
                  class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl lg:text-6xl font-display"
                >
                  Apasionados por el Marketing Digital
                </h2>

                <!-- Description -->
                <p class="text-lg leading-relaxed text-white/90">
                  Desarrollamos estrategias de marketing digital para nuestros
                  clientes, desde la etapa de planeamiento hasta la
                  implementación de campañas de marketing digital, medición de
                  resultados y asesoramiento personalizado.
                </p>
              </div>
            </m-col>

            <!-- Right Column: Empty Space (As requested) -->
            <m-col class="flex-1 w-full lg:w-1/2">
              <LeadForm theme="light" />
            </m-col>
          </m-row>
        </div>
      </div>
    </m-container>
  </section>
  <!-- --------------- CLIENTS CAROUSEL --------------- -->
  <section id="clients-carousel" class="py-16 md:py-24 bg-brand-fondo">
    <m-container>
      <m-col class="items-center mb-12 text-center md:mb-16">
        <!-- Badge -->
        <div class="mb-6">
          <ChipOvertitle text="Nuestros clientes" />
        </div>
        <!-- Heading -->
        <h2
          class="text-3xl md:text-4xl lg:text-[44px] font-display font-semibold tracking-tight"
        >
          <span class="text-brand-dark">+150 empresas</span>
          <span class="text-brand-gris">confían en nosotros</span>
        </h2>
      </m-col>

      <!-- Carousel Container -->
      <div class="relative w-full">
        <!-- Left Fade -->
        <div
          class="absolute inset-y-0 left-0 z-10 w-16 pointer-events-none md:w-32 bg-linear-to-r from-brand-fondo to-transparent"
        >
        </div>

        <!-- Right Fade -->
        <div
          class="absolute inset-y-0 right-0 z-10 w-16 pointer-events-none md:w-32 bg-linear-to-l from-brand-fondo to-transparent"
        >
        </div>

        <!-- Scrollable Track -->
        <div
          class="flex items-center justify-between gap-12 px-8 py-4 overflow-x-auto md:gap-20 snap-x"
        >
          <!-- Client Logos -->
          <img
            src="https://placehold.co/200x80/f7f8ff/7388aa?text=Logo+Citrin"
            alt="Cliente 1"
            class="object-contain w-auto h-8 transition-opacity opacity-50 md:h-12 hover:opacity-100 snap-center shrink-0 mix-blend-multiply"
          />
          <img
            src="https://placehold.co/200x80/f7f8ff/7388aa?text=Logo+Chaer"
            alt="Cliente 2"
            class="object-contain w-auto h-8 transition-opacity opacity-50 md:h-12 hover:opacity-100 snap-center shrink-0 mix-blend-multiply"
          />
          <img
            src="https://placehold.co/200x80/f7f8ff/7388aa?text=Logo+CareU"
            alt="Cliente 3"
            class="object-contain w-auto h-8 transition-opacity opacity-50 md:h-12 hover:opacity-100 snap-center shrink-0 mix-blend-multiply"
          />
          <img
            src="https://placehold.co/200x80/f7f8ff/7388aa?text=Logo+Caracas"
            alt="Cliente 4"
            class="object-contain w-auto h-8 transition-opacity opacity-50 md:h-12 hover:opacity-100 snap-center shrink-0 mix-blend-multiply"
          />
          <img
            src="https://placehold.co/200x80/f7f8ff/7388aa?text=Logo+Canaglia"
            alt="Cliente 5"
            class="object-contain w-auto h-8 transition-opacity opacity-50 md:h-12 hover:opacity-100 snap-center shrink-0 mix-blend-multiply"
          />
          <img
            src="https://placehold.co/200x80/f7f8ff/7388aa?text=Logo+Cami"
            alt="Cliente 6"
            class="object-contain w-auto h-8 transition-opacity opacity-50 md:h-12 hover:opacity-100 snap-center shrink-0 mix-blend-multiply"
          />
        </div>
      </div>
    </m-container>
  </section>
  <Certificaciones />
  <Footer />
</Layout>
