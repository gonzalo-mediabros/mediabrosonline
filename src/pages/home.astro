---
import Layout from "../layouts/Layout.astro";

import BigHero from "../components/ui/big-hero.astro";
import LeadForm from "../components/ui/LeadForm.astro";

const BASE = import.meta.env.BASE_URL;
---

<Layout
  title="Mediabros - Rediseño Estratégico"
  description="Genera leads de calidad para tu empresa con una estrategia de marketing digital probada. Curso online gratuito en 45 minutos."
>
  <!-- ----- HERO ----- -->
  <BigHero />
  <!-- --------------- QUALIFIED LEADS SECTION --------------- -->
  <section
    id="qualified-leads"
    class="relative py-16 overflow-hidden lg:py-24 bg-brand-fondo"
  >
    <m-container class="relative z-10">
      <m-row
        class="flex-col items-center gap-12 lg:flex-row lg:gap-8 lg:items-stretch"
      >
        <!-- Left Column: Content -->
        <m-col
          class="flex flex-col justify-center flex-none w-full lg:w-1/2 lg:pr-8 xl:pr-16"
        >
          <!-- Badge -->
          <div class="mb-6 lg:mb-8">
            <span
              class="inline-block border border-brand-dark/20 text-brand-dark/80 rounded-full px-5 py-1.5 text-[14px] md:text-[15px] tracking-wide bg-transparent"
            >
              Nuestra agencia de marketing digital
            </span>
          </div>

          <!-- Heading -->
          <h2
            class="text-4xl md:text-5xl xl:text-[52px] font-display font-semibold text-brand-dark leading-[1.15] tracking-tight mb-8"
          >
            Recibe leads calificados<br class="hidden md:block" /> de forma constante
          </h2>

          <!-- CTA Button -->
          <div class="mb-12 lg:mb-16">
            <a
              href="#"
              class="inline-flex items-center justify-center gap-2 bg-brand-celeste hover:bg-brand-celeste-hover text-white font-medium text-base px-8 py-3.5 rounded-full transition-colors shadow-blue"
            >
              Solicitar diagnóstico
              <m-icon class="material-symbols-outlined text-[20px]"
                >arrow_forward</m-icon
              >
            </a>
          </div>

          <!-- Features Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-10">
            <!-- Feature 1 -->
            <div>
              <div
                class="flex items-center justify-center w-8 h-8 mb-4 rounded-full bg-brand-turquesa"
              >
                <m-icon
                  class="material-symbols-outlined text-brand-celeste text-[18px] font-black"
                  >check</m-icon
                >
              </div>
              <h3
                class="text-[17px] md:text-lg font-display font-semibold text-brand-dark mb-2 tracking-tight"
              >
                Nuestras certificaciones
              </h3>
              <p
                class="text-brand-gris text-[14px] md:text-[15px] leading-relaxed"
              >
                Somos partners certificados en las principales plataformas de
                publicidad digital, cumpliendo estándares de calidad y buenas
                prácticas.
              </p>
            </div>

            <!-- Feature 2 -->
            <div>
              <div
                class="flex items-center justify-center w-8 h-8 mb-4 rounded-full bg-brand-turquesa"
              >
                <m-icon
                  class="material-symbols-outlined text-brand-celeste text-[18px] font-black"
                  >check</m-icon
                >
              </div>
              <h3
                class="text-[17px] md:text-lg font-display font-semibold text-brand-dark mb-2 tracking-tight"
              >
                Tecnología propia
              </h3>
              <p
                class="text-brand-gris text-[14px] md:text-[15px] leading-relaxed"
              >
                Usamos automatización y herramientas internas para optimizar
                campañas más rápido y reducir el desperdicio de inversión.
              </p>
            </div>

            <!-- Feature 3 -->
            <div>
              <div
                class="flex items-center justify-center w-8 h-8 mb-4 rounded-full bg-brand-turquesa"
              >
                <m-icon
                  class="material-symbols-outlined text-brand-celeste text-[18px] font-black"
                  >check</m-icon
                >
              </div>
              <h3
                class="text-[17px] md:text-lg font-display font-semibold text-brand-dark mb-2 tracking-tight"
              >
                Tiempos de respuesta
              </h3>
              <p
                class="text-brand-gris text-[14px] md:text-[15px] leading-relaxed"
              >
                Te respondemos con SLA definidos según el tipo de
                implementación. Menos espera, más velocidad para ejecutar
                mejoras.
              </p>
            </div>

            <!-- Feature 4 -->
            <div>
              <div
                class="flex items-center justify-center w-8 h-8 mb-4 rounded-full bg-brand-turquesa"
              >
                <m-icon
                  class="material-symbols-outlined text-brand-celeste text-[18px] font-black"
                  >check</m-icon
                >
              </div>
              <h3
                class="text-[17px] md:text-lg font-display font-semibold text-brand-dark mb-2 tracking-tight"
              >
                Equipo de trabajo
              </h3>
              <p
                class="text-brand-gris text-[14px] md:text-[15px] leading-relaxed"
              >
                Cada cuenta trabaja con un equipo mínimo de 3 especialistas,
                para asegurar continuidad, análisis y ejecución constante.
              </p>
            </div>
          </div>
        </m-col>

        <!-- Right Column: Image with Bleeding Background -->
        <m-col
          class="relative flex items-center justify-center flex-none w-full lg:w-1/2 lg:mt-0 lg:items-end lg:justify-end"
        >
          <!-- Bleeding Dark Background (Breaks out of the grid to the right) -->
          <div
            class="absolute top-[35%] bottom-[0%] left-[-0%] w-screen bg-brand-dark rounded-[30px] z-0"
          >
          </div>
          <div class="relative z-10 w-full mx-auto max-w-150 lg:mr-0">
            <img
              src="home/mano-celu.webp"
              alt="Tráfico calificado conversiones"
              class="w-full h-auto"
            />
          </div>
        </m-col>
      </m-row>
    </m-container>
  </section>
  <!-- DEFINICIÓN DE SVGs (Colocar arriba en Astro) -->
  <svg width="0" height="0" class="absolute hidden">
    <symbol id="icon-mia" viewBox="0 0 146 96" fill="none">
      <g clip-path="url(#clip0_115_388)">
        <path
          d="M0 0L69.0441 16.5423L69.0565 17.8633C69.0565 17.8633 66.4688 17.4502 66.2423 17.4975L48.2468 49.9704L30.94 17.5921L18.9295 17.4975V75.5074C21.6288 75.7407 25.805 76.2451 28.4051 75.8353C29.038 75.7344 29.491 75.6776 29.7237 74.9683L30.0992 38.936L30.7973 39.3395L43.7324 64.9616L51.5077 65.2579L65.9321 36.4106L66.1213 76.6392L0 96V0Z"
          fill="#148BEF"></path>
        <path
          d="M134.812 76.7684C134.489 76.6927 133.968 77.0963 133.788 76.7684L128.765 61.4746L109.047 61.2949L103.471 76.7684H92.1467L113.838 18.6514H123.316L145.997 76.7684H134.809H134.812ZM126.869 53.4037L118.991 31.0573L110.775 53.4226L126.866 53.4068L126.869 53.4037Z"
          fill="#148BEF"></path>
        <path
          d="M88.7368 32.9458V76.7685H77.7285C77.9581 62.4362 77.7068 47.3127 77.7285 32.9458H88.7368Z"
          fill="#148BEF"></path>
        <path
          d="M88.7368 14.9753H77.7285V26.3251H88.7368V14.9753Z"
          fill="#148BEF"></path>
      </g>
      <defs>
        <clipPath id="clip0_115_388">
          <rect width="146" height="96" fill="white"></rect>
        </clipPath>
      </defs>
    </symbol>
    <symbol id="icon-app" viewBox="0 0 133 52" fill="none">
      <path
        d="M34.1406 52L31.2109 42.0391H15.0781L12.1875 52H0.234375L16.7578 0.828125H29.5312L46.0938 52H34.1406ZM23.0469 14.5781L17.7344 32.8984H28.5938L23.2422 14.5781H23.0469ZM59.2406 9.96875V25.3203H68.1078C70.6339 25.3203 72.574 24.6302 73.9281 23.25C75.3083 21.8698 75.9984 20.0208 75.9984 17.7031C75.9984 15.3594 75.3083 13.4844 73.9281 12.0781C72.574 10.6719 70.6339 9.96875 68.1078 9.96875H59.2406ZM68.1078 34.4609H59.2406V52H47.3266V0.828125H68.1078C74.1755 0.828125 78.9802 2.36458 82.5219 5.4375C86.0896 8.51042 87.8734 12.5859 87.8734 17.6641C87.8734 22.7422 86.0896 26.8177 82.5219 29.8906C78.9802 32.9375 74.1755 34.4609 68.1078 34.4609ZM104.106 9.96875V25.3203H112.973C115.499 25.3203 117.44 24.6302 118.794 23.25C120.174 21.8698 120.864 20.0208 120.864 17.7031C120.864 15.3594 120.174 13.4844 118.794 12.0781C117.44 10.6719 115.499 9.96875 112.973 9.96875H104.106ZM112.973 34.4609H104.106V52H92.1922V0.828125H112.973C119.041 0.828125 123.846 2.36458 127.387 5.4375C130.955 8.51042 132.739 12.5859 132.739 17.6641C132.739 22.7422 130.955 26.8177 127.387 29.8906C123.846 32.9375 119.041 34.4609 112.973 34.4609Z"
        fill="#148BEF"></path>
    </symbol>
  </svg>

  <!-- --------------- PERFORMANCE AI SECTION --------------- -->
  <section id="performance-ai" class="py-16 md:py-24 bg-brand-fondo">
    <m-container>
      <!-- Outer Blue Container -->
      <div
        class="relative px-6 py-12 overflow-hidden bg-brand-celeste rounded-xl shadow-blue md:p-12 lg:p-16"
      >
        <m-row
          class="relative z-10 flex-col items-center gap-12 lg:flex-row lg:gap-16"
        >
          <!-- Left Side: Text Content -->
          <m-col class="lg:w-[45%] flex-none text-white">
            <!-- Badge -->
            <div class="mb-6">
              <span
                class="inline-block border border-white/40 text-white rounded-full px-5 py-1.5 text-[14px] font-medium tracking-wide"
              >
                IA aplicada a performance
              </span>
            </div>

            <!-- Heading -->
            <h2
              class="text-4xl md:text-5xl lg:text-[52px] font-display font-semibold leading-[1.1] tracking-tight mb-8"
            >
              Mejores resultados con<br class="hidden xl:block" /> optimizaciones
              24/7
            </h2>

            <!-- Description Paragraphs -->
            <div
              class="text-white/90 text-[15px] md:text-base leading-relaxed space-y-4 pr-0 lg:pr-8"
            >
              <p>
                Desarrollamos tecnología propia para monitorear y optimizar
                campañas todos los días.
              </p>
              <p>
                Detectamos oportunidades, reducimos desperdicio de inversión y
                aceleramos mejoras para generar más leads con el mismo
                presupuesto.
              </p>
              <p>
                Unimos automatización + criterio humano para lograr performance
                real.
              </p>
            </div>
          </m-col>

          <!-- Right Side: Action Cards -->
          <m-col class="lg:w-[55%] flex-none flex flex-col gap-6 w-full">
            <!-- Card 1: MIA -->
            <div
              class="flex flex-col items-start gap-6 p-6 transition-colors rounded-lg bg-brand-dark md:p-8 sm:flex-row sm:items-center sm:gap-8 shadow-premium hover:bg-brand-dark/95"
            >
              <!-- Icon -->
              <div class="shrink-0 w-24 md:w-[110px] flex justify-center">
                <svg class="w-full h-auto"><use href="#icon-mia"></use></svg>
              </div>
              <!-- Text -->
              <div class="flex-1">
                <h3
                  class="text-brand-celeste font-display font-semibold text-lg md:text-[20px] tracking-tight mb-2"
                >
                  MIA: MediaBros Intelligent Automation
                </h3>
                <p
                  class="text-brand-pastel-gris/80 text-[14px] md:text-[15px] leading-relaxed"
                >
                  Optimizaciones automáticas y monitoreo constante para mejorar
                  performance y reducir costos
                </p>
              </div>
            </div>

            <!-- Card 2: App -->
            <div
              class="flex flex-col items-start gap-6 p-6 transition-colors rounded-lg bg-brand-dark md:p-8 sm:flex-row sm:items-center sm:gap-8 shadow-premium hover:bg-brand-dark/95"
            >
              <!-- Icon -->
              <div class="shrink-0 w-24 md:w-[110px] flex justify-center">
                <svg class="w-full h-auto"><use href="#icon-app"></use></svg>
              </div>
              <!-- Text -->
              <div class="flex-1">
                <h3
                  class="text-brand-celeste font-display font-semibold text-lg md:text-[20px] tracking-tight mb-2"
                >
                  MediaBros App
                </h3>
                <p
                  class="text-brand-pastel-gris/80 text-[14px] md:text-[15px] leading-relaxed"
                >
                  Portal de clientes con estrategia, reportes y performance en
                  tiempo real. Toda la información clara, centralizada y
                  disponible cuando la necesitás.
                </p>
              </div>
            </div>
          </m-col>
        </m-row>
      </div>
    </m-container>
  </section>
  <!-- --------------- SERVICES MULTICHANNEL --------------- -->
  <section id="services-multichannel" class="py-20 lg:py-28 bg-brand-fondo">
    <m-container>
      <!-- Section Header -->
      <m-col class="mb-12 md:mb-16">
        <div class="mb-6">
          <span
            class="inline-block border border-brand-dark/20 text-brand-dark/80 rounded-full px-5 py-1.5 text-sm md:text-[15px] tracking-wide"
          >
            Servicios
          </span>
        </div>
        <h2
          class="text-4xl md:text-5xl lg:text-[56px] font-display font-semibold text-brand-dark leading-[1.1] tracking-tight max-w-2xl"
        >
          Campañas multicanal<br /> que generan leads
        </h2>
      </m-col>

      <!-- Services Grid -->
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
        <!-- Card 1: Google Ads -->
        <div
          class="group flex flex-col bg-white rounded-[24px] p-6 lg:p-8 shadow-card hover:shadow-card-hover hover:bg-brand-dark hover:-translate-y-1 transition-all duration-300 cursor-pointer"
        >
          <div class="flex items-center gap-4 mb-6">
            <div
              class="flex items-center justify-center transition-colors rounded-full w-14 h-14 shrink-0 bg-brand-fondo group-hover:bg-white/10"
            >
              <img
                src="iconos/ico-google-ads.png"
                alt="Google Ads Icon"
                class="object-contain w-8 h-8"
              />
            </div>
            <h3
              class="text-[22px] font-display font-semibold text-brand-dark group-hover:text-white transition-colors tracking-tight"
            >
              Google Ads
            </h3>
          </div>
          <p
            class="text-brand-gris text-[15px] leading-relaxed group-hover:text-white/80 transition-colors flex-1 mb-8"
          >
            Administración profesional de campañas en Search, Display,
            Remarketing, Shopping y Video. ¡Optimizamos tus conversiones!
          </p>
          <div
            class="flex items-center self-end justify-center w-8 h-8 mt-auto transition-colors rounded-full bg-brand-fondo group-hover:bg-white/10"
          >
            <m-icon
              class="material-symbols-outlined text-[18px] text-brand-gris group-hover:text-white transition-colors"
              >arrow_forward</m-icon
            >
          </div>
        </div>

        <!-- Card 2: Meta Ads -->
        <div
          class="group flex flex-col bg-white rounded-[24px] p-6 lg:p-8 shadow-card hover:shadow-card-hover hover:bg-brand-dark hover:-translate-y-1 transition-all duration-300 cursor-pointer"
        >
          <div class="flex items-center gap-4 mb-6">
            <div
              class="flex items-center justify-center transition-colors rounded-full w-14 h-14 shrink-0 bg-brand-fondo group-hover:bg-white/10"
            >
              <img
                src="iconos/ico-meta.png"
                alt="Meta Ads Icon"
                class="object-contain w-8 h-8"
              />
            </div>
            <h3
              class="text-[22px] font-display font-semibold text-brand-dark group-hover:text-white transition-colors tracking-tight"
            >
              Meta Ads
            </h3>
          </div>
          <p
            class="text-brand-gris text-[15px] leading-relaxed group-hover:text-white/80 transition-colors flex-1 mb-8"
          >
            Creamos, configuramos y administramos campañas en Facebook Ads e
            Instagram Ads de forma profesional.
          </p>
          <div
            class="flex items-center self-end justify-center w-8 h-8 mt-auto transition-colors rounded-full bg-brand-fondo group-hover:bg-white/10"
          >
            <m-icon
              class="material-symbols-outlined text-[18px] text-brand-gris group-hover:text-white transition-colors"
              >arrow_forward</m-icon
            >
          </div>
        </div>

        <!-- Card 3: LinkedIn Ads -->
        <div
          class="group flex flex-col bg-white rounded-[24px] p-6 lg:p-8 shadow-card hover:shadow-card-hover hover:bg-brand-dark hover:-translate-y-1 transition-all duration-300 cursor-pointer"
        >
          <div class="flex items-center gap-4 mb-6">
            <div
              class="flex items-center justify-center transition-colors rounded-full w-14 h-14 shrink-0 bg-brand-fondo group-hover:bg-white/10"
            >
              <img
                src="iconos/ico-linkedin.png"
                alt="LinkedIn Ads Icon"
                class="object-contain w-8 h-8"
              />
            </div>
            <h3
              class="text-[22px] font-display font-semibold text-brand-dark group-hover:text-white transition-colors tracking-tight"
            >
              LinkedIn Ads
            </h3>
          </div>
          <p
            class="text-brand-gris text-[15px] leading-relaxed group-hover:text-white/80 transition-colors flex-1 mb-8"
          >
            Campañas patrocinadas en la red de profesionales mas grande del
            mundo. Segmentaciones especificas y enfocadas en leads.
          </p>
          <div
            class="flex items-center self-end justify-center w-8 h-8 mt-auto transition-colors rounded-full bg-brand-fondo group-hover:bg-white/10"
          >
            <m-icon
              class="material-symbols-outlined text-[18px] text-brand-gris group-hover:text-white transition-colors"
              >arrow_forward</m-icon
            >
          </div>
        </div>

        <!-- Card 4: Tiktok Ads (Simulating active/hovered state naturally via Tailwind group mechanics) -->
        <div
          class="group flex flex-col bg-white rounded-[24px] p-6 lg:p-8 shadow-card hover:shadow-card-hover hover:bg-brand-dark hover:-translate-y-1 transition-all duration-300 cursor-pointer"
        >
          <div class="flex items-center gap-4 mb-6">
            <div
              class="flex items-center justify-center transition-colors rounded-full w-14 h-14 shrink-0 bg-brand-fondo group-hover:bg-white/10"
            >
              <img
                src="iconos/ico-tiktok.png"
                alt="Tiktok Ads Icon"
                class="object-contain w-8 h-8"
              />
            </div>
            <h3
              class="text-[22px] font-display font-semibold text-brand-dark group-hover:text-white transition-colors tracking-tight"
            >
              Tiktok Ads
            </h3>
          </div>
          <p
            class="text-brand-gris text-[15px] leading-relaxed group-hover:text-white/80 transition-colors flex-1 mb-8"
          >
            Gestión de campañas en Tiktok Ads: configuración, segmentación y
            optimización para atraer tráfico de calidad y aumentar conversiones.
          </p>
          <div
            class="flex items-center self-end justify-center w-8 h-8 mt-auto transition-colors rounded-full bg-brand-fondo group-hover:bg-white/10"
          >
            <m-icon
              class="material-symbols-outlined text-[18px] text-brand-gris group-hover:text-white transition-colors"
              >arrow_forward</m-icon
            >
          </div>
        </div>

        <!-- Card 5: Content SEO -->
        <div
          class="group flex flex-col bg-white rounded-[24px] p-6 lg:p-8 shadow-card hover:shadow-card-hover hover:bg-brand-dark hover:-translate-y-1 transition-all duration-300 cursor-pointer"
        >
          <div class="flex items-center gap-4 mb-6">
            <div
              class="flex items-center justify-center transition-colors rounded-full w-14 h-14 shrink-0 bg-brand-fondo group-hover:bg-white/10"
            >
              <img
                src="iconos/ico-seo-content.png"
                alt="Content SEO Icon"
                class="object-contain w-8 h-8"
              />
            </div>
            <h3
              class="text-[22px] font-display font-semibold text-brand-dark group-hover:text-white transition-colors tracking-tight"
            >
              Content SEO
            </h3>
          </div>
          <p
            class="text-brand-gris text-[15px] leading-relaxed group-hover:text-white/80 transition-colors flex-1 mb-8"
          >
            Redacción de contenido optimizado para SEO: relevante, estructurado
            y enfocado en palabras clave para mejorar el posicionamiento en
            buscadores.
          </p>
          <div
            class="flex items-center self-end justify-center w-8 h-8 mt-auto transition-colors rounded-full bg-brand-fondo group-hover:bg-white/10"
          >
            <m-icon
              class="material-symbols-outlined text-[18px] text-brand-gris group-hover:text-white transition-colors"
              >arrow_forward</m-icon
            >
          </div>
        </div>

        <!-- Card 6: Technical SEO -->
        <div
          class="group flex flex-col bg-white rounded-[24px] p-6 lg:p-8 shadow-card hover:shadow-card-hover hover:bg-brand-dark hover:-translate-y-1 transition-all duration-300 cursor-pointer"
        >
          <div class="flex items-center gap-4 mb-6">
            <div
              class="flex items-center justify-center transition-colors rounded-full w-14 h-14 shrink-0 bg-brand-fondo group-hover:bg-white/10"
            >
              <img
                src="iconos/ico-seo-technical.png"
                alt="Technical SEO Icon"
                class="object-contain w-8 h-8"
              />
            </div>
            <h3
              class="text-[22px] font-display font-semibold text-brand-dark group-hover:text-white transition-colors tracking-tight"
            >
              Technical SEO
            </h3>
          </div>
          <p
            class="text-brand-gris text-[15px] leading-relaxed group-hover:text-white/80 transition-colors flex-1 mb-8"
          >
            Optimización técnica para mejorar el rendimiento e indexación en
            buscadores: estructura, sitemap, robots y etiquetas.
          </p>
          <div
            class="flex items-center self-end justify-center w-8 h-8 mt-auto transition-colors rounded-full bg-brand-fondo group-hover:bg-white/10"
          >
            <m-icon
              class="material-symbols-outlined text-[18px] text-brand-gris group-hover:text-white transition-colors"
              >arrow_forward</m-icon
            >
          </div>
        </div>

        <!-- Card 7: Local SEO -->
        <div
          class="group flex flex-col bg-white rounded-[24px] p-6 lg:p-8 shadow-card hover:shadow-card-hover hover:bg-brand-dark hover:-translate-y-1 transition-all duration-300 cursor-pointer"
        >
          <div class="flex items-center gap-4 mb-6">
            <div
              class="flex items-center justify-center transition-colors rounded-full w-14 h-14 shrink-0 bg-brand-fondo group-hover:bg-white/10"
            >
              <img
                src="iconos/ico-seo-local.png"
                alt="Local SEO Icon"
                class="object-contain w-8 h-8"
              />
            </div>
            <h3
              class="text-[22px] font-display font-semibold text-brand-dark group-hover:text-white transition-colors tracking-tight"
            >
              Local SEO
            </h3>
          </div>
          <p
