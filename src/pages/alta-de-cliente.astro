---
import Layout from "@/layouts/Layout.astro";
import Navigation from "@/components/ui/Navigation.astro";
import HeroSmall from "@/components/ui/HeroSmall.astro";
import Breadcrumb from "@/components/atoms/Breadcrumb.astro";
import FormClienteAlta from "@/components/form/FormClienteAlta.astro";
import Certificaciones from "@/components/ui/Certificaciones.astro";
import Footer from "@/components/ui/Footer.astro";

const { pathname } = Astro.url;

const SEO = {
  title: "Alta de cliente | Mediabros Online",
  description:
    "Alta de cliente. Agencia MediaBros: Tráfico calificado y conversiones. Servicios Paid Media, Posicionamiento y Análisis.",
  canonicalURL: new URL(Astro.url.pathname, Astro.site ?? Astro.url).href,
  ogType: "website" as const,
  noindex: true,
};
---

<Layout {...SEO}>
  <Navigation pathname={pathname} />

  <HeroSmall
    title="Alta de cliente"
    subtitle="Agencia MediaBros: Tráfico calificado y conversiones"
  />

  <Breadcrumb
    items={[{ label: "Home", href: "/" }, { label: "Alta de cliente" }]}
  />

  <main class="py-16 md:py-24 bg-brand-bg">
    <m-container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-center text-3xl font-display font-semibold mb-8">
          Completá tus datos para comenzar.
        </h2>

        <FormClienteAlta />
      </div>
    </m-container>
  </main>

  <Certificaciones />
  <Footer />
</Layout>
