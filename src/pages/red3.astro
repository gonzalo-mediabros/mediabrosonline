<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Williams Psicología | Terapia para hispanohablantes</title>

    <!-- Tailwind CSS v4 -->
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>

    <!-- Google Fonts: Lora (Serif/Elegancia) & Manrope (Sans/Modernidad) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Google Material Icons -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24..48,200..300,0,0"
      rel="stylesheet"
    />

    <style>
      body {
        font-family: "Manrope", sans-serif;
        background-color: #f9f8f6; /* Blanco roto / Arena muy claro */
        color: #2c2a28; /* Gris muy oscuro, más suave que el negro puro */
      }
      h1,
      h2,
      h3,
      .font-serif {
        font-family: "Lora", serif;
      }
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 300,
          "GRAD" 0,
          "opsz" 48;
      }
      /* Ocultar scrollbar en el carrusel para un look más limpio */
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </head>
  <body class="antialiased selection:bg-[#C05C47] selection:text-white">
    <!-- Navegación Minimalista -->
    <nav
      class="fixed w-full top-0 z-50 bg-[#F9F8F6]/80 backdrop-blur-md border-b border-[#EAE6DF]"
    >
      <div
        class="max-w-[1200px] mx-auto px-6 py-5 flex justify-between items-center"
      >
        <div class="text-2xl font-serif font-medium tracking-wide">
          Williams<span class="text-[#C05C47]">.</span>
        </div>
        <div
          class="hidden md:flex space-x-8 text-[13px] font-semibold tracking-widest uppercase text-[#7A7369]"
        >
          <a href="#equipo" class="hover:text-[#C05C47] transition-colors"
            >Equipo</a
          >
          <a href="#servicios" class="hover:text-[#C05C47] transition-colors"
            >Especialidades</a
          >
          <a href="#enfoque" class="hover:text-[#C05C47] transition-colors"
            >Enfoque</a
          >
        </div>
        <a
          href="#tarifas"
          class="bg-[#2C2A28] text-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-[#C05C47] transition-colors duration-300"
        >
          Reservar sesión
        </a>
      </div>
    </nav>

    <!-- Hero Section (Orientada al servicio y la calma) -->
    <section class="pt-40 pb-24 px-6 relative overflow-hidden">
      <div
        class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center"
      >
        <div class="relative z-10">
          <div
            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#EAE6DF] text-[#7A7369] text-xs font-bold tracking-widest uppercase mb-8"
          >
            <span class="material-symbols-outlined text-[16px]">public</span>
            Terapia Online Global
          </div>
          <h1
            class="text-5xl md:text-6xl lg:text-[4.5rem] font-serif leading-[1.1] mb-6 text-[#2C2A28]"
          >
            Un espacio propio,<br />
            <span class="text-[#C05C47] italic font-light"
              >estés donde estés.</span
            >
          </h1>
          <p
            class="text-lg md:text-xl text-[#5C574F] font-light leading-relaxed mb-10 max-w-lg"
          >
            Acompañamos a personas hispanohablantes que viven lejos de su país a
            transitar sus procesos emocionales en su idioma y desde su cultura.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#contacto"
              class="bg-[#C05C47] text-white px-8 py-4 rounded-full text-center font-medium hover:bg-[#A84E3A] transition-colors shadow-lg shadow-[#C05C47]/20"
            >
              Comenzar mi proceso
            </a>
            <a
              href="#servicios"
              class="px-8 py-4 rounded-full text-center font-medium bg-white text-[#2C2A28] border border-[#EAE6DF] hover:border-[#C05C47] transition-colors"
            >
              Ver áreas de trabajo
            </a>
          </div>
        </div>

        <div
          class="relative w-full h-[600px] rounded-[2rem] overflow-hidden shadow-2xl shadow-[#2C2A28]/5"
        >
          <!-- Imagen suave de consultorio/servicio -->
          <img
            src="https://images.unsplash.com/photo-1573497620053-ea5300f94f21?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80"
            alt="Sesión de terapia"
            class="w-full h-full object-cover"
          />
          <!-- Overlay sutil -->
          <div
            class="absolute inset-0 bg-[#C05C47] mix-blend-overlay opacity-10"
          >
          </div>
        </div>
      </div>
    </section>

    <!-- Equipo Section (Avatares pequeños, centrados en el mensaje) -->
    <section
      id="equipo"
      class="py-24 bg-white px-6 border-t border-b border-[#EAE6DF]"
    >
      <div class="max-w-[1200px] mx-auto">
        <div class="max-w-3xl mb-16">
          <h2 class="text-4xl md:text-5xl font-serif text-[#2C2A28] mb-6">
            Somos colegas y familia.
          </h2>
          <p class="text-xl text-[#5C574F] font-light leading-relaxed">
            Llegamos a este proyecto con trayectorias clínicas distintas pero
            con una idea en común: <span class="font-medium text-[#2C2A28]"
              >que la psicoterapia de calidad requiere algo más que técnica</span
            > — requiere que el profesional comprenda el mundo del paciente, su cultura,
            su forma de nombrar las cosas y de vincularse.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24">
          <!-- Guillermo -->
          <div>
            <div class="flex items-center gap-5 mb-6">
              <img
                src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&q=80"
                alt="Guillermo"
                class="w-16 h-16 rounded-full object-cover border border-[#EAE6DF] shadow-sm grayscale"
              />
              <div>
                <h3 class="text-2xl font-serif text-[#2C2A28]">
                  Guillermo Williams
                </h3>
                <p
                  class="text-[#C05C47] text-xs font-bold tracking-widest uppercase mt-1"
                >
                  Psicólogo UBA
                </p>
              </div>
            </div>
            <div class="space-y-4 text-[#5C574F] font-light leading-relaxed">
              <p>
                Más de 10 años de experiencia clínica y sociocomunitaria en
                distintos dispositivos: acompañamiento terapéutico, espacios
                grupales y consultorio.
              </p>
              <p>
                Trabajo desde un enfoque integrativo, combinando herramientas de
                distintas corrientes según lo que cada proceso requiere.
              </p>
              <p>
                Me interesa pensar junto con el paciente, de manera ética y
                transparente, sobre aquello que lo trae al espacio terapéutico —
                en un contexto epocal que no facilita precisamente ese tipo de
                pausa y reflexión.
              </p>
            </div>
          </div>

          <!-- Diego -->
          <div>
            <div class="flex items-center gap-5 mb-6">
              <img
                src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&q=80"
                alt="Diego"
                class="w-16 h-16 rounded-full object-cover border border-[#EAE6DF] shadow-sm grayscale"
              />
              <div>
                <h3 class="text-2xl font-serif text-[#2C2A28]">
                  Diego Williams
                </h3>
                <p
                  class="text-[#C05C47] text-xs font-bold tracking-widest uppercase mt-1"
                >
                  Psicólogo UNC
                </p>
              </div>
            </div>
            <div class="space-y-4 text-[#5C574F] font-light leading-relaxed">
              <p>Llevo 18 años ayudando a personas a estar mejor.</p>
              <p>
                Creo firmemente que no hay diagnóstico ni etiqueta que agote la
                experiencia de cada uno. Las dificultades, miedos y angustias
                que cada persona atraviesa son únicas — y es justamente esa
                singularidad lo que hace de la terapia algo tan significativo.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Servicios (Carrusel de Cards Grandes e Iguales) -->
    <section
      id="servicios"
      class="py-24 pl-6 md:pl-12 lg:pl-[calc(50vw-600px)] overflow-hidden bg-[#F9F8F6]"
    >
      <div class="mb-12 pr-6 max-w-3xl">
        <span
          class="text-[#7A7369] text-xs font-bold tracking-widest uppercase mb-4 block"
          >Motivos de Consulta</span
        >
        <h2 class="text-4xl md:text-5xl font-serif text-[#2C2A28] mb-6">
          ¿En qué podemos ayudarte?
        </h2>
      </div>

      <!-- Contenedor Carrusel -->
      <div
        class="flex gap-6 overflow-x-auto snap-x snap-mandatory pb-12 no-scrollbar cursor-grab active:cursor-grabbing"
      >
        <!-- Duelo Migratorio (Card Destacada) -->
        <div
          class="snap-start shrink-0 w-[85vw] sm:w-[400px] h-[480px] bg-[#2C2A28] text-white rounded-[2rem] p-10 flex flex-col justify-between shadow-xl shadow-[#2C2A28]/10 group"
        >
          <span
            class="material-symbols-outlined text-[3rem] text-[#C05C47] bg-white/10 w-16 h-16 rounded-2xl flex items-center justify-center"
            >public</span
          >
          <div>
            <h3 class="text-3xl font-serif mb-4 leading-tight">
              Duelo migratorio y desarraigo
            </h3>
            <p class="text-white/70 font-light leading-relaxed">
              Vivir afuera puede ser mucho a la vez: la nostalgia, la
              adaptación, sentir que no terminás de pertenecer a ningún lado. Es
              más frecuente de lo que se habla.
            </p>
          </div>
        </div>

        <!-- Ansiedad -->
        <div
          class="snap-start shrink-0 w-[85vw] sm:w-[400px] h-[480px] bg-white border border-[#EAE6DF] rounded-[2rem] p-10 flex flex-col justify-between hover:border-[#C05C47] transition-colors group"
        >
          <span
            class="material-symbols-outlined text-[3rem] text-[#7A7369] bg-[#F9F8F6] w-16 h-16 rounded-2xl flex items-center justify-center group-hover:text-[#C05C47] group-hover:bg-[#C05C47]/10 transition-colors"
            >air</span
          >
          <div>
            <h3 class="text-3xl font-serif mb-4 text-[#2C2A28] leading-tight">
              Ansiedad y estrés
            </h3>
            <p class="text-[#5C574F] font-light leading-relaxed">
              Cuando el cuerpo y la mente no paran, aunque no haya una razón
              clara. Esa sensación de alerta constante que agota y no permite
              descansar.
            </p>
          </div>
        </div>

        <!-- Depresión -->
        <div
          class="snap-start shrink-0 w-[85vw] sm:w-[400px] h-[480px] bg-white border border-[#EAE6DF] rounded-[2rem] p-10 flex flex-col justify-between hover:border-[#C05C47] transition-colors group"
        >
          <span
            class="material-symbols-outlined text-[3rem] text-[#7A7369] bg-[#F9F8F6] w-16 h-16 rounded-2xl flex items-center justify-center group-hover:text-[#C05C47] group-hover:bg-[#C05C47]/10 transition-colors"
            >cloud</span
          >
          <div>
            <h3 class="text-3xl font-serif mb-4 text-[#2C2A28] leading-tight">
              Depresión y ánimo
            </h3>
            <p class="text-[#5C574F] font-light leading-relaxed">
              La tristeza que se instala de forma prolongada, la falta de
              energía persistente y el alejamiento paulatino de lo que antes
              importaba.
            </p>
          </div>
        </div>

        <!-- Soledad -->
        <div
          class="snap-start shrink-0 w-[85vw] sm:w-[400px] h-[480px] bg-[#EFECE7] border border-[#EAE6DF] rounded-[2rem] p-10 flex flex-col justify-between hover:border-[#C05C47] transition-colors group"
        >
          <span
            class="material-symbols-outlined text-[3rem] text-[#2C2A28] bg-white w-16 h-16 rounded-2xl flex items-center justify-center"
            >person</span
          >
          <div>
            <h3 class="text-3xl font-serif mb-4 text-[#2C2A28] leading-tight">
              Soledad
            </h3>
            <p class="text-[#5C574F] font-light leading-relaxed">
              No siempre es fácil de nombrar, pero es uno de los malestares más
              comunes en quienes viven lejos de su red afectiva. A veces convive
              con una vida aparente.
            </p>
          </div>
        </div>

        <!-- Identidad & Crisis -->
        <div
          class="snap-start shrink-0 w-[85vw] sm:w-[400px] h-[480px] bg-white border border-[#EAE6DF] rounded-[2rem] p-10 flex flex-col justify-between hover:border-[#C05C47] transition-colors group"
        >
          <span
            class="material-symbols-outlined text-[3rem] text-[#7A7369] bg-[#F9F8F6] w-16 h-16 rounded-2xl flex items-center justify-center group-hover:text-[#C05C47] group-hover:bg-[#C05C47]/10 transition-colors"
            >route</span
          >
          <div>
            <h3 class="text-3xl font-serif mb-4 text-[#2C2A28] leading-tight">
              Crisis e Identidad
            </h3>
            <p class="text-[#5C574F] font-light leading-relaxed">
              Separaciones, pérdidas, cambios grandes. Preguntas sobre quién
              sos, qué querés, cómo te relacionás. Momentos que sacuden lo que
              creías claro.
            </p>
          </div>
        </div>

        <!-- Vínculos & Trauma -->
        <div
          class="snap-start shrink-0 w-[85vw] sm:w-[400px] h-[480px] bg-white border border-[#EAE6DF] rounded-[2rem] p-10 flex flex-col justify-between hover:border-[#C05C47] transition-colors group"
        >
          <span
            class="material-symbols-outlined text-[3rem] text-[#7A7369] bg-[#F9F8F6] w-16 h-16 rounded-2xl flex items-center justify-center group-hover:text-[#C05C47] group-hover:bg-[#C05C47]/10 transition-colors"
            >healing</span
          >
          <div>
            <h3 class="text-3xl font-serif mb-4 text-[#2C2A28] leading-tight">
              Trauma y Vínculos
            </h3>
            <p class="text-[#5C574F] font-light leading-relaxed">
              Dificultades en las relaciones, patrones que se repiten.
              Experiencias que dejaron marca y que siguen apareciendo. Se
              trabaja con cuidado y tiempo.
            </p>
          </div>
        </div>

        <!-- Spacer -->
        <div class="snap-start shrink-0 w-6"></div>
      </div>
    </section>

    <!-- Enfoque: Objetivo y Método (Estilo Editorial, tipografía grande, fondos limpios) -->
    <section id="enfoque" class="py-32 px-6 bg-white">
      <div class="max-w-[1000px] mx-auto space-y-32">
        <!-- Objetivo -->
        <div class="text-center">
          <span
            class="material-symbols-outlined text-[3rem] text-[#EAE6DF] mb-6"
            >explore</span
          >
          <h2
            class="text-4xl md:text-5xl font-serif text-[#2C2A28] mb-8 leading-tight"
          >
            El Objetivo: Un espacio propio, <br />en tu idioma y cultura.
          </h2>
          <div
            class="text-xl md:text-2xl text-[#5C574F] font-light leading-relaxed space-y-6"
          >
            <p>
              Acompañar a personas hispanohablantes que viven lejos de su país a
              transitar sus procesos emocionales sintiéndose comprendidos de
              raíz.
            </p>
            <p class="text-[#2C2A28] font-medium">
              Creemos que la terapia es una herramienta de crecimiento, no solo
              de alivio del síntoma.
            </p>
          </div>
        </div>

        <!-- Método -->
        <div class="text-center relative">
          <!-- Decorative line -->
          <div
            class="absolute left-1/2 -top-16 bottom-auto w-px h-12 bg-[#EAE6DF] transform -translate-x-1/2"
          >
          </div>

          <span
            class="material-symbols-outlined text-[3rem] text-[#C05C47] mb-6"
            >psychology</span
          >
          <h2
            class="text-4xl md:text-5xl font-serif text-[#2C2A28] mb-8 leading-tight"
          >
            El Método: No aplicamos un modelo rígido.
          </h2>
          <div
            class="text-xl md:text-2xl text-[#5C574F] font-light leading-relaxed space-y-6"
          >
            <p>
              Trabajamos desde un enfoque integrativo y basado en evidencia,
              combinando herramientas de distintas corrientes terapéuticas según
              las necesidades de cada persona.
            </p>
            <p class="text-[#C05C47] font-serif italic text-3xl mt-8">
              Construimos el proceso junto con vos.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Corte Duro a Sección Oscura: Tarifas y Planes -->
    <section id="tarifas" class="bg-[#1D1C1A] text-white py-32 px-6">
      <div class="max-w-[1200px] mx-auto">
        <div class="text-center mb-20">
          <h2 class="text-5xl md:text-6xl font-serif mb-6 text-[#F9F8F6]">
            Planes y Precios
          </h2>
          <p class="text-[#A59F95] text-lg font-light max-w-2xl mx-auto">
            Transparencia en nuestros honorarios para que puedas planificar tu
            proceso con total tranquilidad.
          </p>
        </div>

        <!-- Cards de Precios Grandes -->
        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-10"
        >
          <!-- Consulta Inicial -->
          <div
            class="bg-[#262422] rounded-[2rem] p-10 md:p-14 border border-[#3A3733] hover:border-[#7A7369] transition-colors flex flex-col justify-between"
          >
            <div>
              <div class="flex justify-between items-center mb-6">
                <h3 class="text-3xl font-serif">Consulta inicial</h3>
                <span class="material-symbols-outlined text-[#A59F95] text-3xl"
                  >forum</span
                >
              </div>
              <p class="text-[#A59F95] font-light mb-8 leading-relaxed">
                Para conocernos, evaluar tu situación personal y decidir si
                somos el equipo adecuado para acompañarte en tu proceso.
              </p>

              <div
                class="flex items-center gap-2 text-[#A59F95] mb-6 text-sm font-medium uppercase tracking-widest"
              >
                <span class="material-symbols-outlined text-[18px]"
                  >schedule</span
                > 20 minutos
              </div>
            </div>

            <div>
              <div class="flex items-baseline gap-3 mb-8">
                <span class="text-5xl md:text-6xl font-serif">€20</span>
                <span class="text-[#A59F95] text-lg font-light">/ $20 USD</span>
              </div>
              <a
                href="#contacto"
                class="block w-full py-4 text-center border border-[#A59F95] text-[#F9F8F6] rounded-full font-medium hover:bg-white hover:text-[#1D1C1A] transition-colors"
              >
                Agendar consulta
              </a>
            </div>
          </div>

          <!-- Sesión Individual -->
          <div
            class="bg-[#C05C47] rounded-[2rem] p-10 md:p-14 flex flex-col justify-between relative transform md:-translate-y-4 shadow-2xl shadow-[#C05C47]/10"
          >
            <div
              class="absolute top-6 right-8 bg-[#1D1C1A] text-white text-[10px] font-bold uppercase tracking-widest py-1.5 px-4 rounded-full"
            >
              Servicio Principal
            </div>
            <div>
              <div class="flex justify-between items-center mb-6">
                <h3 class="text-3xl font-serif">Sesión individual</h3>
                <span class="material-symbols-outlined text-white/80 text-3xl"
                  >person</span
                >
              </div>
              <p class="text-white/80 font-light mb-8 leading-relaxed">
                Tu espacio semanal o quincenal para trabajar a fondo en tu
                bienestar emocional, en tu idioma y con absoluta
                confidencialidad.
              </p>

              <div
                class="flex items-center gap-2 text-white/90 mb-6 text-sm font-medium uppercase tracking-widest"
              >
                <span class="material-symbols-outlined text-[18px]"
                  >schedule</span
                > 50 minutos
              </div>
            </div>

            <div>
              <div class="flex items-baseline gap-3 mb-8">
                <span class="text-5xl md:text-6xl font-serif">€32</span>
                <span class="text-white/70 text-lg font-light">/ $35 USD</span>
              </div>
              <a
                href="#contacto"
                class="block w-full py-4 text-center bg-[#1D1C1A] text-white rounded-full font-medium hover:bg-white hover:text-[#1D1C1A] transition-colors"
              >
                Reservar sesión
              </a>
            </div>
          </div>
        </div>

        <!-- Beca (Formato Banner Pequeño) -->
        <div
          class="max-w-4xl mx-auto bg-[#262422] border border-[#3A3733] rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between gap-6 hover:border-[#C05C47]/50 transition-colors"
        >
          <div class="flex items-center gap-5">
            <span class="material-symbols-outlined text-[#C05C47] text-[2rem]"
              >volunteer_activism</span
            >
            <div>
              <h4 class="text-xl font-serif text-white">Programa de Beca</h4>
              <p class="text-[#A59F95] text-sm font-light mt-1">
                Precio diferencial sujeto a evaluación. Sesiones de 50 min.
              </p>
            </div>
          </div>
          <a
            href="#contacto"
            class="px-6 py-2.5 text-sm font-medium border border-[#C05C47] text-[#C05C47] rounded-full hover:bg-[#C05C47] hover:text-white transition-colors whitespace-nowrap"
          >
            A consultar
          </a>
        </div>

        <!-- Accesibilidad (Texto Editorial Limpio) -->
        <div
          class="max-w-3xl mx-auto mt-24 text-center border-t border-[#3A3733] pt-16"
        >
          <h4
            class="text-[#A59F95] text-xs font-bold tracking-widest uppercase mb-6"
          >
            Compromiso de Accesibilidad
          </h4>
          <p
            class="text-xl md:text-2xl font-light text-[#F9F8F6] leading-relaxed mb-6"
          >
            Creemos que el acceso a la psicoterapia de calidad no debería
            depender exclusivamente de la situación económica de cada persona.
          </p>
