        <h2
          class="text-4xl md:text-5xl font-display text-brand-foreground leading-[1.1] tracking-tight max-w-2xl"
        >
          Sistema modular de formularios
        </h2>
        <p class="text-brand-muted text-lg max-w-xl leading-relaxed">
          <code class="font-mono text-sm text-brand-primary">Form.astro</code> — orquestador
          sin presentación.
          <code class="font-mono text-sm text-brand-primary"
            >LeadForm.astro</code
          > — wrapper presentacional con título, subtítulo y footer.
        </p>
      </m-col>

      <!-- Form desnuda -->
      <div class="mb-16">
        <p
          class="text-xs font-mono text-brand-muted uppercase tracking-widest mb-4"
        >
          Form.astro — sin presentación · theme="light"
        </p>
        <div
          class="border border-brand-border-subtle rounded-2xl p-8 bg-brand-surface max-w-xl"
        >
        </div>
      </div>

      <!-- LeadForm light + dark -->
      <m-row class="md:flex-row gap-8 items-start">
        <m-col>
          <p
            class="text-xs font-mono text-brand-muted uppercase tracking-widest mb-4"
          >
            LeadForm · theme="light"
          </p>
        </m-col>
        <m-col>
          <p
            class="text-xs font-mono text-brand-muted uppercase tracking-widest mb-4"
          >
            LeadForm · theme="dark"
          </p>
        </m-col>
      </m-row>
    </m-container>
  </section>

