---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/ui/Navigation.astro";
import HeroSmall from "../components/ui/HeroSmall.astro";
import ChipOvertitle from "../components/ui/ChipOvertitle.astro";
import FaqAccordion from "../components/ui/FaqAccordion.astro";
import LeadForm from "../components/ui/LeadForm.astro";
import Certificaciones from "../components/ui/Certificaciones.astro";
import Footer from "../components/ui/Footer.astro";
import Icon from "../components/ui/Icon.astro";

const BASE = import.meta.env.BASE_URL;
const { pathname } = Astro.url;
---

<Layout
  title="Google Ads | Mediabros Online"
  description="Google Ads como motor principal de generación de demanda y leads calificados"
>
  <!-- ----- HERO ----- -->
  <Navigation pathname={pathname} />
  <HeroSmall
    title="Google Ads"
    icon="ico-google-ads.png"
    subtitle="Google Ads como motor principal de generación de demanda y leads calificados"
  />

  <!-- ----- RESULTADOS MEDIBLES ----- -->
  <section id="resultados-medibles" class="py-16 md:py-24 bg-brand-fondo">
    <m-container>
      <m-row
        class="flex-col items-center gap-12 lg:flex-row lg:gap-8 lg:items-stretch"
      >
        <!-- Left Column: Content -->
        <m-col
          class="flex flex-col justify-center w-full text-sm lg:pr-8 xl:pr-16 basis-1 grow-3"
        >
          <!-- Badge -->
          <div class="mb-6 lg:mb-8">
            <ChipOvertitle text="Más leads con Google Ads" />
          </div>

          <!-- Heading -->
          <h2
            class="text-4xl md:text-5xl font-display text-brand-dark leading-[1.15] tracking-tight mb-8"
          >
            Resultados medibles
          </h2>

          <!-- Description -->
          <p class="mb-8 text-base leading-relaxed md:text-lg text-brand-gris">
            Google Ads es uno de los canales más efectivos para generar
            oportunidades comerciales cuando el objetivo es captar usuarios con
            intención real de compra o contratación. A diferencia de otros
            medios, Google permite impactar a personas que ya están buscando
            activamente una solución, un servicio o un proveedor.
          </p>

          <!-- CTA Button -->
          <a
            href="#contacto"
            class="self-start inline-flex items-center justify-center gap-2 bg-brand-celeste hover:bg-brand-celeste-hover text-white font-medium text-base px-8 py-3.5 rounded-full transition-colors shadow-blue"
          >
            Consúltanos
            <Icon name="arrow_forward" size={20} />
          </a>
        </m-col>

        <!-- Right Column: Image -->
        <m-col class="flex items-center justify-center text-sm basis-1 grow-4">
          <img
            src={`${BASE}imgs/google-ads/Google-Ads.webp`}
            alt="Google Ads"
            class="w-full h-auto rounded-lg"
          />
        </m-col>
      </m-row>
    </m-container>
  </section>

  <!-- ----- TIPOS DE CAMPAÑAS ----- -->
  <section id="tipos-campanas" class="py-16 md:py-24 bg-brand-fondo">
    <m-container class="p-8 bg-white rounded-3xl md:p-12 lg:p-16">
      <m-row
        class="flex-col items-start gap-12 lg:flex-row lg:gap-16 lg:items-center"
      >
        <!-- Left Column: Content -->
        <m-col class="flex flex-col justify-center w-full text-sm lg:w-1/2">
          <!-- Icon -->
          <span
            class="inline-flex items-center justify-center w-16 h-16 mb-6 rounded-full bg-gradient-to-tr from-brand-pastel-verde/40 to-brand-pastel-celeste/40"
          >
            <img
              src={`${BASE}iconos/ico-google-ads.png`}
              alt="Google Ads"
              class="size-16"
            />
          </span>

          <!-- Badge -->
          <div class="mb-6">
            <ChipOvertitle text="Campañas en Google Ads" />
          </div>

          <!-- Heading -->
          <h2
            class="text-4xl md:text-5xl font-display text-brand-dark leading-[1.15] tracking-tight mb-8"
          >
            Tipos de campañas de Google Ads
          </h2>

          <!-- Description -->
          <p class="text-base leading-relaxed md:text-lg text-brand-gris">
            La red publicitaria de Google Ads ofrece diferentes tipos de
            campañas para poder cumplir con los objetivos de tu empresa y captar
            a tu publico objetivo en las diferentes etapas de su proceso de
            compra.
          </p>
        </m-col>

        <!-- Right Column: Campaign List -->
        <m-col class="flex flex-col w-full text-sm shrink">
          <!-- Campaign Item 1: Google Search -->
          <div
            class="flex items-start gap-4 py-6 border-b border-brand-pastel-gris first:pt-0"
          >
            <img
              src={`${BASE}imgs/google-ads/ico-google.png`}
              alt="Google Search"
              class="size-12 shrink-0 mt-0.5"
            />
            <div>
              <h3 class="text-lg font-display text-brand-dark mb-1.5">
                Google Search
              </h3>
              <p class="text-sm leading-relaxed text-brand-gris">
                Si tu producto o servicio tiene búsquedas este tipo de campañas
                son la prioridad ya que generan tráfico caliente y conversiones.
              </p>
            </div>
          </div>

          <!-- Campaign Item 2: Google Display -->
          <div
            class="flex items-start gap-4 py-6 border-b border-brand-pastel-gris"
          >
            <img
              src={`${BASE}imgs/google-ads/ico-display.png`}
              alt="Google Display"
              class="size-12 shrink-0 mt-0.5"
            />
            <div>
              <h3 class="text-lg font-display text-brand-dark mb-1.5">
                Google Display
              </h3>
              <p class="text-sm leading-relaxed text-brand-gris">
                Ideal para darnos a conocer ó hacer seguimiento de nuestros
                clientes potenciales en la red publicitaria de sitios más
                grande.
              </p>
            </div>
          </div>

          <!-- Campaign Item 3: YouTube -->
          <div
            class="flex items-start gap-4 py-6 border-b border-brand-pastel-gris"
          >
            <img
              src={`${BASE}imgs/google-ads/ico-youtube.png`}
              alt="YouTube"
              class="size-12 shrink-0 mt-0.5"
            />
            <div>
              <h3 class="text-lg font-display text-brand-dark mb-1.5">
                YouTube
              </h3>
              <p class="text-sm leading-relaxed text-brand-gris">
                Con una gran variedad de formatos podemos encontrar a nuestro
                público objetivo cuando mira contenidos en YouTube.
              </p>
            </div>
          </div>

          <!-- Campaign Item 4: Max Performance -->
          <div
            class="flex items-start gap-4 py-6 border-brand-pastel-gris last:pb-0"
          >
            <img
              src={`${BASE}imgs/google-ads/ico-max-perfo.png`}
              alt="Max Performance"
              class="size-12 shrink-0 mt-0.5"
            />
            <div>
              <h3 class="text-lg font-display text-brand-dark mb-1.5">
                Max Performance
              </h3>
              <p class="text-sm leading-relaxed text-brand-gris">
                Campañas basadas en objetivos que permiten acceder a todo el
                inventario de la red publicitaria de Google y encontrar a tu
                público.
              </p>
            </div>
          </div>
        </m-col>
      </m-row>
    </m-container>
  </section>

  <!-- ----- ¿POR QUÉ GOOGLE ADS? ----- -->
  <section id="por-que-google-ads" class="py-16 md:py-24 bg-brand-fondo">
    <m-container>
      <!-- Header Section -->
      <header class="flex flex-col items-center mb-12 text-center md:mb-16">
        <!-- Badge -->
        <div class="flex justify-center mb-6">
          <ChipOvertitle text="Más leads con Google Ads" />
        </div>

        <!-- Heading -->
        <h2
          class="text-4xl md:text-5xl font-display text-brand-dark leading-[1.15] tracking-tight mb-8 mx-auto"
        >
          ¿Por qué Google Ads es clave para tu empresa?
        </h2>

        <!-- Description -->
        <p class="mx-auto text-base leading-relaxed md:text-lg text-brand-gris">
          Google Ads permite conectar la oferta de una empresa con la demanda
          existente en el mercado. Cuando alguien busca un servicio o solución
          específica, la intención ya está creada. El desafío no es generar
          interés, sino <strong
            >estar presente en el momento correcto con el mensaje adecuado.</strong
          >
        </p>
      </header>

      <!-- Content Rows -->
      <m-row class="flex-col gap-12 lg:flex-row lg:gap-16 lg:items-center">
        <!-- Left Column: List -->
        <m-col class="flex flex-col w-full text-sm lg:w-1/2">
          <h3 class="text-2xl md:text-[28px] font-display text-brand-dark mb-8">
            Especialmente efectivo cuando:
          </h3>
          <ul class="space-y-4">
            <li class="flex items-center gap-3">
              <span
                class="flex items-center justify-center size-10 rounded-full bg-[#dcecfc] shrink-0"
              >
                <Icon
                  name="check"
                  size={20}
                  class="stroke-2 text-brand-celeste"
                />
              </span>
              <span class="text-base text-brand-gris"
                >El proceso de decisión comienza con una búsqueda.</span
              >
            </li>
            <li class="flex items-center gap-3">
              <span
                class="flex items-center justify-center size-10 rounded-full bg-[#dcecfc] shrink-0"
              >
                <Icon
                  name="check"
                  size={20}
                  class="stroke-2 text-brand-celeste"
                />
              </span>
              <span class="text-base text-brand-gris"
                >El ticket promedio justifica una inversión publicitaria.</span
              >
            </li>
            <li class="flex items-center gap-3">
              <span
                class="flex items-center justify-center size-10 rounded-full bg-[#dcecfc] shrink-0"
              >
                <Icon
                  name="check"
                  size={20}
                  class="stroke-2 text-brand-celeste"
                />
              </span>
              <span class="text-base text-brand-gris"
                >Se busca captar leads con intención concreta.</span
              >
            </li>
            <li class="flex items-center gap-3">
              <span
                class="flex items-center justify-center size-10 rounded-full bg-[#dcecfc] shrink-0"
              >
                <Icon
                  name="check"
                  size={20}
                  class="stroke-2 text-brand-celeste"
                />
              </span>
              <span class="text-base text-brand-gris"
                >El negocio necesita resultados medibles y escalables.</span
              >
            </li>
          </ul>
        </m-col>

        <!-- Right Column: Text Card -->
        <m-col class="flex flex-col w-full text-sm lg:w-1/2">
          <div
            class="flex flex-col items-center p-8 text-center bg-brand-celeste/20 rounded-2xl md:p-12"
          >
            <div
              class="flex items-center justify-center w-12 h-12 mb-8 text-white rounded-full bg-brand-dark"
            >
              <Icon name="emoji_events" size={24} />
            </div>
            <p
              class="text-[17px] md:text-[19px] text-brand-dark/90 leading-relaxed mx-auto"
            >
              Somos expertos en el diseño de estrategias de Google Ads,
              enfocadas en transformar búsquedas en clientes. Nos enfocamos
              maximizar resultados con crecimiento real para tu negocio, con a
              un flujo continuo de optimización basado en datos
            </p>
          </div>
        </m-col>
      </m-row>
    </m-container>
  </section>

  <!-- ----- BANNER CTA ----- -->
  <section id="banner-cta" class="py-16 md:py-24 bg-brand-fondo">
    <m-container
      class="relative flex items-center p-6 overflow-hidden bg-brand-dark rounded-xl shadow-blue md:p-10 lg:p-10"
    >
      <div
        class="absolute top-0 left-100 -translate-x-1/2 w-full h-100 bg-brand-dark opacity-20 blur-[120px] rounded-full pointer-events-none z-1"
      >
      </div>

      <m-row
        class="relative z-10 flex-col items-center w-full gap-12 lg:flex-row lg:gap-16"
      >
        <!-- Left Side: Text Content -->
        <m-col class="flex text-white grow-2">
          <!-- Badge -->
          <div class="mb-6">
            <ChipOvertitle text="Google Ads" theme="dark" />
          </div>

          <!-- Heading -->
          <h2
            class="mb-8 text-4xl tracking-tight md:text-4xl font-display leading"
          >
            ¿Es el canal adecuado para tu empresa?
          </h2>

          <!-- Description -->
          <p class="text-base leading-relaxed text-white/90">
            Podemos analizar tu mercado, tu ticket promedio y tu estrategia
            actual para definir cómo aprovechar Google Ads dentro de un plan de
            generación de demanda.
          </p>
        </m-col>

        <!-- Right Side: CTA Button -->
        <m-col class="flex items-center justify-center">
          <a
            href="#contacto"
            class="inline-flex items-center justify-center gap-2 bg-brand-celeste hover:bg-brand-celeste-hover text-white font-medium text-base px-8 py-3.5 rounded-full transition-colors shadow-blue"
          >
            Consúltanos
            <Icon name="arrow_forward" size={20} />
          </a>
        </m-col>
      </m-row>
    </m-container>
  </section>

  <!-- ----- FAQs ----- -->
  <section id="faqs" class="py-16 bg-white md:py-24">
    <m-container>
      <!-- Section Header -->
      <header class="mb-12 text-center md:mb-16">
        <!-- Badge -->
        <div class="mb-6">
          <ChipOvertitle text="Preguntas Frecuentes" />
        </div>

        <!-- Heading -->
        <h2
          class="text-4xl md:text-5xl font-display text-brand-dark leading-[1.1] tracking-tight"
        >
          Aprende todo sobre Google Ads
        </h2>
      </header>

      <!-- FAQs List -->
      <div class="w-full mx-auto space-y-4">
        <FaqAccordion question="¿Qué es Google Ads?">
          <p class="text-sm leading-relaxed md:text-base text-brand-gris">
            <strong>Google Ads</strong> es una plataforma publicitaria desarrollada
            por <strong>Google</strong>, que permite a los anunciantes mostrar
            anuncios relevantes y específicos en los resultados de búsqueda de <strong
              >Google</strong
            >, en sitios web que forman parte de la red de <strong
              >Google</strong
            >. Anteriormente conocida como <strong>Google AdWords</strong>, <strong
              >Google Ads</strong
            > funciona mediante un sistema de subasta donde los anunciantes pujan
            por la oportunidad de mostrar sus anuncios a los usuarios que realizan
            búsquedas utilizando palabras clave específicas o que visitan sitios web
            relevantes para sus productos o servicios. Los anuncios pueden aparecer
            en forma de texto, imágenes, videos o en otros formatos, y los anunciantes
            solo pagan cuando los usuarios hacen clic en sus anuncios o realizan ciertas
            acciones predefinidas, como completar un formulario o realizar una compra.
            <strong>Google Ads</strong> es una herramienta poderosa para las empresas
            que desean aumentar su visibilidad en línea, generar tráfico a su sitio
            web y alcanzar a su audiencia objetivo de manera efectiva.
          </p>
        </FaqAccordion>

        <FaqAccordion question="¿Cómo funciona Google Ads?">
          <p class="text-sm leading-relaxed md:text-base text-brand-gris">
            <strong>Google Ads</strong> funciona mediante un sistema de subastas.
            Cuando un usuario realiza una búsqueda, <strong>Google Ads</strong> realiza
            una subasta en tiempo real entre los anunciantes que han pujado por las
            palabras clave relevantes para esa búsqueda. El anuncio que gana la subasta
            es el que se muestra al usuario en la primera posición.
          </p>
        </FaqAccordion>

        <FaqAccordion question="¿Cuánto cuesta Google Ads?">
          <p class="text-sm leading-relaxed md:text-base text-brand-gris">
            El costo de <strong>Google Ads</strong> depende de varios factores, como
            el presupuesto que establezcas, las palabras clave por las que pujas,
            la calidad de tus anuncios y la relevancia de tu público objetivo. No
            hay un costo mínimo para utilizar <strong>Google Ads</strong>, y
            puedes establecer un presupuesto diario o mensual que se ajuste a
            tus necesidades.
          </p>
        </FaqAccordion>

        <FaqAccordion
          question="¿Qué tipos de anuncios puedo crear con Google Ads?"
        >
          <p class="mb-3 text-sm leading-relaxed md:text-base text-brand-gris">
            <strong>Google Ads</strong> ofrece una variedad de tipos de anuncios,
            incluyendo:
          </p>
          <ul class="space-y-2 text-sm md:text-base text-brand-gris">
            <li>
              <strong>Anuncios de texto:</strong> Son anuncios breves que aparecen
              en los resultados de búsqueda de <strong>Google</strong>.
            </li>
            <li>
              <strong>Anuncios gráficos:</strong> Son anuncios que incluyen imágenes
              o videos, y se pueden mostrar en sitios web asociados y aplicaciones
              móviles.
            </li>
            <li>
              <strong>Anuncios de video:</strong> Son anuncios que se reproducen automáticamente
              cuando un usuario visita un sitio web o una aplicación móvil.
            </li>
            <li>
              <strong>Anuncios de shopping:</strong> Son anuncios que muestran productos
              con su precio e imagen, y permiten a los usuarios comprar directamente
              desde el anuncio.
            </li>
          </ul>
        </FaqAccordion>

        <FaqAccordion
          question="¿Cómo puedo medir el rendimiento de mis campañas de Google Ads?"
        >
          <p class="mb-3 text-sm leading-relaxed md:text-base text-brand-gris">
            <strong>Google Ads</strong> ofrece una variedad de herramientas para medir
            el rendimiento de tus campañas, como:
          </p>
          <ul class="space-y-2 text-sm md:text-base text-brand-gris">
            <li>
              <strong>Impresiones:</strong> El número de veces que se ha mostrado
              tu anuncio.
            </li>
            <li>
              <strong>Clics:</strong> El número de veces que se ha hecho clic en tu
              anuncio.
            </li>
            <li>
              <strong>CTR (tasa de clics):</strong> El porcentaje de impresiones que
              ha resultado en un clic.
            </li>
            <li>
              <strong>Conversiones:</strong> El número de veces que un usuario ha
              realizado una acción deseada, como realizar una compra o registrarse
              para recibir un boletín informativo.
            </li>
          </ul>
        </FaqAccordion>

        <FaqAccordion
          question="¿Cómo puedo usar Google Ads para promocionar mis servicios?"
        >
          <p class="text-sm leading-relaxed md:text-base text-brand-gris">
            <strong>Google Ads</strong> ofrece una variedad de herramientas para que
            las empresas de servicios promocionen sus servicios, como anuncios de
            texto, anuncios gráficos, anuncios de video y anuncios de shopping. Puedes
            usar estas herramientas para llegar a clientes potenciales que buscan
            servicios como los tuyos en tu área local.
          </p>
        </FaqAccordion>

        <FaqAccordion
          question="¿Cómo puedo usar Google Ads para generar leads para mi empresa de servicios?"
        >
          <p class="text-sm leading-relaxed md:text-base text-brand-gris">
            <strong>Google Ads</strong> puede ser una herramienta eficaz para generar
            leads para tu empresa de servicios. Puedes utilizar formularios de leads
            en tus anuncios para capturar la información de contacto de los clientes
            potenciales, y luego puedes utilizar esa información para seguir adelante
            con ellos.
          </p>
        </FaqAccordion>

        <FaqAccordion
          question="¿Cómo puedo usar Google Ads para promocionar ofertas especiales y descuentos?"
        >
          <p class="text-sm leading-relaxed md:text-base text-brand-gris">
            <strong>Google Ads</strong> te permite promocionar ofertas especiales
            y descuentos en tus anuncios. Esto puede ser una excelente manera de atraer
            nuevos clientes y aumentar tus ventas.
          </p>
        </FaqAccordion>

        <FaqAccordion
          question="¿Cómo puedo usar Google Ads para reorientar a los clientes que ya han visitado mi sitio web?"
        >
          <p class="text-sm leading-relaxed md:text-base text-brand-gris">
            <strong>Google Ads</strong> te permite reorientar a los clientes que ya
            han visitado tu sitio web. Esto puede ser una excelente manera de mantener
            a los clientes interesados en tu negocio y animarlos a volver a tu sitio
            web.
          </p>
        </FaqAccordion>
      </div>
    </m-container>
  </section>

  <!-- ----- CONTACTO ----- -->
  <section id="contacto" class="py-14 md:py-24 bg-brand-fondo">
    <m-container class="relative w-full overflow-hidden rounded-xl shadow-blue">
      <div class="absolute inset-0 bg-brand-celeste/90">
        <img
          src={`${BASE}home/bg.team.webp`}
          alt="Fondo de equipo trabajando"
          class="absolute inset-0 object-cover w-full opacity-8 mix-blend-luminosity h-[150%] -top-70"
        />
      </div>

      <!-- Content -->
      <div class="relative z-10 p-6 md:p-10 lg:p-10">
        <m-row class="flex-col items-center gap-12 lg:flex-row">
          <!-- Left Column: Text Content -->
          <m-col class="flex-1 w-full lg:w-1/2">
            <div>
              <!-- Tag/Badge -->
              <div class="mb-8">
                <ChipOvertitle text="Conversemos" theme="dark" />
              </div>

              <!-- Heading -->
              <h2
                class="mb-6 text-4xl leading-tight text-white md:text-5xl lg:text-6xl font-display"
              >
                Apasionados por el Marketing Digital
              </h2>

              <!-- Description -->
              <p class="leading-relaxed text-white/90">
                Desarrollamos estrategias de marketing digital para nuestros
                clientes, desde la etapa de planeamiento hasta la implementación
                de campañas de marketing digital, medición de resultados y
                asesoramiento personalizado.
              </p>
            </div>
          </m-col>

          <!-- Right Column: Form -->
          <m-col class="flex-1 w-full lg:w-1/2">
            <LeadForm theme="light" />
          </m-col>
        </m-row>
      </div>
    </m-container>
  </section>

  <!-- ----- CERTIFICACIONES & FOOTER ----- -->
  <Certificaciones />
  <Footer />
</Layout>
