---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/ui/Navigation.astro";
import HeroSmall from "../components/ui/HeroSmall.astro";
import Certificaciones from "../components/ui/Certificaciones.astro";
import Footer from "../components/ui/Footer.astro";
import ContactSection from "../components/ui/ContactSection.astro";
import ResultadosMedibles from "../components/google-ads/ResultadosMedibles.astro";
import TiposCampanas from "../components/google-ads/TiposCampanas.astro";
import PorQueGoogleAds from "../components/google-ads/PorQueGoogleAds.astro";
import CtaBanner from "../components/google-ads/CtaBanner.astro";
import FaqsSection from "../components/google-ads/FaqsSection.astro";

const { pathname } = Astro.url;
---

<Layout
  title="Google Ads | Mediabros Online"
  description="Google Ads como motor principal de generación de demanda y leads calificados"
>
  <!-- ----- HERO ----- -->
  <Navigation pathname={pathname} />
  <HeroSmall
    title="Google Ads"
    icon="ico-google-ads.png"
    subtitle="Google Ads como motor principal de generación de demanda y leads calificados"
  />

  <ResultadosMedibles />
  <TiposCampanas />
  <PorQueGoogleAds />
  <CtaBanner />
  <FaqsSection />

  <ContactSection />

  <Certificaciones />
  <Footer />
</Layout>
