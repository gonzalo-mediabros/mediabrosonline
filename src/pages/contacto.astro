---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/ui/Navigation.astro";
import HeroSmall from "../components/ui/HeroSmall.astro";
import Breadcrumb from "../components/atoms/Breadcrumb.astro";
import ContactSection from "../components/ui/ContactSection.astro";
import Certificaciones from "../components/ui/Certificaciones.astro";
import Footer from "../components/ui/Footer.astro";

const { pathname } = Astro.url;

const SEO = {
  title: "Contacto - Envianos tu consulta! | MediaBros",
  description: "Con sede central en Buenos Aires, brindamos servicios de marketing digital en todo Latinoamérica, Estados Unidos, Canadá y varios países de Europa.",
  canonicalURL: new URL(Astro.url.pathname, Astro.site ?? Astro.url).href,
  ogType: "website",
  noindex: false,
};
---

<Layout {...SEO}>
  <Navigation pathname={pathname} />

  <HeroSmall
    title="Contacto"
    subtitle="La comunicación es una ventana de oportunidades."
  />

  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Contacto" }]} />

  <ContactSection />

  <Certificaciones />
  <Footer />
</Layout>
