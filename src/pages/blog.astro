---
import BlogListLayout from "../layouts/BlogListLayout.astro";
import { fetchPostsPaginated, fetchPosts } from "../lib/wordpress";

const [{ posts, totalPages }, recentPosts] = await Promise.all([
  fetchPostsPaginated(1, 9),
  fetchPosts(4),
]);
---

<BlogListLayout
  title="Blog | Mediabros"
  description="Noticias, novedades y estrategias de marketing digital de Mediabros"
  heroTitle="Blog"
  breadcrumbItems={[{ label: "Inicio", href: "/" }, { label: "Blog" }]}
  posts={posts}
  totalPages={totalPages}
  currentPage={1}
  recentPosts={recentPosts}
  baseUrl="/blog"
/>
