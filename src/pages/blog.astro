---
import BlogListLayout from "../layouts/BlogListLayout.astro";
import { fetchPostsPaginated, fetchPosts } from "../lib/wordpress";

const [{ posts, totalPages }, recentPosts] = await Promise.all([
  fetchPostsPaginated(1, 9),
  fetchPosts(4),
]);

const SEO = {
  title: "Blog de Marketing Digital | Mediabros Online",
  description: "Artículos, guías y novedades sobre marketing digital, Google Ads, SEO y redes sociales. Blog de Mediabros, agencia Google Partner Premier.",
  canonicalURL: new URL(Astro.url.pathname, Astro.site ?? Astro.url).href,
  ogType: "website" as const,
  ogImage: undefined,
  ogImageAlt: "Blog de Marketing Digital | Mediabros Online",
  noindex: false,
};
---

<BlogListLayout
  {...SEO}
  heroTitle="Blog"
  breadcrumbItems={[{ label: "Inicio", href: "/" }, { label: "Blog" }]}
  posts={posts}
  totalPages={totalPages}
  currentPage={1}
  recentPosts={recentPosts}
  baseUrl="/blog"
/>
